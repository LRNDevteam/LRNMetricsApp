@model LabMetricsDashboard.Models.AdminViewModel
@{
    ViewData["Title"] = "Admin - Assign User Labs";
}

<h2>Assign User Labs</h2>
<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <form id="frmAssignLabPage" method="post" asp-action="AssignUserLab">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label">User</label>
                        <select class="form-select" id="mapUserSelectPage2" name="assignUserId">
                            <option value="">-- select user --</option>
                            @foreach(var u in Model.Users){<option value="@u.LabUserID">@u.UserName</option>}
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Lab</label>
                        <select class="form-select" id="mapLabSelectPage" name="labId"></select>
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-primary">Assign Lab</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <h5>Assigned Labs</h5>
        <table class="table table-sm" id="tblUserLabsPage"><thead><tr><th>Lab</th><th>Action</th></tr></thead><tbody></tbody></table>
    </div>
</div>

@await Html.PartialAsync("_AdminScripts")
