@model IEnumerable<LabMetricsDashboard.Models.Lab>
@{
    ViewData["Title"] = "Admin - Manage Labs";
    var totalCount    = Model.Count();
    var activeCount   = Model.Count(l => l.IsActive);
    var inactiveCount = totalCount - activeCount;
}

<style>
    .lab-page-header {
        background: linear-gradient(135deg,#0d1b2a 0%,#1b3a5c 55%,#1565c0 100%);
        color:#fff; border-radius:18px;
        padding:1.1rem 1.4rem; margin-bottom:1.25rem;
        box-shadow:0 6px 22px rgba(13,27,42,.18);
        display:flex; flex-wrap:wrap; align-items:center; gap:1rem;
    }
    .lab-page-header h2 { margin:0; font-weight:800; letter-spacing:.02em; }
    .lab-page-header .subtitle { color:rgba(255,255,255,.78); font-size:.86rem; }
    .lab-stat {
        background:rgba(255,255,255,.12);
        border:1px solid rgba(255,255,255,.22);
        border-radius:14px; padding:.55rem 1rem;
        display:flex; align-items:center; gap:.55rem;
        font-size:.78rem; font-weight:700; letter-spacing:.04em;
    }
    .lab-stat .num { font-size:1.15rem; font-weight:800; }
    .lab-stat.ok    { background:rgba(31,138,76,.22);   border-color:rgba(31,138,76,.45); }
    .lab-stat.muted { background:rgba(255,255,255,.08); border-color:rgba(255,255,255,.18); }

    .lab-card {
        background:#fff; border-radius:16px;
        box-shadow:0 2px 16px rgba(13,27,42,.08);
        overflow:hidden;
    }
    .lab-toolbar {
        display:flex; align-items:center; gap:.75rem; flex-wrap:wrap;
        padding:.85rem 1rem; border-bottom:1px solid #eef2f7;
        background:#f8fafc;
    }
    .lab-search {
        flex:1; min-width:220px;
        border:1.5px solid #d0d9e8; border-radius:10px;
        padding:.45rem .85rem; font-size:.85rem;
        background:#fff;
    }
    .lab-search:focus { outline:none; border-color:#1565c0; box-shadow:0 0 0 3px rgba(21,101,192,.15); }

    .lab-table {
        width:100%; border-collapse:separate; border-spacing:0;
        font-size:.85rem;
    }
    .lab-table thead th {
        background:#f0f4f8; color:#5a6a8a;
        font-size:.7rem; font-weight:800; letter-spacing:.07em;
        text-transform:uppercase;
        padding:.7rem .9rem; text-align:left;
        border-bottom:1px solid #e4eaf3;
        white-space:nowrap;
    }
    .lab-table tbody td {
        padding:.7rem .9rem; vertical-align:middle;
        border-bottom:1px solid #eef2f7; color:#243049;
    }
    .lab-table tbody tr:hover { background:#f0f8ff; }
    .lab-table tbody tr:last-child td { border-bottom:none; }

    .lab-id-pill {
        display:inline-block; min-width:34px; text-align:center;
        background:#eef4ff; color:#1565c0;
        border:1px solid #d6e3f7; border-radius:8px;
        padding:.1em .55em; font-size:.72rem; font-weight:700;
        font-variant-numeric:tabular-nums;
    }
    .lab-name-cell { display:flex; align-items:center; gap:.6rem; }
    .lab-avatar {
        width:34px; height:34px; border-radius:10px;
        display:grid; place-items:center;
        background:linear-gradient(135deg,#1b3a5c,#1565c0);
        color:#fff; font-weight:800; font-size:.85rem;
        flex-shrink:0; box-shadow:0 3px 8px rgba(21,101,192,.25);
    }
    .lab-name-cell .name { font-weight:700; color:#1a2744; }
    .lab-status {
        display:inline-flex; align-items:center; gap:.35rem;
        border-radius:20px; padding:.18em .7em;
        font-size:.72rem; font-weight:800; letter-spacing:.04em;
    }
    .lab-status .dot { width:.5rem; height:.5rem; border-radius:50%; display:inline-block; }
    .lab-status.ok    { background:#e6f5ec; color:#1f7a3d; border:1px solid #c7e6d2; }
    .lab-status.ok .dot { background:#1f8a4c; }
    .lab-status.off   { background:#f1f3f5; color:#6c757d; border:1px solid #dee2e6; }
    .lab-status.off .dot { background:#94a3b8; }

    .lab-meta { font-size:.78rem; color:#5a6a8a; white-space:nowrap; }
    .lab-meta .who { color:#243049; font-weight:600; }

    .lab-action-btn {
        border:1.5px solid #d0d9e8; border-radius:8px;
        padding:.3rem .65rem; font-size:.76rem; font-weight:700;
        color:#1565c0; background:#fff; transition:all .15s;
        display:inline-flex; align-items:center; gap:.35rem;
    }
    .lab-action-btn:hover { border-color:#1565c0; background:#eef4ff; }

    .lab-empty {
        text-align:center; padding:3rem 1rem; color:#8a9ab8;
    }
    .lab-empty .emoji { font-size:2.5rem; opacity:.55; margin-bottom:.5rem; }

    .lab-row-hidden { display:none !important; }

    /* Modal polish */
    #createLabModal .modal-content { border-radius:16px; overflow:hidden; border:none; }
    #createLabModal .modal-header {
        background:linear-gradient(135deg,#0d1b2a,#1565c0); color:#fff; border:none;
    }
    #createLabModal .modal-header .btn-close { filter: invert(1) brightness(1.4); }
    #createLabModal .form-label { font-weight:700; font-size:.78rem;
        text-transform:uppercase; letter-spacing:.05em; color:#5a6a8a; }
    #createLabModal .form-control { border-radius:10px; padding:.55rem .85rem; }
    #createLabModal .form-control:focus { border-color:#1565c0; box-shadow:0 0 0 3px rgba(21,101,192,.15); }
</style>

<!-- Page header -->
<div class="lab-page-header">
    <div style="flex:1 1 280px">
        <h2><i class="bi bi-buildings me-2"></i>Manage Labs</h2>
        <div class="subtitle mt-1">Maintain the master list of labs available across the application.</div>
    </div>
    <div class="lab-stat muted">
        <i class="bi bi-collection"></i> Total <span class="num">@totalCount</span>
    </div>
    <div class="lab-stat ok">
        <i class="bi bi-check2-circle"></i> Active <span class="num">@activeCount</span>
    </div>
    <div class="lab-stat muted">
        <i class="bi bi-pause-circle"></i> Inactive <span class="num">@inactiveCount</span>
    </div>
    <button type="button" class="btn btn-light fw-bold"
            data-bs-toggle="modal" data-bs-target="#createLabModal"
            style="border-radius:10px;color:#1565c0">
        <i class="bi bi-plus-circle me-1"></i> Add Lab
    </button>
</div>

@if (TempData["LabSuccess"] is string okMsg && !string.IsNullOrWhiteSpace(okMsg))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-1"></i> @okMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["LabError"] is string errMsg && !string.IsNullOrWhiteSpace(errMsg))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> @errMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="lab-card">
    <div class="lab-toolbar">
        <input type="text" id="labSearch" class="lab-search" placeholder="?? Search by lab name…" autocomplete="off" />
        <span class="text-muted small" id="labSearchCount">@totalCount lab@(totalCount == 1 ? "" : "s")</span>
    </div>

    @if (!Model.Any())
    {
        <div class="lab-empty">
            <div class="emoji">??</div>
            <div class="fw-semibold">No labs configured yet.</div>
            <div class="small mt-1">Click <strong>Add Lab</strong> to create your first lab.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="lab-table" id="tblLabs">
                <thead>
                    <tr>
                        <th style="width:70px">ID</th>
                        <th>Lab Name</th>
                        <th style="width:110px">Status</th>
                        <th>Created</th>
                        <th>Modified</th>
                        <th style="width:100px;text-align:right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in Model)
                    {
                        var initial = string.IsNullOrWhiteSpace(l.LabName) ? "?" : l.LabName.Trim().Substring(0, 1).ToUpperInvariant();
                        <tr data-lab-name="@l.LabName?.ToLowerInvariant()">
                            <td><span class="lab-id-pill">@l.LabId</span></td>
                            <td>
                                <div class="lab-name-cell">
                                    <div class="lab-avatar">@initial</div>
                                    <div class="name">@l.LabName</div>
                                </div>
                            </td>
                            <td>
                                @if (l.IsActive)
                                { <span class="lab-status ok"><span class="dot"></span> Active</span> }
                                else
                                { <span class="lab-status off"><span class="dot"></span> Inactive</span> }
                            </td>
                            <td>
                                <div class="lab-meta">
                                    <span class="who">@(string.IsNullOrWhiteSpace(l.CreatedBy) ? "—" : l.CreatedBy)</span>
                                    @if (l.CreatedDate.HasValue)
                                    { <div class="text-muted">@l.CreatedDate.Value.ToString("yyyy-MM-dd HH:mm")</div> }
                                </div>
                            </td>
                            <td>
                                <div class="lab-meta">
                                    <span class="who">@(string.IsNullOrWhiteSpace(l.ModifiedBy) ? "—" : l.ModifiedBy)</span>
                                    @if (l.ModifiedDate.HasValue)
                                    { <div class="text-muted">@l.ModifiedDate.Value.ToString("yyyy-MM-dd HH:mm")</div> }
                                </div>
                            </td>
                            <td style="text-align:right">
                                <a class="lab-action-btn" asp-action="EditLab" asp-route-id="@l.LabId">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Create Lab modal -->
<div class="modal fade" id="createLabModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="frmCreateLab" method="post" asp-action="CreateLab">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-buildings me-2"></i>Add New Lab</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="createLabError" class="alert alert-danger d-none"></div>

                    <div class="mb-3">
                        <label class="form-label">Lab Name <span class="text-danger">*</span></label>
                        <input id="createLabName" name="LabName" class="form-control"
                               maxlength="200" required autocomplete="off"
                               placeholder="Enter lab name (must be unique)" />
                        <div class="invalid-feedback" id="createLabNameFeedback"></div>
                        <small id="createLabNameHint" class="form-text text-muted">Lab name must be unique.</small>
                    </div>

                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true"
                               id="createLabActive" checked />
                        <input type="hidden" name="IsActive" value="false" />
                        <label class="form-check-label" for="createLabActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="btnCreateLab">
                        <i class="bi bi-check2 me-1"></i> Create Lab
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // ?? Search filter for Labs table ???????????????????????????
    var searchEl  = document.getElementById('labSearch');
    var countEl   = document.getElementById('labSearchCount');
    var rows      = document.querySelectorAll('#tblLabs tbody tr');
    function applyLabSearch() {
        var q = (searchEl?.value || '').trim().toLowerCase();
        var visible = 0;
        rows.forEach(function (tr) {
            var name = tr.getAttribute('data-lab-name') || '';
            var match = !q || name.indexOf(q) !== -1;
            tr.classList.toggle('lab-row-hidden', !match);
            if (match) visible++;
        });
        if (countEl) countEl.textContent = visible + ' lab' + (visible === 1 ? '' : 's');
    }
    if (searchEl) searchEl.addEventListener('input', applyLabSearch);

    // ?? Create-lab modal: live duplicate check ?????????????????
    var form     = document.getElementById('frmCreateLab');
    var nameEl   = document.getElementById('createLabName');
    var fb       = document.getElementById('createLabNameFeedback');
    var hint     = document.getElementById('createLabNameHint');
    var errBox   = document.getElementById('createLabError');
    var submitBtn = document.getElementById('btnCreateLab');
    if (!form || !nameEl) return;

    var checkUrl = '@Url.Action("IsLabNameAvailable", "Admin")';
    var debounceTimer = null;
    var lastChecked = { name: '', available: true };

    function setError(msg) {
        nameEl.classList.add('is-invalid');
        if (fb) { fb.textContent = msg; }
        try { nameEl.setCustomValidity(msg); } catch (e) {}
    }
    function clearError() {
        nameEl.classList.remove('is-invalid');
        if (fb) { fb.textContent = ''; }
        try { nameEl.setCustomValidity(''); } catch (e) {}
    }

    function checkAvailability() {
        var name = (nameEl.value || '').trim();
        if (!name) { clearError(); return; }
        if (name === lastChecked.name) {
            if (!lastChecked.available) setError('A lab with this name already exists.');
            else clearError();
            return;
        }
        fetch(checkUrl + '?labName=' + encodeURIComponent(name), { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (data) {
                if (!data) return;
                lastChecked = { name: name, available: !!data.available };
                if (data.available) {
                    clearError();
                    if (hint) { hint.textContent = '? Name is available.'; hint.className = 'form-text text-success'; }
                } else {
                    setError('A lab with this name already exists.');
                    if (hint) { hint.textContent = ''; hint.className = 'form-text text-muted'; }
                }
            })
            .catch(function () { /* ignore */ });
    }

    nameEl.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(checkAvailability, 300);
    });
    nameEl.addEventListener('blur', checkAvailability);

    form.addEventListener('submit', function (e) {
        if (errBox) { errBox.classList.add('d-none'); errBox.textContent = ''; }
        var name = (nameEl.value || '').trim();
        if (!name) {
            e.preventDefault();
            setError('Lab Name is required.');
            return;
        }
        if (lastChecked.name === name && !lastChecked.available) {
            e.preventDefault();
            setError('A lab with this name already exists.');
            if (errBox) { errBox.classList.remove('d-none'); errBox.textContent = 'A lab with this name already exists.'; }
        }
    });
})();
</script>
}
