@model LabMetricsDashboard.Models.AdminViewModel
@inherits Microsoft.AspNetCore.Mvc.Razor.RazorPage<LabMetricsDashboard.Models.AdminViewModel>
@{
    ViewData["Title"] = "Admin - Users";
}

<h2>Users</h2>

<div class="card mb-3">
    <div class="card-body">
        <form id="frmCreateUserPage" method="post" asp-action="CreateUser">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="row g-2 mb-2">
                <div class="col-md-2">
                    <label class="form-label">UserName</label>
                    <input class="form-control" asp-for="NewUser.UserName" />
                    <span asp-validation-for="NewUser.UserName" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Password</label>
                    <input class="form-control" asp-for="NewUserPassword" type="password" />
                    <span asp-validation-for="NewUserPassword" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Confirm</label>
                    <input class="form-control" asp-for="NewUserConfirmPassword" type="password" />
                    <span asp-validation-for="NewUserConfirmPassword" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label">First Name</label>
                    <input class="form-control" asp-for="NewUser.FirstName" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Last Name</label>
                    <input class="form-control" asp-for="NewUser.LastName" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="d-grid">
                        <button class="btn btn-primary">Create User</button>
                    </div>
                </div>
            </div>

            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Email</label>
                    <input class="form-control" asp-for="NewUser.Email" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Mobile</label>
                    <input class="form-control" asp-for="NewUser.Mobile" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Role</label>
                    <select class="form-select" asp-for="NewUserRoleId">
                        <option value="">-- select role --</option>
                        @foreach(var r in Model.Roles)
                        {
                            <option value="@r.RoleID">@r.RoleName</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Lab</label>
                    <select class="form-select" asp-for="NewUserLabId">
                        <option value="">-- select lab --</option>
                        @foreach(var l in Model.Labs)
                        {
                            <option value="@l.LabId">@l.LabName</option>
                        }
                    </select>
                </div>
            </div>
        </form>
    </div>
</div>

<div>
    <h5>Existing Users</h5>
    <table class="table table-sm table-striped">
        <thead><tr><th>UserName</th><th>Name</th><th>Email</th><th>Mobile</th><th>Labs</th><th>Active</th><th>Actions</th></tr></thead>
        <tbody id="tblUsersBody">
            @foreach(var u in Model.Users)
            {
                <tr>
                    <td>@u.UserName</td>
                    <td>@u.FirstName @u.LastName</td>
                    <td>@u.Email</td>
                    <td>@u.Mobile</td>
                    <td><!-- labs will be populated by admin script --></td>
                    <td>@(u.IsActive?"Yes":"No")</td>
                    <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.LabUserID">Edit</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_AdminScripts")
