                                                    <div class="det-expand-block">
                                                        <div class="det-expand-label" style="color:#e65100">Additional CPTs</div>
                                                        <div class="cpt-tags">
                                                            @foreach (var t in additionalTags) { <span class="cpt-tag cpt-tag-extra">@t</span> }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
