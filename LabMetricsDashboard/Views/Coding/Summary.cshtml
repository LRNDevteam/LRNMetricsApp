                    <div class="cs-table-scroll">
                        <table class="cs-table">
                            <thead>
                                <tr>
                                    <th style="width:28px"></th>
                                    <th style="text-align:left">Panel Name</th>
                                    <th>Total No.<br/>of Claims</th>
                                    <th>Billed<br/>Charges</th>
                                    <th>Billed Charges for<br/>Missing CPTs / Units</th>
                                    <th>Revenue<br/>Loss</th>
                                    <th>Billed Charges for<br/>Additional CPTs / Units</th>
                                    <th>Potential<br/>Recoupment</th>
                                    <th>Net Impact</th>
                                </tr>
                            </thead>
                            <tbody id="tbody-wtd-insights-@week.GetHashCode()">
                                @foreach (var r in wrows)
                                {
                                    var ni = r.NetImpact;
                                    var billableTags   = r.BillableCptCombo.Split(new[]{'*',',',' '}, StringSplitOptions.RemoveEmptyEntries);
                                    var billedTags     = r.BilledCptCombo.Split(new[]{'*',',',' '}, StringSplitOptions.RemoveEmptyEntries);
                                    var missingTags    = r.MissingCpts.Split(new[]{'*',',',' '}, StringSplitOptions.RemoveEmptyEntries);
                                    var additionalTags = r.AdditionalCpts.Split(new[]{'*',',',' '}, StringSplitOptions.RemoveEmptyEntries);
                                    <tr class="row-main" data-week="@r.WeekFolder" data-panel="@r.PanelName" onclick="rowToggle(this)">
                                        <td class="row-toggle-cell"><div class="row-arrow"></div></td>
                                        <td><span class="panel-chip">@r.PanelName</span></td>
                                        <td class="r"><strong>@r.TotalClaims.ToString("N0")</strong></td>
                                        <td class="r money money-neutral">$&thinsp;@r.TotalBilledCharges.ToString("N2")</td>
                                        <td class="r money money-neutral">$&thinsp;@r.BilledChargesForMissingCpts.ToString("N2")</td>
                                        <td class="r money @(r.RevenueLoss != 0 ? "money-neg" : "money-neutral")">
                                            $&thinsp;@r.RevenueLoss.ToString("N2")
                                        </td>
                                        <td class="r money money-neutral">$&thinsp;@r.BilledChargesForAdditionalCpts.ToString("N2")</td>
                                        <td class="r money money-neutral">$&thinsp;@r.PotentialRecoupment.ToString("N2")</td>
                                        <td class="r">
                                            <span class="impact-chip @(ni < 0 ? "neg" : ni > 0 ? "pos" : "zero")">
                                                @(ni < 0 ? "-" : ni > 0 ? "+" : "")$@Math.Abs(ni).ToString("N2")
                                            </span>
                                        </td>
                                    </tr>
                                    <tr class="row-expand">
                                        <td colspan="9" class="det-expand-inner">
                                            <div class="det-expand-grid">
                                                <div class="det-expand-block">
                                                    <div class="det-expand-label">Billable CPT Codes</div>
                                                    <div class="cpt-tags">
                                                        @if (!billableTags.Any()) { <span style="color:#aaa;font-size:.72rem">�</span> }
