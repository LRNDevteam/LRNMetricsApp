@model LabMetricsDashboard.Models.CodingSummaryViewModel
@{
ViewData["Title"]       = $"Coding Summary � {Model.LabName}";
ViewData["SelectedLab"] = Model.LabName;
ViewData["PageLabel"]   = "Coding Summary";

var years = Model.InsightRows.Select(r => r.Year)
                 .Union(Model.SummaryRows.Select(r => r.Year))
                 .Distinct().OrderByDescending(y => y).ToList();

// Shared filter option lists - union across all four YTD/WTD tabs so the
// single filter bar has a complete dropdown set.
var sharedWeeks = Model.WtdInsightRows.Select(r => r.WeekFolder)
                      .Union(Model.WtdSummaryRows.Select(r => r.WeekFolder))
                      .Where(w => !string.IsNullOrWhiteSpace(w))
                      .Distinct().OrderByDescending(w => w).ToList();
var sharedPanels = Model.InsightRows.Select(r => r.PanelName)
                      .Union(Model.SummaryRows.Select(r => r.PanelName))
                      .Union(Model.WtdInsightRows.Select(r => r.PanelName))
                      .Union(Model.WtdSummaryRows.Select(r => r.PanelName))
                      .Where(p => !string.IsNullOrWhiteSpace(p))
                      .Distinct().OrderBy(p => p).ToList();

// KPI values � driven from the latest financial summary row when available,
    // falling back to aggregated SummaryRows for labs without financial data.
    var fin = Model.LatestFinancial;
    var kpiClaims     = fin?.TotalClaims     ?? Model.SummaryRows.Sum(r => r.TotalClaims);
    var kpiBilled     = fin?.TotalBilledCharges    ?? Model.SummaryRows.Sum(r => r.TotalBilledCharges);
    var kpiExpected   = fin?.ExpectedBilledCharges ?? 0m;
    var kpiLost       = fin?.RevenueLoss_PotentialLoss ?? Model.SummaryRows.Sum(r => r.LostRevenue);
    var kpiAtRisk     = fin?.RevenueAtRisk_PotentialRecoup ?? Model.SummaryRows.Sum(r => r.RevenueAtRisk);
    var kpiNetImpact  = kpiAtRisk - kpiLost;
    var kpiCompliance = fin?.ComplianceRatePct ?? string.Empty;
    var kpiWeek       = fin?.WeekFolder ?? string.Empty;
}

@functions {
    // Renders a "CPT*Units(Modifier)" comma-separated combo into styled pills.
    // variant: "billable" | "billed" | "missing" | "additional"
    // The pill container is clamped to ~3 lines via CSS; if it overflows JS
    // reveals a "+ more" toggle that expands to show all pills.
    static string FormatCptPills(string? combo, string variant)
    {
        if (string.IsNullOrWhiteSpace(combo))
            return "<span class=\"cpt-empty\">&#8212;</span>";

        var tokens = combo.Split(',', StringSplitOptions.RemoveEmptyEntries)
                          .Select(t => t.Trim())
                          .Where(t => t.Length > 0)
                          .ToList();
        if (tokens.Count == 0)
            return "<span class=\"cpt-empty\">&#8212;</span>";

        var sb = new System.Text.StringBuilder();
        sb.Append("<span class=\"cpt-pill-block\">");
        sb.Append("<span class=\"cpt-pills cpt-pills-collapsed\" data-total=\"")
          .Append(tokens.Count).Append("\">");

        foreach (var token in tokens)
        {
            string code = token;
            string? units = null, mod = null;

            var starIdx = token.IndexOf('*');
            if (starIdx >= 0)
            {
                code = token.Substring(0, starIdx).Trim();
                var rest = token.Substring(starIdx + 1).Trim();
                var lp = rest.IndexOf('(');
                if (lp >= 0)
                {
                    units = rest.Substring(0, lp).Trim();
                    var rp = rest.IndexOf(')', lp);
                    mod = rp > lp
                        ? rest.Substring(lp + 1, rp - lp - 1).Trim()
                        : rest.Substring(lp + 1).Trim();
                }
                else
                {
                    units = rest;
                }
            }

            sb.Append("<span class=\"cpt-pill cpt-pill-").Append(variant).Append("\">");
            sb.Append("<span class=\"cpt-pill-code\">").Append(System.Net.WebUtility.HtmlEncode(code)).Append("</span>");
            if (!string.IsNullOrWhiteSpace(units))
            {
                sb.Append("<span class=\"cpt-pill-units\">&times;").Append(System.Net.WebUtility.HtmlEncode(units)).Append("</span>");
            }
            if (!string.IsNullOrWhiteSpace(mod))
            {
                sb.Append("<span class=\"cpt-pill-mod\">").Append(System.Net.WebUtility.HtmlEncode(mod)).Append("</span>");
            }
            sb.Append("</span>");
        }
        sb.Append("</span>"); // /.cpt-pills

        // Toggle button starts hidden; JS reveals it only if the pills container overflows.
        sb.Append("<button type=\"button\" class=\"cpt-pill-toggle\" onclick=\"cptPillsToggle(this, event)\" ")
          .Append("data-more=\"+ more\" data-less=\"&minus; less\" aria-expanded=\"false\" ")
          .Append("style=\"display:none\">+ more</button>");

        sb.Append("</span>"); // /.cpt-pill-block
        return sb.ToString();
    }
}

