    width:46px; height:46px; border-radius:999px;
    background:rgba(255,255,255,.92); border:1px solid rgba(15,35,55,.10);
    display:grid; place-items:center; text-align:center; padding:4px;
}
.ck-ring-pct  { font-size:11px; font-weight:900; line-height:1.1; }
.ck-ring-cap  { font-size:8px; font-weight:800; color:rgba(11,31,42,.65); margin-top:1px; }
.ck-footnote  { margin-top:6px; font-size:10px; color:var(--ck-muted); font-weight:800; }

/* compliance chip */
.cs-compliance-chip {
    display:inline-block; border-radius:20px; padding:.2em .75em;
    font-size:.75rem; font-weight:800; letter-spacing:.04em;
}
.cs-compliance-chip.good { background:#e3f2fd; color:#1565c0; border:1px solid #bbdefb; }
.cs-compliance-chip.warn { background:#fff3e0; color:#e65100; border:1px solid #ffe0b2; }

@@media (max-width:960px) { .ck-grid { grid-template-columns:1fr 1fr; } }
@@media (max-width:640px) { .ck-grid { grid-template-columns:1fr; } }

