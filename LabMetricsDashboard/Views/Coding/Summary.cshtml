                                                    <div class="det-expand-block">
                                                        <div class="det-expand-label" style="color:#c62828">Missing CPTs</div>
                                                        <div class="cpt-tags">
                                                            @foreach (var t in missingTags) { <span class="cpt-tag cpt-tag-missing">@t</span> }
                                                        </div>
                                                    </div>
                                                }
                                                @if (additionalTags.Any())
