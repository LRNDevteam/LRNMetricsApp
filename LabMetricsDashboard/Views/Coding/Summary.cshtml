                                                                        <td class="cpt-cell">@Html.Raw(FormatCptPills(di.BillableCptCombo, "billable"))</td>
                                                                        <td class="r"><strong>@di.TotalClaims.ToString("N0")</strong></td>
                                                                        <td class="r money money-neutral">$&thinsp;@di.TotalBilledCharges.ToString("N2")</td>
                                                                        <td class="cpt-cell">@Html.Raw(FormatCptPills(di.BilledCptCombo, "billed"))</td>
                                                                        <td class="cpt-cell">@Html.Raw(FormatCptPills(di.MissingCpts, "missing"))</td>
                                                                        <td class="r money money-neutral">$&thinsp;@di.BilledChargesForMissingCpts.ToString("N2")</td>
                                                                        <td class="r money @(di.RevenueLoss != 0 ? "money-neg" : "money-neutral")">$&thinsp;@di.RevenueLoss.ToString("N2")</td>
                                                                        <td class="cpt-cell">@Html.Raw(FormatCptPills(di.AdditionalCpts, "additional"))</td>
                                                                        <td class="r money money-neutral">$&thinsp;@di.BilledChargesForAdditionalCpts.ToString("N2")</td>
                                                                        <td class="r money money-neutral">$&thinsp;@di.PotentialRecoupment.ToString("N2")</td>
                                                                        <td class="r">
                                                                            <span class="impact-chip @(ni < 0 ? "neg" : ni > 0 ? "pos" : "zero")">
                                                                                @(ni < 0 ? "-" : ni > 0 ? "+" : "")$@Math.Abs(ni).ToString("N2")
                                                                            </span>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

