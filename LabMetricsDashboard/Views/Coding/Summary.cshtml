    <!-- ?? Tab: Validation Detail ??????????????????????????????????????????? -->
    <div class="cs-tab-pane mt-3" id="pane-detail">
        <div class="cs-filter-bar">
            <span class="cs-filter-label">&#9660; Filter</span>
            <span class="cs-filter-label" style="margin-left:.25rem">Panel</span>
            <select id="flt-det-panel" class="cs-filter-select">
                <option value="">All Panels</option>
                @foreach (var p in Model.DetailRows.Select(r => r.PanelName).Distinct().OrderBy(x => x))
                { <option value="@p">@p</option> }
            </select>
            <span class="cs-filter-label">Status</span>
            <select id="flt-det-status" class="cs-filter-select">
                <option value="">All Statuses</option>
                @foreach (var s in Model.DetailRows.Select(r => r.ValidationStatus).Distinct().OrderBy(x => x))
                { <option value="@s">@s</option> }
            </select>
            <span class="cs-filter-label">Search</span>
            <input type="text" id="flt-det-search" class="cs-filter-select" placeholder="Accession / CPT�" style="min-width:180px" />
            <button class="cs-filter-reset" onclick="resetDetailFilter()">&#10005; Clear</button>
            <span class="cs-filter-count" id="flt-det-count"></span>
            <button type="button" class="exportCodingExcelBtn btn btn-sm btn-outline-success" style="margin-left:auto;font-size:.76rem;border-radius:20px;padding:.3em .9em">
                <i class="bi bi-file-earmark-excel me-1"></i>Download Excel
            </button>
        </div>

        @if (!Model.DetailRows.Any())
        {
            <div class="cs-table-wrap p-4">
                <div class="cs-empty">
                    <div class="cs-empty-icon">&#128203;</div>
                    <div class="fw-semibold">No validation detail rows available.</div>
                    <div class="small mt-1">Ensure CaptureDataApp has processed at least one report.</div>
                </div>
            </div>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(Model.DetailRows[0].WeekFolder))
            {
                <div style="margin-bottom:.6rem">
                    <span class="cs-year-pill" style="font-size:.78rem">&#128197;&thinsp; @Model.DetailRows[0].WeekFolder</span>
                    <span class="cs-year-count ms-2" id="det-total-count">@Model.DetailRows.Count rows</span>
                </div>
            }
            <div class="cs-table-wrap">
                <div class="cs-table-scroll">
                    <table class="cs-table" id="tbl-detail" style="min-width:780px">
                        <thead>
                            <tr>
                                <th style="width:2rem"></th>
                                <th style="text-align:left">Accession No.</th>
                                <th style="text-align:left">Panel</th>
                                <th>Date of Service</th>
                                <th>Validation Status</th>
                                <th>Total Charge</th>
                                <th>Missing Charge</th>
                                <th>Additional Charge</th>
                            </tr>
                        </thead>
                        <tbody id="tbody-detail">
                            @foreach (var r in Model.DetailRows)
                            {
                                var isMissing    = !string.IsNullOrWhiteSpace(r.MissingCPTCodes);
                                var isAdditional = !string.IsNullOrWhiteSpace(r.AdditionalCPTCodes);
                                var statusClass  = r.ValidationStatus.Contains("Valid", StringComparison.OrdinalIgnoreCase)
                                                   && !r.ValidationStatus.Contains("Invalid", StringComparison.OrdinalIgnoreCase)
                                                   ? "det-status-ok" : "det-status-err";
                                @* Split CPT strings into individual tags *@
                                var actualTags   = r.ActualCPTCode.Split(new[]{',',';',' '}, StringSplitOptions.RemoveEmptyEntries);
                                var expectedTags = r.ExpectedCPTCode.Split(new[]{',',';',' '}, StringSplitOptions.RemoveEmptyEntries);
                                var missingTags  = r.MissingCPTCodes.Split(new[]{',',';',' '}, StringSplitOptions.RemoveEmptyEntries);
                                var extraTags    = r.AdditionalCPTCodes.Split(new[]{',',';',' '}, StringSplitOptions.RemoveEmptyEntries);
                                <tr class="det-row-main"
                                    data-panel="@r.PanelName"
                                    data-status="@r.ValidationStatus"
                                    data-search="@(r.AccessionNo + " " + r.ActualCPTCode + " " + r.ExpectedCPTCode + " " + r.MissingCPTCodes)"
                                    onclick="detToggle(this)">
                                    <td class="det-toggle-cell"><div class="det-arrow"></div></td>
                                    <td class="mono">@r.AccessionNo</td>
                                    <td><span class="panel-chip">@r.PanelName</span></td>
                                    <td class="r">@r.DateofService</td>
                                    <td><span class="det-status-chip @statusClass">@r.ValidationStatus</span></td>
                                    <td class="r money-neutral">@(string.IsNullOrWhiteSpace(r.TotalCharge) ? "�" : "$\u2009" + r.TotalCharge)</td>
                                    <td class="r @(isMissing ? "money-neg" : "money-neutral")">@(string.IsNullOrWhiteSpace(r.MissingCPT_Charges) ? "�" : "$\u2009" + r.MissingCPT_Charges)</td>
                                    <td class="r @(isAdditional ? "money-warn" : "money-neutral")">@(string.IsNullOrWhiteSpace(r.AdditionalCPT_Charges) ? "�" : "$\u2009" + r.AdditionalCPT_Charges)</td>
                                </tr>
                                <tr class="det-row-expand">
                                    <td colspan="8" class="det-expand-inner">
                                        <div class="det-expand-grid">
                                            <div class="det-expand-block">
                                                <div class="det-expand-label">Actual CPT Codes</div>
                                                <div class="cpt-tags">
                                                    @if (actualTags.Length == 0){ <span style="color:#aaa;font-size:.72rem">�</span> }
                                                    @foreach (var t in actualTags){ <span class="cpt-tag cpt-tag-actual">@t</span> }
                                                </div>
                                            </div>
                                            <div class="det-expand-block">
                                                <div class="det-expand-label">Expected CPT Codes</div>
                                                <div class="cpt-tags">
                                                    @if (expectedTags.Length == 0){ <span style="color:#aaa;font-size:.72rem">�</span> }
                                                    @foreach (var t in expectedTags){ <span class="cpt-tag cpt-tag-expected">@t</span> }
                                                </div>
                                            </div>
                                            @if (isMissing)
                                            {
                                                <div class="det-expand-block">
                                                    <div class="det-expand-label" style="color:#c62828">Missing CPTs</div>
                                                    <div class="cpt-tags">
                                                        @foreach (var t in missingTags){ <span class="cpt-tag cpt-tag-missing">@t</span> }
                                                    </div>
                                                </div>
                                            }
                                            @if (isAdditional)
                                            {
                                                <div class="det-expand-block">
                                                    <div class="det-expand-label" style="color:#e65100">Additional CPTs</div>
                                                    <div class="cpt-tags">
                                                        @foreach (var t in extraTags){ <span class="cpt-tag cpt-tag-extra">@t</span> }
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(r.Remarks))
                                            {
                                                <div class="det-expand-block" style="grid-column:1/-1">
                                                    <div class="det-expand-label">Remarks</div>
                                                    <div style="font-size:.75rem;color:#4a5568">@r.Remarks</div>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Pager -->
                <div class="det-pager" id="det-pager">
                    <span class="det-pager-info" id="det-pager-info"></span>
                    <div id="det-pager-btns"></div>
                </div>
            </div>
        }
    </div><!-- /#pane-detail -->
}

@section Scripts {
<script>
(function () {
    'use strict';

    // ????????????????????????????????????????????????????????????
    // Tab switcher
    // ????????????????????????????????????????????????????????????
    document.querySelectorAll('#csTabs .cs-tab-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('#csTabs .cs-tab-btn').forEach(function (b) { b.classList.remove('active'); });
            document.querySelectorAll('.cs-tab-pane').forEach(function (p) { p.classList.remove('active'); });
            btn.classList.add('active');
            var pane = document.getElementById('pane-' + btn.dataset.tab);
            if (pane) pane.classList.add('active');
        });
    });

    // ????????????????????????????????????????????????????????????
    // Filter engine
    // Each tab config: { pane, rows selector, filter specs, count el id }
    // ????????????????????????????????????????????????????????????
    var tabFilters = [
        {
            pane:    'pane-insights',
            rowSel:  '#pane-insights tbody tr',
            countId: 'flt-shared-count',
            filters: [
                { selId: 'flt-shared-year',  attr: 'data-year'  },
                { selId: 'flt-shared-panel', attr: 'data-panel' }
            ]
        },
        {
            pane:    'pane-summary',
            rowSel:  '#pane-summary tbody tr',
            countId: 'flt-shared-count',
            filters: [
                { selId: 'flt-shared-year',  attr: 'data-year'  },
                { selId: 'flt-shared-panel', attr: 'data-panel' }
            ]
        },
        {
            pane:    'pane-wtd-insights',
            rowSel:  '#pane-wtd-insights tbody tr',
            countId: 'flt-shared-count',
            filters: [
                { selId: 'flt-shared-week',  attr: 'data-week'  },
                { selId: 'flt-shared-panel', attr: 'data-panel' }
            ]
        },
        {
            pane:    'pane-wtd-summary',
            rowSel:  '#pane-wtd-summary tbody tr',
            countId: 'flt-shared-count',
            filters: [
                { selId: 'flt-shared-week',  attr: 'data-week'  },
                { selId: 'flt-shared-panel', attr: 'data-panel' }
            ]
        }
    ];

    function getActivePaneId() {
        var active = document.querySelector('.cs-tab-pane.active');
        return active ? active.id : 'pane-summary';
    }

    function updateSharedFilterVisibility() {
        // Show Year filters for YTD tabs; Week for WTD tabs; both hidden for others.
        var paneId = getActivePaneId();
        var isWtd  = paneId === 'pane-wtd-summary' || paneId === 'pane-wtd-insights';
        var isYtd  = paneId === 'pane-summary' || paneId === 'pane-insights';

        var yearLabel = document.getElementById('csSharedYearLabel');
        var yearSel   = document.getElementById('flt-shared-year');
        var weekLabel = document.getElementById('csSharedWeekLabel');
        var weekSel   = document.getElementById('flt-shared-week');

        if (yearLabel) yearLabel.style.display = isYtd ? '' : 'none';
        if (yearSel)   yearSel.style.display   = isYtd ? '' : 'none';
        if (weekLabel) weekLabel.style.display = isWtd ? '' : 'none';
        if (weekSel)   weekSel.style.display   = isWtd ? '' : 'none';
    }

    function applyFilter(cfg) {
        var rows    = document.querySelectorAll(cfg.rowSel);
        var visible = 0;
        rows.forEach(function (row) {
            var show = cfg.filters.every(function (f) {
                var sel = document.getElementById(f.selId);
                if (!sel) return true;
                var val = sel.value;
                if (!val) return true;                          // "All" option selected
                return row.getAttribute(f.attr) === val;
            });
            row.classList.toggle('cs-row-hidden', !show);
            if (show) visible++;
        });
        // Show/hide entire year/week section when all its rows are filtered out
        document.querySelectorAll('#' + cfg.pane + ' .cs-year-section').forEach(function (sec) {
            var anyVisible = sec.querySelectorAll('tbody tr:not(.cs-row-hidden)').length > 0;
            sec.style.display = anyVisible ? '' : 'none';
        });
        // Only show counts for the active tab in the shared filter bar.
        if (cfg.pane === getActivePaneId()) {
            var countEl = document.getElementById(cfg.countId);
            if (countEl) countEl.textContent = visible + ' row' + (visible !== 1 ? 's' : '');
        }
    }

    function applyAllTabFilters() {
        tabFilters.forEach(function (cfg) { applyFilter(cfg); });
    }

    // Wire up shared filter bar change listeners
    ['flt-shared-year', 'flt-shared-week', 'flt-shared-panel'].forEach(function (id) {
        var sel = document.getElementById(id);
        if (sel) sel.addEventListener('change', function () { applyAllTabFilters(); });
    });

    // Shared clear button
    var sharedClear = document.getElementById('flt-shared-clear');
    if (sharedClear) {
        sharedClear.addEventListener('click', function () {
            var y = document.getElementById('flt-shared-year'); if (y) y.value = '';
            var w = document.getElementById('flt-shared-week'); if (w) w.value = '';
            var p = document.getElementById('flt-shared-panel'); if (p) p.value = '';
            applyAllTabFilters();
        });
    }

    // Init
    updateSharedFilterVisibility();
    applyAllTabFilters();

    // Toggle full / clamped CPT pills inside any cpt-pill-block
    window.cptPillsToggle = function (btn, evt) {
        if (!btn) return;
        var block = btn.closest('.cpt-pill-block');
        if (!block) return;
        var pills = block.querySelector('.cpt-pills');
        if (!pills) return;
        var collapsed = pills.classList.toggle('cpt-pills-collapsed');
        pills.classList.toggle('cpt-pills-expanded', !collapsed);
        btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        var more = btn.getAttribute('data-more') || '+ more';
        var less = btn.getAttribute('data-less') || '- less';
        btn.innerHTML = collapsed ? more : less;
        // Don't bubble click into row toggles in the Summary tabs
        if (evt && evt.stopPropagation) evt.stopPropagation();
    };

    // After render, reveal "+ more" only where the clamped pills actually overflow.
    function refreshCptPillToggles() {
        document.querySelectorAll('.cpt-pill-block').forEach(function (block) {
            var pills  = block.querySelector('.cpt-pills');
            var toggle = block.querySelector('.cpt-pill-toggle');
            if (!pills || !toggle) return;
            // Only meaningful while collapsed; if user expanded, leave toggle visible.
            if (!pills.classList.contains('cpt-pills-collapsed')) {
                toggle.style.display = '';
                return;
            }
            var overflowing = pills.scrollHeight > pills.clientHeight + 1;
            toggle.style.display = overflowing ? '' : 'none';
        });
    }
    // Expose globally so handlers in nested IIFEs (rowToggle) can re-trigger it.
    window.refreshCptPillToggles = refreshCptPillToggles;
    // Initial pass + re-run on resize (column widths change → wrapping changes)
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', refreshCptPillToggles);
    } else {
        refreshCptPillToggles();
    }
    var _cptResizeTimer;
    window.addEventListener('resize', function () {
        clearTimeout(_cptResizeTimer);
        _cptResizeTimer = setTimeout(refreshCptPillToggles, 150);
    });
    // Re-evaluate when a tab becomes visible (hidden panes have 0 height → bad measurements)
    document.querySelectorAll('#csTabs .cs-tab-btn').forEach(function (b) {
        b.addEventListener('click', function () {
            updateSharedFilterVisibility();
            // Re-apply filters so the shared count matches the newly active pane.
            applyAllTabFilters();
            setTimeout(refreshCptPillToggles, 30);
        });
    });

    // Wire up all Download Excel buttons (class-based) with progress overlay.
    (function () {
        var overlay     = document.getElementById('csExportOverlay');
        var bar         = document.getElementById('csExportBar');
        var pctLabel    = document.getElementById('csExportPct');
        var statusLabel = document.getElementById('csExportStatus');
        var cancelBtn   = document.getElementById('csExportCancelBtn');
        if (!overlay || !bar || !pctLabel || !statusLabel || !cancelBtn) return;

        var exportUrl = '@Url.Action("ExportCodingExcel", "Coding", new { lab = Model.LabName })';

        var steps = [
            { pct:  8, text: 'Connecting to database\u2026' },
            { pct: 18, text: 'Fetching YTD Insights\u2026' },
            { pct: 28, text: 'Fetching YTD Summary\u2026' },
            { pct: 38, text: 'Fetching WTD Insights\u2026' },
            { pct: 48, text: 'Fetching WTD Summary\u2026' },
            { pct: 58, text: 'Fetching Financial Dashboard\u2026' },
            { pct: 68, text: 'Fetching Validation Detail rows\u2026' },
            { pct: 80, text: 'Building Excel workbook\u2026' },
            { pct: 92, text: 'Finalizing sheets & formatting\u2026' }
        ];

        function csGetCookie(name) {
            var m = document.cookie.match('(^|;)\\s*' + name + '=([^;]*)');
            return m ? m[2] : null;
        }
        function csDeleteCookie(name) {
            document.cookie = name + '=; path=/; max-age=0';
        }
        function csCleanup(p, c, s, iframe) {
            clearInterval(p); clearInterval(c); clearInterval(s);
            if (iframe && iframe.parentNode) document.body.removeChild(iframe);
        }

        function startExport() {
            csDeleteCookie('csExportDone');
            overlay.style.display = 'flex';
            bar.style.width = '0%';
            pctLabel.textContent = '0%';
            statusLabel.textContent = 'Starting export\u2026';

            var startTime = Date.now();
            function elapsed() {
                var secs = Math.floor((Date.now() - startTime) / 1000);
                var m = Math.floor(secs / 60), s = secs % 60;
                return m > 0 ? m + 'm ' + s + 's' : s + 's';
            }

            var stepIdx = 0, currentPct = 0;
            var stepTimer = setInterval(function () {
                if (stepIdx < steps.length) {
                    currentPct = steps[stepIdx].pct;
                    bar.style.width = currentPct + '%';
                    pctLabel.textContent = currentPct + '%';
                    statusLabel.textContent = steps[stepIdx].text;
                    stepIdx++;
                } else { clearInterval(stepTimer); }
            }, 1500);

            var creepTimer = setInterval(function () {
                if (stepIdx >= steps.length) {
                    if (currentPct < 99) currentPct += 0.15;
                    var p = Math.min(Math.round(currentPct), 99);
                    bar.style.width = p + '%';
                    pctLabel.textContent = p + '%';
                    var msgs = [
                        'Writing Validation Detail sheet\u2026',
                        'Writing YTD/WTD sheets\u2026',
                        'Formatting report sheets\u2026',
                        'Almost there, please wait\u2026',
                        'Compressing workbook\u2026',
                        'Hang tight, almost done\u2026'
                    ];
                    var msgIdx = Math.floor((Date.now() - startTime) / 4000) % msgs.length;
                    statusLabel.textContent = msgs[msgIdx] + '  (' + elapsed() + ')';
                }
            }, 1000);

            var iframe = document.createElement('iframe');
            iframe.style.display = 'none';
            iframe.src = exportUrl;
            document.body.appendChild(iframe);

            var pollTimer = setInterval(function () {
                if (csGetCookie('csExportDone')) {
                    csCleanup(pollTimer, creepTimer, stepTimer, iframe);
                    csDeleteCookie('csExportDone');
                    bar.style.width = '100%';
                    pctLabel.textContent = '100%';
                    statusLabel.textContent = 'Download complete!  (' + elapsed() + ')';
                    setTimeout(function () { overlay.style.display = 'none'; }, 900);
                }
            }, 500);

            var onCancel = function () {
                csCleanup(pollTimer, creepTimer, stepTimer, iframe);
                csDeleteCookie('csExportDone');
                overlay.style.display = 'none';
                cancelBtn.removeEventListener('click', onCancel);
            };
            cancelBtn.addEventListener('click', onCancel);

            // Safety timeout: hide overlay after 10 minutes regardless.
            setTimeout(function () {
                csCleanup(pollTimer, creepTimer, stepTimer, iframe);
                overlay.style.display = 'none';
            }, 600000);
        }

        document.querySelectorAll('.exportCodingExcelBtn').forEach(function (btn) {
            btn.addEventListener('click', startExport);
        });
    }());


    // ?? Validation Detail: filter + pager + expand ???????????????????????
    (function () {
        var PAGE_SIZE = 50;
        var allRows   = [];   // {main, expand, panel, status, search, visible}
        var filtered  = [];   // subset after filters applied
        var curPage   = 1;

        function buildIndex() {
            var mains = document.querySelectorAll('#tbody-detail .det-row-main');
            mains.forEach(function (m) {
                allRows.push({
                    main:   m,
                    expand: m.nextElementSibling,
                    panel:  m.getAttribute('data-panel')  || '',
                    status: m.getAttribute('data-status') || '',
                    search: (m.getAttribute('data-search') || '').toLowerCase()
                });
            });
        }

        function applyFilters() {
            var panel  = (document.getElementById('flt-det-panel')  || {}).value || '';
            var status = (document.getElementById('flt-det-status') || {}).value || '';
            var search = ((document.getElementById('flt-det-search') || {}).value || '').toLowerCase();
            filtered = allRows.filter(function (r) {
                return (!panel  || r.panel  === panel)
                    && (!status || r.status === status)
                    && (!search || r.search.indexOf(search) !== -1);
            });
            var cnt = document.getElementById('flt-det-count');
            if (cnt) cnt.textContent = filtered.length + ' row' + (filtered.length !== 1 ? 's' : '');
            curPage = 1;
            renderPage();
        }

        function renderPage() {
            // Hide all rows first
            allRows.forEach(function (r) {
                r.main.style.display   = 'none';
                r.expand.style.display = 'none';
                r.expand.classList.remove('open');
                r.main.classList.remove('open');
            });

            var start = (curPage - 1) * PAGE_SIZE;
            var page  = filtered.slice(start, start + PAGE_SIZE);
            page.forEach(function (r) { r.main.style.display = ''; });

            // Pager info
            var info = document.getElementById('det-pager-info');
            if (info) {
                var from = filtered.length === 0 ? 0 : start + 1;
                var to   = Math.min(start + PAGE_SIZE, filtered.length);
                info.textContent = 'Showing ' + from + '�' + to + ' of ' + filtered.length + ' rows';
            }
            renderPagerBtns();
        }

        function renderPagerBtns() {
            var container = document.getElementById('det-pager-btns');
            if (!container) return;
            container.innerHTML = '';
            var totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
            if (totalPages <= 1) return;

            function mkBtn(label, page, disabled, active) {
                var b = document.createElement('button');
                b.className = 'det-pager-btn' + (active ? ' active' : '');
                b.textContent = label;
                b.disabled = !!disabled;
                if (!disabled) b.addEventListener('click', function () { curPage = page; renderPage(); });
                return b;
            }

            container.appendChild(mkBtn('�', 1,          curPage === 1, false));
            container.appendChild(mkBtn('�', curPage - 1, curPage === 1, false));

            // page number buttons � show window of �2 around current
            var lo = Math.max(1, curPage - 2);
            var hi = Math.min(totalPages, curPage + 2);
            if (lo > 1)          { container.appendChild(mkBtn('1', 1, false, false)); if (lo > 2) { var e=document.createElement('span'); e.className='det-pager-ellipsis'; e.textContent='�'; container.appendChild(e); } }
            for (var p = lo; p <= hi; p++) container.appendChild(mkBtn(String(p), p, false, p === curPage));
            if (hi < totalPages) { if (hi < totalPages-1) { var e2=document.createElement('span'); e2.className='det-pager-ellipsis'; e2.textContent='�'; container.appendChild(e2); } container.appendChild(mkBtn(String(totalPages), totalPages, false, false)); }

            container.appendChild(mkBtn('�', curPage + 1, curPage === totalPages, false));
            container.appendChild(mkBtn('�', totalPages,  curPage === totalPages, false));
        }

        // Row expand/collapse � Validation Detail
        window.detToggle = function (mainRow) {
            var exp  = mainRow.nextElementSibling;
            var open = exp.classList.toggle('open');
            mainRow.classList.toggle('open', open);
            exp.style.display = open ? '' : 'none';
        };

        // Row expand/collapse � YTD/WTD tables
        window.rowToggle = function (mainRow) {
            var exp  = mainRow.nextElementSibling;
            var open = exp.classList.toggle('open');
            mainRow.classList.toggle('open', open);
            exp.style.display = open ? '' : 'none';
            // Child sub-table just became visible/hidden � re-evaluate CPT pill clamping.
            if (typeof refreshCptPillToggles === 'function') {
                setTimeout(refreshCptPillToggles, 30);
            }
        };

        window.resetDetailFilter = function () {
            ['flt-det-panel', 'flt-det-status'].forEach(function (id) {
                var el = document.getElementById(id); if (el) el.value = '';
            });
            var s = document.getElementById('flt-det-search'); if (s) s.value = '';
            applyFilters();
        };

        ['flt-det-panel', 'flt-det-status'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.addEventListener('change', applyFilters);
        });
        var detSearch = document.getElementById('flt-det-search');
        if (detSearch) detSearch.addEventListener('input', applyFilters);

        buildIndex();
        applyFilters();
    }());

}());
</script>
