    margin:0; font-size:10px; font-weight:800;
    color:rgba(11,31,42,.72); line-height:1.2;
    display:flex; align-items:center; gap:5px; white-space:nowrap;
}
.ck-tag {
    width:16px; height:16px; border-radius:6px;
    display:grid; place-items:center;
    background:rgba(14,43,69,.08); border:1px solid rgba(14,43,69,.10);
    color:rgba(14,43,69,.88); font-size:9px; font-weight:900; flex-shrink:0;
}
.ck-value {
    margin:0; font-size:14px; font-weight:900;
    font-variant-numeric:tabular-nums; white-space:nowrap;
    color:var(--ck-navy);
}
.ck-value.ck-danger  { color:var(--ck-danger); }
.ck-value.ck-success { color:var(--ck-success); }
.ck-value.ck-warning { color:var(--ck-warning); }
.ck-value.ck-info    { color:var(--ck-info); }
.ck-value.sm         { font-size:12px; }

/* sparkline */
.ck-spark {
    margin-top:5px; height:20px; border-radius:8px;
    border:1px solid rgba(15,35,55,.10);
    background:linear-gradient(180deg,rgba(47,111,237,.08),rgba(10,122,116,.04));
    overflow:hidden; position:relative;
}
.ck-spark svg { position:absolute; inset:0; width:100%; height:100%; opacity:.95; }

/* compliance gauge */
.ck-gauge {
    display:flex; gap:10px; align-items:center; justify-content:space-between;
    padding:6px 8px;
}
.ck-gauge-left {
    display:grid; grid-template-columns:1fr 1fr; gap:6px; flex:1 1 auto;
}
