/* ?? Claim KPI card design (from Claim.html) ??????????????????????? */
:root {
    --ck-navy:   #0E2B45;
    --ck-teal:   #1565c0;
    --ck-teal-2: #1e88e5;
    --ck-card:   rgba(255,255,255,.86);
    --ck-stroke: rgba(15,35,55,.12);
    --ck-muted:  #5A6B78;
    --ck-success:#1F8A4C;
    --ck-warning:#D9822B;
    --ck-danger: #C5322B;
    --ck-info:   #2F6FED;
    --ck-shadow: 0 10px 30px rgba(7,24,39,.10);
    --ck-r24:    24px;
    --ck-r20:    20px;
}

.ck-wrap {
    margin-bottom:1.5rem;
}

/* header bar */
.ck-header {
    background:linear-gradient(135deg,#0d1b2a 0%,#1b3a5c 55%,#1565c0 100%);
    border-radius:var(--ck-r24) var(--ck-r24) 0 0;
    padding:.65rem 1.4rem;
    display:flex; align-items:center; gap:.9rem; flex-wrap:wrap;
}
.ck-header-week {
    display:inline-flex; align-items:center; gap:.4rem;
    background:rgba(255,255,255,.14); border:1.5px solid rgba(255,255,255,.28);
    border-radius:30px; padding:.28em .9em;
    font-size:.82rem; font-weight:800; color:#fff; letter-spacing:.04em;
}
.ck-header-date { font-size:.76rem; color:rgba(255,255,255,.7); font-weight:600; }

/* 3-col grid */
.ck-grid {
    display:grid;
    grid-template-columns:repeat(3, minmax(0,1fr));
    gap:12px;
    padding:12px;
    background:#F6F9FC;
    border-radius:0 0 var(--ck-r24) var(--ck-r24);
}

/* individual card */
.ck-card {
    background:var(--ck-card);
    border:1px solid var(--ck-stroke);
    border-radius:var(--ck-r24);
    box-shadow:var(--ck-shadow);
    overflow:hidden;
    position:relative;
    backdrop-filter:blur(12px);
    -webkit-backdrop-filter:blur(12px);
}
.ck-card::before {
    content:"";
    position:absolute; inset:0; pointer-events:none;
    background:radial-gradient(500px 200px at 15% 0%, rgba(17,163,155,.16), transparent 60%),
               radial-gradient(380px 200px at 85% 10%, rgba(47,111,237,.10), transparent 58%);
    opacity:.65;
}

.ck-card-head {
    position:relative;
    padding:7px 10px 5px;
    display:flex; align-items:flex-start;
    justify-content:space-between; gap:8px; z-index:1;
}
.ck-card-head-meta { display:flex; flex-direction:column; gap:2px; }
.ck-card-title {
    margin:0; font-size:10px; font-weight:900;
    letter-spacing:1px; text-transform:uppercase;
    color:rgba(11,31,42,.85);
}
.ck-card-desc { margin:0; font-size:10px; color:var(--ck-muted); font-weight:600; }

.ck-chip {
    display:flex; align-items:center; gap:5px;
    padding:4px 7px; border-radius:999px;
    background:rgba(14,43,69,.06); border:1px solid rgba(14,43,69,.10);
    font-weight:800; color:rgba(14,43,69,.86); font-size:10px; white-space:nowrap;
}
.ck-ico {
    width:18px; height:18px; border-radius:7px;
    display:grid; place-items:center;
    color:#fff; box-shadow:0 4px 10px rgba(0,0,0,.12);
    flex:0 0 auto; font-weight:900; font-size:10px;
}
.ck-ico-teal   { background:linear-gradient(180deg,var(--ck-teal-2),var(--ck-teal)); }
.ck-ico-navy   { background:linear-gradient(180deg,#2F6FED,var(--ck-navy)); }
.ck-ico-red    { background:linear-gradient(180deg,#E15D5D,#7A1E22); }
.ck-ico-amber  { background:linear-gradient(180deg,#F0B35A,#7B3F00); }

.ck-card-body { position:relative; padding:0 10px 8px; z-index:1; }

/* row-style kpi list */
.ck-rows { display:grid; grid-template-columns:1fr; gap:4px; }
.ck-row {
    display:flex; align-items:center;
    justify-content:space-between; gap:8px;
    min-height:0; padding:5px 8px;
    border-radius:var(--ck-r20);
    border:1px solid rgba(15,35,55,.10);
    background:rgba(255,255,255,.78);
}
