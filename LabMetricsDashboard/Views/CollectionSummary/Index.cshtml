        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="cptpctpay-tab" data-bs-toggle="pill"
                    data-bs-target="#cptpctpay-pane" type="button" role="tab"
                    aria-controls="cptpctpay-pane" aria-selected="false">
                <i class="bi bi-list-ol"></i> CPT vs Payment %
            </button>
        </li>
            <li class="nav-item" role="presentation">
