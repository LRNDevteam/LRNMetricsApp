    <div id="csTabLoading" class="cs-tab-loading" aria-hidden="true">
        <div class="cs-tab-loading-card">
            <div class="lmd-spinner"></div>
            <div class="cs-tab-loading-text">Loading tab…</div>
        </div>
    </div>

    <div class="tab-content" id="csRptTabContent">

        <!-- ?? Monthly Claim Volume tab ???????????????????????? -->
        <div class="tab-pane fade show active" id="mcv-pane" role="tabpanel" aria-labelledby="mcv-tab">
            @if (Model.MonthlyClaimVolume.HasData)
            {
                var mcvPivot = Model.MonthlyClaimVolume;
                var mcvPeriods = mcvPivot.Periods;
                var mcvYears = mcvPivot.Years;
                var mcvMonthsByYear = mcvPeriods
                    .GroupBy(p => p.Year)
                    .OrderBy(g => g.Key)
                    .ToDictionary(g => g.Key, g => g.OrderBy(p => p.Month).ToList());

                int McvCellEnc(Dictionary<string, CollectionMonthlyCell>? d, string mk)
                    => d is not null && d.TryGetValue(mk, out var c) ? c.EncounterCount : 0;
                decimal McvCellPaid(Dictionary<string, CollectionMonthlyCell>? d, string mk)
                    => d is not null && d.TryGetValue(mk, out var c) ? c.InsurancePaidAmount : 0m;
                int McvYearEnc(Dictionary<int, CollectionYearTotal>? d, int y)
                    => d is not null && d.TryGetValue(y, out var t) ? t.EncounterCount : 0;
                decimal McvYearPaid(Dictionary<int, CollectionYearTotal>? d, int y)
                    => d is not null && d.TryGetValue(y, out var t) ? t.InsurancePaidAmount : 0m;

                <div class="d-flex align-items-center justify-content-between mb-2" style="font-size:.78rem;color:#475569">
                    <div>
                        <i class="bi bi-info-circle me-1" style="color:#1565c0"></i>
                        <strong>Data based on Posted Date</strong>
                        <span class="text-muted">(CheckDate)</span>
                    </div>
                </div>

                <div class="cs-rpt-wrap">
                    <div class="cs-rpt-scroll">
                        <table class="cs-rpt-table">
                            <thead>
                                @* Row 1: year spans *@
                                <tr>
                                    <th rowspan="2" style="min-width:40px">&nbsp;</th>
                                    <th rowspan="2" style="text-align:left;min-width:260px">Panel &amp; Insurance</th>
                                    @foreach (var year in mcvYears)
                                    {
                                        var monthsInYear = mcvMonthsByYear.TryGetValue(year, out var my) ? my : [];
                                        <th colspan="@(monthsInYear.Count * 2)">@year</th>
                                        <th colspan="2">@year Total</th>
                                    }
                                    <th colspan="2">Grand Total</th>
                                </tr>
                                @* Row 2: month sub-headers *@
                                @{
                                    var encLabel      = "No. of Encounters";
                                    var encTotalLabel = "No. of Encounters";
                                    var paidLabel     = "Insurance Paid Amount";
                                }
                                <tr>
                                    @foreach (var year in mcvYears)
                                    {
                                        var monthsInYear = mcvMonthsByYear.TryGetValue(year, out var my) ? my : [];
                                        @foreach (var p in monthsInYear)
                                        {
                                            <th>@p.MonthLabel @encLabel</th>
                                            <th>@p.MonthLabel @paidLabel</th>
                                        }
                                        <th>@encTotalLabel</th>
                                        <th>@paidLabel</th>
                                    }
                                    <th>@encTotalLabel</th>
                                    <th>@paidLabel</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var mcvIdx = 0; }
                                @foreach (var panel in mcvPivot.PanelRows)
                                {
                                    mcvIdx++;
                                    var letter = mcvIdx <= 26 ? ((char)('A' + mcvIdx - 1)).ToString() : mcvIdx.ToString();
                                    @* Panel row *@
                                    <tr>
                                        <td style="font-weight:700">@letter</td>
                                        <td style="text-align:left;font-weight:700">@panel.PanelName</td>
                                        @foreach (var year in mcvYears)
                                        {
                                            var monthsInYear = mcvMonthsByYear.TryGetValue(year, out var my) ? my : [];
                                            @foreach (var p in monthsInYear)
                                            {
                                                <td style="text-align:right;font-weight:600">@McvCellEnc(panel.ByMonth, p.Key).ToString("N0")</td>
                                                <td style="text-align:right;font-weight:600">@McvCellPaid(panel.ByMonth, p.Key).ToString("C0")</td>
                                            }
                                            <td style="text-align:right;font-weight:700">@McvYearEnc(panel.ByYear, year).ToString("N0")</td>
                                            <td style="text-align:right;font-weight:700">@McvYearPaid(panel.ByYear, year).ToString("C0")</td>
                                        }
                                        <td style="text-align:right;font-weight:700">@panel.TotalEncounters.ToString("N0")</td>
                                        <td style="text-align:right;font-weight:700">@panel.TotalInsurancePaid.ToString("C0")</td>
                                    </tr>
                                    @* Payer drill-down rows (all payers when table1 mode, top 3 otherwise) *@
                                    @foreach (var payer in panel.TopPayers)
                                    {
                                        <tr class="mcv-drilldown">
                                            <td></td>
                                            <td style="text-align:left">@payer.PayerName</td>
                                            @foreach (var year in mcvYears)
                                            {
                                                var monthsInYear = mcvMonthsByYear.TryGetValue(year, out var my) ? my : [];
                                                @foreach (var p in monthsInYear)
                                                {
                                                    <td style="text-align:right">@McvCellEnc(payer.ByMonth, p.Key).ToString("N0")</td>
                                                    <td style="text-align:right">@McvCellPaid(payer.ByMonth, p.Key).ToString("C0")</td>
                                                }
                                                <td style="text-align:right;font-weight:600">@McvYearEnc(payer.ByYear, year).ToString("N0")</td>
                                                <td style="text-align:right;font-weight:600">@McvYearPaid(payer.ByYear, year).ToString("C0")</td>
                                            }
                                            <td style="text-align:right;font-weight:600">@payer.TotalEncounters.ToString("N0")</td>
                                            <td style="text-align:right;font-weight:600">@payer.TotalInsurancePaid.ToString("C0")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr style="background:linear-gradient(135deg,#0a1628 0%,#0e3460 50%,#0d5c74 100%);color:#fff;font-weight:700">
                                    <td style="color:#fff"></td>
                                    <td style="text-align:left;color:#fff">Grand Total</td>
                                    @foreach (var year in mcvYears)
                                    {
                                        var monthsInYear = mcvMonthsByYear.TryGetValue(year, out var my) ? my : [];
                                        @foreach (var p in monthsInYear)
                                        {
                                            <td style="text-align:right;color:#fff">@McvCellEnc(mcvPivot.GrandTotalByMonth, p.Key).ToString("N0")</td>
                                            <td style="text-align:right;color:#fff">@McvCellPaid(mcvPivot.GrandTotalByMonth, p.Key).ToString("C0")</td>
                                        }
                                        <td style="text-align:right;color:#fff">@McvYearEnc(mcvPivot.GrandTotalByYear, year).ToString("N0")</td>
                                        <td style="text-align:right;color:#fff">@McvYearPaid(mcvPivot.GrandTotalByYear, year).ToString("C0")</td>
                                    }
                                    <td style="text-align:right;color:#fff">@mcvPivot.GrandTotalEncounters.ToString("N0")</td>
                                    <td style="text-align:right;color:#fff">@mcvPivot.GrandTotalInsurancePaid.ToString("C0")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <div class="mt-2" style="font-size:.68rem; color:#94a3b8">
                    <strong>Source:</strong> ClaimLevelData (all rows) &bull;
                    <strong>Filter (base):</strong> InsurancePayment &gt; 0 &nbsp;·&nbsp; CheckDate not blank/invalid &bull;
                    <strong>Filter (applied):</strong> Payers: @(Model.FilterPayerNames != null && Model.FilterPayerNames.Count > 0 ? string.Join(", ", Model.FilterPayerNames) : "All") &nbsp;|&nbsp; Panels: @(Model.FilterPanelNames != null && Model.FilterPanelNames.Count > 0 ? string.Join(", ", Model.FilterPanelNames) : "All") &nbsp;|&nbsp; FirstBilledDate: @(string.IsNullOrWhiteSpace(Model.FilterFirstBillFrom) ? "-" : Model.FilterFirstBillFrom) — @(string.IsNullOrWhiteSpace(Model.FilterFirstBillTo) ? "-" : Model.FilterFirstBillTo) &nbsp;|&nbsp; DOS: @(string.IsNullOrWhiteSpace(Model.FilterDosFrom) ? "-" : Model.FilterDosFrom) — @(string.IsNullOrWhiteSpace(Model.FilterDosTo) ? "-" : Model.FilterDosTo) &nbsp;|&nbsp; CheckDate: @(string.IsNullOrWhiteSpace(Model.FilterCheckDateFrom) ? "-" : Model.FilterCheckDateFrom) — @(string.IsNullOrWhiteSpace(Model.FilterCheckDateTo) ? "-" : Model.FilterCheckDateTo) &bull;
                    <strong>Rows:</strong> PanelName &bull;
                    <strong>Drill-down:</strong> Top 3 PayerName_Raw by Unique ClaimID count &bull;
                    <strong>Columns:</strong> CheckDate (Year, Month) &bull;
                    <strong>Sorted by:</strong> Grand Total (Unique ClaimID count) DESC
                </div>
            }
            else
            {
                var mcvReason = "No rows match: InsurancePayment > 0 · CheckDate is a valid date";
                <div class="text-center py-5 text-muted">
                    <div style="font-size:2rem;opacity:.4">&#128202;</div>
                    <div class="fw-semibold mt-2">No monthly claim volume data available</div>
                    <div class="small mt-1"><strong>Reason:</strong> @mcvReason. Try adjusting your filters.</div>
                </div>
            }

            @* -- Active Collection Summary Rule footer -- *@
            @{
            var csActiveRule = string.IsNullOrWhiteSpace(Model.CollectionSummaryRule) ? "Default" : Model.CollectionSummaryRule!;
            }
            <div class="pr-rule-footer mt-3 small text-muted" style="opacity:.65;line-height:1.45;border-top:1px dashed #cfd6df;padding-top:.5rem">
                <div><span class="fw-semibold">Active Rule:</span> @csActiveRule</div>
                <div class="mt-1"><span class="fw-semibold">Monthly Claim Volume Logic:</span></div>
                <ul class="mb-0 ps-3" style="font-size:.78rem">
                    <li>Source: <code>ClaimLevelData</code> (all rows)</li>
                    <li>Rows: <code>PanelName</code> &nbsp;·&nbsp; Drill-down: Top 3 <code>PayerName_Raw</code> by <code>COUNT(DISTINCT ClaimID)</code></li>
                    <li>Columns: <code>YEAR(CheckDate)</code> / <code>MONTH(CheckDate)</code></li>
                    <li>Filter (base): <code>InsurancePayment &gt; 0</code> &nbsp;·&nbsp; <code>CheckDate</code> not blank/invalid &nbsp;·&nbsp; <code>PayerName_Raw</code> not blank</li>
                    <li>Rank by: <code>COUNT(DISTINCT ClaimID)</code> &nbsp;·&nbsp; Sort: Grand Total descending</li>
                </ul>
            </div>
        </div>

        <!-- Weekly Claim Volume tab -->
        <div class="tab-pane fade" id="wcv-pane"           role="tabpanel" aria-labelledby="wcv-tab"           data-cs-tab="wcv">@await Html.PartialAsync("_CsTabWcv",          Model)</div>
