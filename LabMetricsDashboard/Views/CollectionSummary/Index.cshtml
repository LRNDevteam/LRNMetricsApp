/* Scope position:absolute for out-of-flow old pane during tab transition */
#csRptTabContent { position: relative; }

/* Status Summary tree icons */
.ss-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 3px;
    font-size: .62rem;
    color: #fff;
    background: #4a6fa5;
    transition: background .15s, transform .15s;
    user-select: none;
    flex-shrink: 0;
    vertical-align: middle;
}
.ss-ico::before         { content: '\25B6'; display: block; }
.ss-ico.open::before    { content: '\25BC'; display: block; }
.ss-lvl1:hover .ss-ico  { background: #0d3460; }
.ss-lvl2:hover .ss-ico  { background: #1e5fa3; }
</style>

<!-- Page heading -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0 fw-bold">
        Collection Summary
        <span class="badge bg-primary bg-gradient fw-semibold"
              style="font-size:.45em;vertical-align:middle;border-radius:20px;padding:.35em .85em">
            @Model.SelectedLab
        </span>
    </h2>
    <a asp-controller="Dashboard" asp-action="Index" asp-route-lab="@Model.SelectedLab"
       class="btn btn-sm btn-outline-primary">
        <i class="bi bi-speedometer2 me-1"></i>Revenue Dashboard
    </a>
</div>

<!-- ?? Collapsible Filter panel ?????????????????????????????????? -->
@if (!string.IsNullOrWhiteSpace(Model.SelectedLab))
{
    <div class="cs-rpt-filter-panel p-3 mb-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="fw-semibold" style="font-size:.9rem">
                <i class="bi bi-funnel"></i> Filters
                @if (Model.HasFilters)
                {
                    <span class="badge bg-primary cs-rpt-filter-badge ms-1">Active</span>
                }
            </span>
            <button class="btn btn-sm btn-link text-muted p-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#csRptFilterBody"
                    aria-expanded="@(Model.HasFilters ? "true" : "false")">
                @Html.Raw(Model.HasFilters ? "&#9650; Hide" : "&#9660; Show")
            </button>
        </div>

        <div id="csRptFilterBody" class="collapse @(Model.HasFilters ? "show" : "")">
            <form id="csRptFilterForm" method="get" asp-controller="CollectionSummary" asp-action="Index" data-lab-form>
                <input type="hidden" name="lab" value="@Model.SelectedLab" />

                <div class="row g-2 align-items-end mb-2">
                    <!-- Payer Name (multi-select) -->
                    <div class="col-sm-6 col-md-4">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PAYER NAME</label>
                        <div class="cs-rpt-ms" data-ms-name="filterPayerNames">
                            <div class="cs-rpt-ms-btn" tabindex="0">
                                <span class="cs-rpt-ms-label">All</span>
                                <span class="cs-rpt-ms-count" style="display:none">0</span>
                            </div>
                            <div class="cs-rpt-ms-panel">
                                <input type="text" class="cs-rpt-ms-search" placeholder="Search payers…" autocomplete="off" />
                                <div class="cs-rpt-ms-list">
                                    @foreach (var pn in Model.PayerNames)
                                    {
                                        <label><input type="checkbox" name="filterPayerNames" value="@pn"
                                            @(Model.FilterPayerNames.Contains(pn) ? "checked" : "") /> @pn</label>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Panel Name (multi-select) -->
                    <div class="col-sm-6 col-md-4">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PANEL NAME</label>
                        <div class="cs-rpt-ms" data-ms-name="filterPanelNames">
                            <div class="cs-rpt-ms-btn" tabindex="0">
                                <span class="cs-rpt-ms-label">All</span>
                                <span class="cs-rpt-ms-count" style="display:none">0</span>
                            </div>
                            <div class="cs-rpt-ms-panel">
                                <input type="text" class="cs-rpt-ms-search" placeholder="Search panels…" autocomplete="off" />
                                <div class="cs-rpt-ms-list">
                                    @foreach (var pl in Model.PanelNames)
                                    {
                                        <label><input type="checkbox" name="filterPanelNames" value="@pl"
                                            @(Model.FilterPanelNames.Contains(pl) ? "checked" : "") /> @pl</label>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-2 align-items-end mb-2">
                    <!-- First Bill Date -->
                    <div class="col-sm-6 col-md-2">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">FIRST BILL DATE FROM</label>
                        <input type="date" name="filterFirstBillFrom" class="form-control form-control-sm" value="@Model.FilterFirstBillFrom" />
                    </div>
                    <div class="col-sm-6 col-md-2">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">FIRST BILL DATE TO</label>
                        <input type="date" name="filterFirstBillTo" class="form-control form-control-sm" value="@Model.FilterFirstBillTo" />
                    </div>

                    <!-- Date of Service -->
                    <div class="col-sm-6 col-md-2">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">DATE OF SERVICE FROM</label>
                        <input type="date" name="filterDosFrom" class="form-control form-control-sm" value="@Model.FilterDosFrom" />
                    </div>
                    <div class="col-sm-6 col-md-2">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">DATE OF SERVICE TO</label>
                        <input type="date" name="filterDosTo" class="form-control form-control-sm" value="@Model.FilterDosTo" />
                    </div>

                    <!-- Check Date -->
                    <div class="col-sm-6 col-md-2">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">CHECK DATE FROM</label>
                        <input type="date" name="filterCheckDateFrom" class="form-control form-control-sm" value="@Model.FilterCheckDateFrom" />
                    </div>
                    <div class="col-sm-6 col-md-2">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">CHECK DATE TO</label>
                        <input type="date" name="filterCheckDateTo" class="form-control form-control-sm" value="@Model.FilterCheckDateTo" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="bi bi-funnel-fill me-1"></i>Apply
                    </button>
                    <a asp-controller="CollectionSummary" asp-action="Index"
                       asp-route-lab="@Model.SelectedLab"
                       class="btn btn-sm btn-outline-secondary">Clear</a>
                    <button type="button" id="csExportExcelBtn" class="btn btn-sm btn-outline-success ms-auto">
                        <i class="bi bi-file-earmark-excel me-1"></i>Download Excel
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<!-- Excel export loading overlay -->
<div id="csExportOverlay" class="cs-export-overlay" style="display:none">
    <div class="cs-export-dialog">
        <div class="cs-export-icon">
            <i class="bi bi-file-earmark-excel"></i>
        </div>
        <div class="cs-export-title">Generating Excel Report</div>
        <div class="cs-export-sub" id="csExportStatus">Fetching data and building workbook…</div>
        <div class="cs-export-bar-bg">
            <div class="cs-export-bar-fill" id="csExportBar" style="width:0%"></div>
        </div>
        <div class="cs-export-pct" id="csExportPct">0%</div>
        <button type="button" id="csExportCancelBtn" class="btn btn-sm btn-outline-secondary mt-3">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </button>
    </div>
</div>

@if (TempData["ExportError"] is string exportError)
{
    <div class="alert alert-warning alert-dismissible fade show mt-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> @exportError
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ?? Error message ???????????????????????????????????????????? -->
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> @Model.ErrorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.SelectedLab) && string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <!-- ?? Top-5 Insurance Dashboard Cards (always visible) ?????? -->
    <div class="top5-cards">

        <!-- ?? Reimbursement % card ??????????????????????????????? -->
        <div class="top5-card">
            @if (Model.Top5Reimbursement.Count > 0)
            {
                var reimbTotal = Model.Top5Reimbursement;
                var reimbTotalCharges = reimbTotal.Sum(r => r.SumChargeAmount);
                var reimbTotalPaid = reimbTotal.Sum(r => r.SumInsurancePayment);
                var reimbTotalVisits = reimbTotal.Sum(r => r.UniqueVisitCount);
                var reimbAvgPct = reimbTotalCharges == 0m ? 0m
                    : Math.Round(reimbTotalPaid / reimbTotalCharges * 100m, 2);

                <div class="top5-card-hdr reimb-hdr">
                    <div>
                        <div class="top5-card-hdr-title">Reimbursement Rate</div>
                        <div class="top5-card-hdr-sub">Top 5 payers by unique visit count</div>
                    </div>
                    <span class="top5-card-badge reimb-badge">
                        <i class="bi bi-percent"></i> Reimbursement
                    </span>
                </div>

                <div class="top5-card-body">
                    <div class="top5-kpi-boxes">
                        <div class="top5-kpi-box">
                            <div class="top5-kpi-box-label"><i class="bi bi-hash"></i> Total Visits</div>
                            <div class="top5-kpi-box-value">@reimbTotalVisits.ToString("N0")</div>
                        </div>
                        <div class="top5-kpi-box">
                            <div class="top5-kpi-box-label"><i class="bi bi-currency-dollar"></i> Total Paid</div>
                            <div class="top5-kpi-box-value">@reimbTotalPaid.ToString("C0")</div>
                        </div>
                    </div>
                    <div class="top5-gauge">
                        <div class="top5-gauge-ring reimb-ring" style="--gauge-pct: @(reimbAvgPct.ToString("F1"))%">
                            <div class="top5-gauge-inner">
                                <div class="top5-gauge-pct">@reimbAvgPct.ToString("F1")%</div>
                                <div class="top5-gauge-label">Reimb.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="top5-payer-list">
                    @foreach (var row in reimbTotal)
                    {
                        var pct = row.ReimbursementPct;
                        var barW = Math.Min(pct, 100m);
                        <div class="top5-payer-row">
                            <div class="top5-payer-rank reimb-rank">@row.Rank</div>
                            <div class="top5-payer-name" title="@row.PayerName">@row.PayerName</div>
                            <div class="top5-payer-detail">
                                <span title="Visits">@row.UniqueVisitCount.ToString("N0")</span>
                                <span title="Paid">@row.SumInsurancePayment.ToString("C0")</span>
                            </div>
                            <div class="top5-payer-bar-wrap">
                                <div class="top5-payer-bar-bg">
                                    <div class="top5-payer-bar-fill reimb-fill" style="width:@(barW.ToString("F1"))%"></div>
                                    <div class="top5-payer-bar-label">@pct.ToString("F1")%</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="top5-card-footer">
                    Ranked by <span class="top5-hl-blue">unique visit count</span> &bull;
                    Formula: SUM(InsurancePayment) / SUM(ChargeAmount) × 100
                </div>
            }
            else
            {
                <div class="top5-card-hdr reimb-hdr">
                    <div>
                        <div class="top5-card-hdr-title">Reimbursement Rate</div>
                        <div class="top5-card-hdr-sub">Top 5 payers by unique visit count</div>
                    </div>
                    <span class="top5-card-badge reimb-badge"><i class="bi bi-percent"></i> Reimbursement</span>
                </div>
                <div class="text-center py-5 text-muted" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center">
                    <div style="font-size:2rem;opacity:.4"><i class="bi bi-bar-chart"></i></div>
                    <div class="fw-semibold mt-2">No reimbursement data available</div>
                    <div class="small mt-1">Try adjusting your filters.</div>
                </div>
            }
        </div>

        <!-- ?? Total Payments card ???????????????????????????????? -->
        <div class="top5-card">
            @if (Model.ShowTop5TotalPayments && Model.Top5TotalPayments.Count > 0)
            {
                var payTotal = Model.Top5TotalPayments;
                var payTotalAmt = payTotal.Sum(r => r.TotalPayments);
                var payTotalVisits = payTotal.Sum(r => r.UniqueVisitCount);
                var maxPay = payTotal.Max(r => r.TotalPayments);
                var topPayerPct = maxPay == 0m ? 0m : Math.Round(payTotal[0].TotalPayments / payTotalAmt * 100m, 1);

                <div class="top5-card-hdr totpay-hdr">
                    <div>
                        <div class="top5-card-hdr-title">Total Payments</div>
                        <div class="top5-card-hdr-sub">Top 5 payers by unique visit count</div>
                    </div>
                    <span class="top5-card-badge totpay-badge">
                        <i class="bi bi-cash-stack"></i> Payments
                    </span>
                </div>

                <div class="top5-card-body">
                    <div class="top5-kpi-boxes">
                        <div class="top5-kpi-box">
                            <div class="top5-kpi-box-label"><i class="bi bi-hash"></i> Total Visits</div>
                            <div class="top5-kpi-box-value">@payTotalVisits.ToString("N0")</div>
                        </div>
                        <div class="top5-kpi-box">
                            <div class="top5-kpi-box-label"><i class="bi bi-currency-dollar"></i> Total Paid</div>
                            <div class="top5-kpi-box-value">@payTotalAmt.ToString("C0")</div>
                        </div>
                    </div>
                    <div class="top5-gauge">
                        <div class="top5-gauge-ring totpay-ring" style="--gauge-pct: @(topPayerPct.ToString("F1"))%">
                            <div class="top5-gauge-inner">
                                <div class="top5-gauge-pct">@topPayerPct.ToString("F0")%</div>
                                <div class="top5-gauge-label">Top Payer</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="top5-payer-list">
                    @foreach (var row in payTotal)
                    {
                        var barW = maxPay == 0m ? 0m : Math.Round(row.TotalPayments / maxPay * 100m, 1);
                        <div class="top5-payer-row">
                            <div class="top5-payer-rank totpay-rank">@row.Rank</div>
                            <div class="top5-payer-name" title="@row.PayerName">@row.PayerName</div>
                            <div class="top5-payer-detail">
                                <span title="Visits">@row.UniqueVisitCount.ToString("N0")</span>
                            </div>
                            <div class="top5-payer-bar-wrap">
                                <div class="top5-payer-bar-bg">
                                    <div class="top5-payer-bar-fill totpay-fill" style="width:@(barW.ToString("F1"))%"></div>
                                    <div class="top5-payer-bar-label">@row.TotalPayments.ToString("C0")</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="top5-card-footer">
                    Ranked by <span class="top5-hl-green">unique visit count</span> &bull;
                    Top payer accounts for <span class="top5-hl-green">@topPayerPct.ToString("F0")%</span> of total payments
                </div>
            }
            else
            {
                <div class="top5-card-hdr totpay-hdr">
                    <div>
                        <div class="top5-card-hdr-title">Total Payments</div>
                        <div class="top5-card-hdr-sub">Top 5 payers by unique visit count</div>
                    </div>
                    <span class="top5-card-badge totpay-badge"><i class="bi bi-cash-stack"></i> Payments</span>
                </div>
                <div class="text-center py-5 text-muted" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center">
                    <div style="font-size:2rem;opacity:.4"><i class="bi bi-cash-coin"></i></div>
                    <div class="fw-semibold mt-2">@(Model.ShowTop5TotalPayments ? "No payment data available" : "Not available for this lab")</div>
                    <div class="small mt-1">Try adjusting your filters.</div>
                </div>
            }
        </div>

    </div>

    <!-- ?? Premium Tabs ???????????????????????????????????????? -->
