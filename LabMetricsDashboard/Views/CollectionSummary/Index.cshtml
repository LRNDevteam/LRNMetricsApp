@* ?? Excel export progress overlay (driven by csExportDone cookie set by ExportExcel) ?? *@
<script>
(function () {
    var btn         = document.getElementById('csExportExcelBtn');
    var form        = document.getElementById('csRptFilterForm');
    var overlay     = document.getElementById('csExportOverlay');
    var bar         = document.getElementById('csExportBar');
    var pctLabel    = document.getElementById('csExportPct');
    var statusLabel = document.getElementById('csExportStatus');
    var cancelBtn   = document.getElementById('csExportCancelBtn');
    if (!btn || !form || !overlay || !bar || !pctLabel || !statusLabel || !cancelBtn) return;

    function getCookie(name) {
        var m = document.cookie.match('(^|;)\\s*' + name + '=([^;]*)');
        return m ? m[2] : null;
    }
    function deleteCookie(name) {
        document.cookie = name + '=; path=/; max-age=0';
    }
    function cleanup(pollTimer, creepTimer, iframe) {
        clearInterval(pollTimer);
        clearInterval(creepTimer);
        if (iframe && iframe.parentNode) document.body.removeChild(iframe);
    }

    var steps = [
        { pct: 8,  text: 'Starting export\u2026' },
        { pct: 20, text: 'Querying database\u2026' },
        { pct: 40, text: 'Aggregating results\u2026' },
        { pct: 60, text: 'Building Excel workbook\u2026' },
        { pct: 80, text: 'Formatting sheets\u2026' },
        { pct: 92, text: 'Finalizing workbook\u2026' }
    ];

    btn.addEventListener('click', function () {
        deleteCookie('csExportDone');
        overlay.style.display = 'flex';
        bar.style.width = '0%';
        pctLabel.textContent = '0%';
        statusLabel.textContent = 'Starting export\u2026';

        var startTime = Date.now();
        function elapsed() {
            var secs = Math.floor((Date.now() - startTime) / 1000);
            var m = Math.floor(secs / 60), s = secs % 60;
            return m > 0 ? m + 'm ' + s + 's' : s + 's';
        }

        var stepIdx = 0, currentPct = 0;
        var stepTimer = setInterval(function () {
            if (stepIdx < steps.length) {
                currentPct = steps[stepIdx].pct;
                bar.style.width = currentPct + '%';
                pctLabel.textContent = currentPct + '%';
                statusLabel.textContent = steps[stepIdx].text;
                stepIdx++;
            } else {
                clearInterval(stepTimer);
            }
        }, 1500);

        var creepTimer = setInterval(function () {
            if (stepIdx >= steps.length) {
                if (currentPct < 99) currentPct += 0.15;
                var p = Math.min(Math.round(currentPct), 99);
                bar.style.width = p + '%';
                pctLabel.textContent = p + '%';

                var msgs = [
                    'Writing ClaimLevelData sheet\u2026',
                    'Writing LineLevelData sheet\u2026',
                    'Formatting report sheets\u2026',
                    'Almost there, please wait\u2026',
                    'Large dataset \u2014 still processing\u2026',
                    'Compressing workbook\u2026',
                    'Hang tight, almost done\u2026'
                ];
                var msgIdx = Math.floor((Date.now() - startTime) / 4000) % msgs.length;
                statusLabel.textContent = msgs[msgIdx] + '  (' + elapsed() + ')';
            }
        }, 1000);

        // Trigger download via hidden iframe
        var params = new URLSearchParams(new FormData(form));
        var url = '@Url.Action("ExportExcel", "CollectionSummary")' + '?' + params.toString();
        var iframe = document.createElement('iframe');
        iframe.style.display = 'none';
        iframe.src = url;
        document.body.appendChild(iframe);

        // Poll for server cookie
        var pollTimer = setInterval(function () {
            if (getCookie('csExportDone')) {
                cleanup(pollTimer, creepTimer, iframe);
                clearInterval(stepTimer);
                deleteCookie('csExportDone');

                bar.style.width = '100%';
                pctLabel.textContent = '100%';
                statusLabel.textContent = 'Download complete!  (' + elapsed() + ')';

                setTimeout(function () { overlay.style.display = 'none'; }, 900);
            }
        }, 500);

        // Cancel button
        var onCancel = function () {
            cleanup(pollTimer, creepTimer, iframe);
            clearInterval(stepTimer);
            deleteCookie('csExportDone');
            overlay.style.display = 'none';
            cancelBtn.removeEventListener('click', onCancel);
        };
        cancelBtn.addEventListener('click', onCancel);

        // Safety timeout: 10 minutes
        setTimeout(function () {
            cleanup(pollTimer, creepTimer, iframe);
            clearInterval(stepTimer);
            overlay.style.display = 'none';
        }, 600000);
    });
})();
</script>

<script>
(function () {
    var tabList = document.getElementById('csRptTabs');
    var overlay = document.getElementById('csTabLoading');
    if (!tabList || !overlay) return;

    /*
     * Capture the scroll target ONCE at page-load using static offsetTop.
     * This value never changes regardless of content height.
     */
    var tabsScrollTop = (function () {
        var el = tabList, top = 0;
        while (el) { top += (el.offsetTop || 0); el = el.offsetParent; }
        return Math.max(0, top - 12);
    }());

    function showOverlay() {
        overlay.classList.add('active');
        overlay.setAttribute('aria-hidden', 'false');
    }
    function hideOverlay() {
        overlay.classList.remove('active');
        overlay.setAttribute('aria-hidden', 'true');
    }

    /*
     * show.bs.tab fires BEFORE Bootstrap starts the fade transition.
     * The old pane is still display:block and contributes full height.
     * Take it OUT of the layout flow immediately using position:absolute
     * so the container collapses before the new pane renders.
     * We avoid display:none because that breaks Bootstrap's transitionend.
     */
    tabList.addEventListener('show.bs.tab', function (e) {
        var prevBtn    = e.relatedTarget;
        var prevTarget = prevBtn ? prevBtn.getAttribute('data-bs-target') : null;
        var prevPane   = prevTarget ? document.querySelector(prevTarget) : null;
        if (prevPane) {
            prevPane.style.position      = 'absolute';
            prevPane.style.visibility    = 'hidden';
            prevPane.style.pointerEvents = 'none';
        }
        window.scrollTo({ top: tabsScrollTop, behavior: 'auto' });
        showOverlay();
    });

    /*
     * shown.bs.tab fires AFTER the new pane has fully faded in.
     * Bootstrap has removed .active from the old pane by now,
     * so we can safely restore its inline styles — Bootstrap's own
     * display:none rule for inactive panes takes over.
     */
    tabList.addEventListener('shown.bs.tab', function (e) {
        var prevBtn    = e.relatedTarget;
        var prevTarget = prevBtn ? prevBtn.getAttribute('data-bs-target') : null;
        var prevPane   = prevTarget ? document.querySelector(prevTarget) : null;
        if (prevPane) {
            prevPane.style.position      = '';
            prevPane.style.visibility    = '';
            prevPane.style.pointerEvents = '';
        }

        /* Reset inner scroll of newly visible pane */
        var newTarget = e.target ? e.target.getAttribute('data-bs-target') : null;
        var newPane   = newTarget ? document.querySelector(newTarget) : null;
        if (newPane) {
            newPane.querySelectorAll('.cs-rpt-scroll').forEach(function (el) {
                el.scrollTop = 0;
            });
        }

        /* Final scroll after all reflows are done */
        window.scrollTo({ top: tabsScrollTop, behavior: 'auto' });
        hideOverlay();
    });
})();
</script>
