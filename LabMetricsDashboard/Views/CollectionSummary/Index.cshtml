                    <strong>Source:</strong> Claim Level Data &bull;
                    <strong>Filter:</strong> InsurancePayment &gt; 0 &bull;
                    <strong>Sorted by:</strong> SUM(InsurancePayment) DESC &bull;
                    <strong>Metric:</strong> COUNT(DISTINCT ClaimID), SUM(InsurancePayment)
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <div style="font-size:2rem;opacity:.4">&#128202;</div>
                    <div class="fw-semibold mt-2">No panel payment data available</div>
                    <div class="small mt-1">No matching claim records found. Try adjusting your filters.</div>
                </div>
            }
        </div>

        <!-- ?? Rep vs Payments tab ????????????????????????????????????? -->
        <div class="tab-pane fade" id="reppay-pane" role="tabpanel" aria-labelledby="reppay-tab">
            @if (Model.RepPayments.HasData)
            {
                var periods = Model.RepPayments.Periods;
                var pivotRows = Model.RepPayments.Rows;
                <div class="cs-rpt-wrap">
                    <div class="cs-rpt-scroll">
                        <table class="cs-rpt-table">
                            <thead>
                                @{
                                    // Group periods by year for the first header row
                                    var yearGroups = periods.GroupBy(p => p.Year).OrderBy(g => g.Key).ToList();
                                }
                                <tr>
                                    <th rowspan="2" style="text-align:left;min-width:220px">Sales Rep</th>
                                    @foreach (var yg in yearGroups)
                                    {
                                        <th colspan="@(yg.Count() * 2)">@yg.Key</th>
                                    }
                                    <th colspan="2">Grand Total</th>
                                </tr>
                                <tr>
                                    @foreach (var p in periods)
                                    {
                                        var monthName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(p.Month);
                                        <th>@monthName Claims</th>
                                        <th>@monthName Payments</th>
                                    }
                                    <th>No. of Claims</th>
                                    <th>Insurance Payments</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in pivotRows)
                                {
                                    <tr>
                                        <td style="text-align:left;font-weight:600">@row.SalesRepName</td>
                                        @foreach (var p in periods)
                                        {
                                            var hasCell = row.Cells.TryGetValue(p, out var cell);
                                            <td style="text-align:right">@(hasCell ? cell!.NoOfClaims.ToString("N0") : "0")</td>
                                            <td style="text-align:right">@(hasCell ? cell!.InsurancePayments.ToString("C2") : "$0.00")</td>
                                        }
                                        <td style="text-align:right;font-weight:700">@row.GrandClaims.ToString("N0")</td>
                                        <td style="text-align:right;font-weight:700">@row.GrandPayments.ToString("C2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr style="background:linear-gradient(135deg,#0a1628 0%,#0e3460 50%,#0d5c74 100%);color:#fff;font-weight:700">
                                    <td style="text-align:left;color:#fff">Grand Total</td>
                                    @foreach (var p in periods)
                                    {
                                        var colClaims = pivotRows.Sum(r => r.Cells.TryGetValue(p, out var c) ? c.NoOfClaims : 0);
                                        var colPayments = pivotRows.Sum(r => r.Cells.TryGetValue(p, out var c) ? c.InsurancePayments : 0m);
                                        <td style="text-align:right;color:#fff">@colClaims.ToString("N0")</td>
                                        <td style="text-align:right;color:#fff">@colPayments.ToString("C2")</td>
                                    }
                                    <td style="text-align:right;color:#fff">@pivotRows.Sum(r => r.GrandClaims).ToString("N0")</td>
                                    <td style="text-align:right;color:#fff">@pivotRows.Sum(r => r.GrandPayments).ToString("C2")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <div class="mt-2" style="font-size:.68rem; color:#94a3b8">
                    <strong>Source:</strong> Claim Level Data &bull;
                    <strong>Filter:</strong> InsurancePayment &gt; 0, CheckDate is valid &bull;
                    <strong>Columns:</strong> Year / Month (from CheckDate) &bull;
                    <strong>Sorted by:</strong> Grand Total (SUM InsurancePayment) DESC &bull;
                    <strong>Metric:</strong> COUNT(DISTINCT ClaimID), SUM(InsurancePayment)
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <div style="font-size:2rem;opacity:.4">&#128100;</div>
                    <div class="fw-semibold mt-2">No rep payment data available</div>
                    <div class="small mt-1">No matching claim records found. Try adjusting your filters.</div>
                </div>
            }
        </div>

        <!-- ?? Insurance vs Payment % tab ????????????????????????????????? -->
        <div class="tab-pane fade" id="inspctpay-pane" role="tabpanel" aria-labelledby="inspctpay-tab">
            @if (Model.InsurancePaymentPct.Count > 0)
            {
                var grandTotalClaims = Model.InsurancePaymentPct.Sum(r => r.TotalClaims);
                var grandInsPayments = Model.InsurancePaymentPct.Sum(r => r.InsurancePayments);
                var grandPaidIns = Model.InsurancePaymentPct.Sum(r => r.PaidInsurancePayment);
                var grandPaidChg = Model.InsurancePaymentPct.Sum(r => r.PaidChargeAmount);
                var grandPaymentPct = grandPaidChg == 0 ? 0m : Math.Round(grandPaidIns / grandPaidChg * 100m, 2);
                var maxPct = Model.InsurancePaymentPct.Max(r => r.PaymentPct);
                <div class="cs-rpt-wrap">
                    <div class="cs-rpt-scroll">
                        <table class="cs-rpt-table">
                            <thead>
                                <tr>
                                    <th style="text-align:left;min-width:280px">Payer</th>
                                    <th style="min-width:140px">Total No. of Claims</th>
                                    <th style="min-width:180px">Insurance Payments</th>
                                    <th style="min-width:260px">Payment %</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.InsurancePaymentPct)
                                {
                                    var pct = row.PaymentPct;
                                    var barWidth = maxPct == 0 ? 0m : Math.Round(pct / maxPct * 100m, 1);
                                    <tr>
                                        <td style="text-align:left;font-weight:600">@row.PayerName</td>
                                        <td style="text-align:right">@row.TotalClaims.ToString("N0")</td>
                                        <td style="text-align:right">@row.InsurancePayments.ToString("C2")</td>
                                        <td>
                                            <div class="reimb-bar-bg">
                                                <div class="reimb-bar-fill" style="width:@(barWidth.ToString("F1"))%"></div>
                                                <div class="reimb-bar-label">@pct.ToString("F2") %</div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr style="background:linear-gradient(135deg,#0a1628 0%,#0e3460 50%,#0d5c74 100%);color:#fff;font-weight:700">
                                    <td style="text-align:left;color:#fff">Grand Total</td>
                                    <td style="text-align:right;color:#fff">@grandTotalClaims.ToString("N0")</td>
                                    <td style="text-align:right;color:#fff">@grandInsPayments.ToString("C2")</td>
                                    <td style="text-align:right;color:#fff">@grandPaymentPct.ToString("F2") %</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <div class="mt-2" style="font-size:.68rem; color:#94a3b8">
                    <strong>Source:</strong> Claim Level Data &bull;
                    <strong>Filter (applied):</strong> Payers: @(Model.FilterPayerNames != null && Model.FilterPayerNames.Count > 0 ? string.Join(", ", Model.FilterPayerNames) : "All") &nbsp;|&nbsp; Panels: @(Model.FilterPanelNames != null && Model.FilterPanelNames.Count > 0 ? string.Join(", ", Model.FilterPanelNames) : "All") &nbsp;|&nbsp; FirstBilledDate: @(string.IsNullOrWhiteSpace(Model.FilterFirstBillFrom) ? "-" : Model.FilterFirstBillFrom) — @(string.IsNullOrWhiteSpace(Model.FilterFirstBillTo) ? "-" : Model.FilterFirstBillTo) &bull;
                    <strong>Sorted by:</strong> SUM(InsurancePayment) DESC &bull;
                    <strong>Payment %:</strong> SUM(InsurancePayment) / SUM(ChargeAmount) × 100 where ClaimStatus IN (Fully Paid, Partially Paid)
                </div>
            }
            else
            {
                var inspReason = "No rows match: PayerName_Raw not blank · InsurancePayment > 0";
                <div class="text-center py-5 text-muted">
                    <div style="font-size:2rem;opacity:.4">&#128202;</div>
                    <div class="fw-semibold mt-2">No insurance payment data available</div>
                    <div class="small mt-1"><strong>Reason:</strong> @inspReason. Try adjusting your filters.</div>
                </div>
            }
        </div>

        <!-- ?? CPT vs Payment % tab ?????????????????????????????????????? -->
        <div class="tab-pane fade" id="cptpctpay-pane" role="tabpanel" aria-labelledby="cptpctpay-tab">
            @if (Model.CptPaymentPct.Count > 0)
            {
                var cptGrandUnits = Model.CptPaymentPct.Sum(r => r.SumServiceUnits);
                var cptGrandPaidIns = Model.CptPaymentPct.Sum(r => r.PaidInsurancePayment);
                var cptGrandPaidChg = Model.CptPaymentPct.Sum(r => r.PaidChargeAmount);
                var cptGrandPct = cptGrandPaidChg == 0 ? 0m : Math.Round(cptGrandPaidIns / cptGrandPaidChg * 100m, 2);
                var cptMaxPct = Model.CptPaymentPct.Max(r => r.PaymentPct);
                <div class="cs-rpt-wrap">
                    <div class="cs-rpt-scroll">
                        <table class="cs-rpt-table">
                            <thead>
                                <tr>
                                    <th style="text-align:left;min-width:200px">CPT Code</th>
                                    <th style="min-width:160px">Sum of Service Units</th>
                                    <th style="min-width:260px">Payment %</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.CptPaymentPct)
                                {
                                    var pct = row.PaymentPct;
                                    var barWidth = cptMaxPct == 0 ? 0m : Math.Round(pct / cptMaxPct * 100m, 1);
                                    <tr>
                                        <td style="text-align:left;font-weight:600">@row.CptCode</td>
                                        <td style="text-align:right">@row.SumServiceUnits.ToString("N0")</td>
                                        <td>
                                            <div class="reimb-bar-bg">
                                                <div class="reimb-bar-fill" style="width:@(barWidth.ToString("F1"))%"></div>
                                                <div class="reimb-bar-label">@pct.ToString("F2") %</div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr style="background:linear-gradient(135deg,#0a1628 0%,#0e3460 50%,#0d5c74 100%);color:#fff;font-weight:700">
                                    <td style="text-align:left;color:#fff">Grand Total</td>
                                    <td style="text-align:right;color:#fff">@cptGrandUnits.ToString("N0")</td>
                                    <td style="text-align:right;color:#fff">@cptGrandPct.ToString("F2") %</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <div class="mt-2" style="font-size:.68rem; color:#94a3b8">
                    <strong>Source:</strong> Line Level Data &bull;
                    <strong>Filter (applied):</strong> Payers: @(Model.FilterPayerNames != null && Model.FilterPayerNames.Count > 0 ? string.Join(", ", Model.FilterPayerNames) : "All") &nbsp;|&nbsp; Panels: @(Model.FilterPanelNames != null && Model.FilterPanelNames.Count > 0 ? string.Join(", ", Model.FilterPanelNames) : "All") &nbsp;|&nbsp; FirstBilledDate: @(string.IsNullOrWhiteSpace(Model.FilterFirstBillFrom) ? "-" : Model.FilterFirstBillFrom) — @(string.IsNullOrWhiteSpace(Model.FilterFirstBillTo) ? "-" : Model.FilterFirstBillTo) &bull;
                    <strong>Sorted by:</strong> SUM(Units) DESC &bull;
                    <strong>Payment %:</strong> SUM(InsurancePayment) / SUM(ChargeAmount) × 100 where ClaimStatus IN (Fully Paid, Partially Paid)
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <div style="font-size:2rem;opacity:.4">&#128202;</div>
                    <div class="fw-semibold mt-2">No CPT payment data available</div>
                    <div class="small mt-1"><strong>Reason:</strong> No rows match: CPTCode not blank (line-level). Try adjusting your filters.</div>
                </div>
            }
        </div>

    </div>

    @* ?? Active rule footer (dull) ?????????????????????????????? *@
    <div class="cs-rule-footer mt-3 small text-muted" style="opacity:.65;line-height:1.45;border-top:1px dashed #cfd6df;padding-top:.5rem">
        <div>
            <span class="fw-semibold">Active Rule:</span>
            @(string.IsNullOrWhiteSpace(Model.CollectionSummaryRule) ? "Default" : Model.CollectionSummaryRule)
        </div>
        @if (string.Equals(Model.CollectionSummaryRule, "Northwestlabs Rule", StringComparison.OrdinalIgnoreCase))
        {
            <div class="mt-1"><span class="fw-semibold">Northwestlabs Rule Logic:</span></div>
            <ul class="mb-0 ps-3" style="font-size:.78rem">
                <li>Source: <code>ClaimLevelData</code> (payments) @if (Model.UsesLineEncounters) { <text>+ <code>LineLevelData</code> (encounters)</text> }</li>
                <li>Rows: <code>PanelName</code> &nbsp;·&nbsp; Drill-down: @if (Model.UsesLineEncounters) { <text>All</text> } else { <text>Top 3</text> } <code>PayerName_Raw</code> by encounter count</li>
                <li>Columns: <code>YEAR(CheckDate)</code> / <code>MONTH(CheckDate)</code></li>
                <li>Filter: <code>InsurancePayment</code> &gt; 0 &nbsp;·&nbsp; <code>ClaimStatus</code> IN (Fully Paid, Partially Paid, Paid-Client) &nbsp;·&nbsp; <code>PostedDate</code> is a valid date</li>
            </ul>
        }
        else
        {
            <div class="mt-1">
                <span class="fw-semibold">Default Logic:</span>
                Monthly columns grouped by <code>YEAR/MONTH(CheckDate)</code>; rows = <code>PanelName</code>
                with @if (Model.UsesLineEncounters) { <text>all</text> } else { <text>Top 3</text> }
                <code>PayerName</code> drill-down by encounter count.
            </div>
        }
    </div>
}

<script>
    // Multi-select dropdown widget
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.cs-rpt-ms').forEach(function (ms) {
            var btn    = ms.querySelector('.cs-rpt-ms-btn');
            var panel  = ms.querySelector('.cs-rpt-ms-panel');
            var search = ms.querySelector('.cs-rpt-ms-search');
            var labels = ms.querySelectorAll('.cs-rpt-ms-list label');
            var labelEl = ms.querySelector('.cs-rpt-ms-label');
            var countEl = ms.querySelector('.cs-rpt-ms-count');

            function updateLabel() {
                var checked = ms.querySelectorAll('.cs-rpt-ms-list input:checked');
                if (checked.length === 0) {
                    labelEl.textContent = 'All';
                    countEl.style.display = 'none';
                } else if (checked.length === 1) {
                    labelEl.textContent = checked[0].value;
                    countEl.style.display = 'none';
                } else {
                    labelEl.textContent = checked[0].value;
                    countEl.textContent = '+' + (checked.length - 1);
                    countEl.style.display = '';
                }
            }

            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                document.querySelectorAll('.cs-rpt-ms-panel.open').forEach(function (p) {
                    if (p !== panel) p.classList.remove('open');
                });
                panel.classList.toggle('open');
                if (panel.classList.contains('open') && search) {
                    search.value = '';
                    search.focus();
                    labels.forEach(function (l) { l.classList.remove('cs-rpt-ms-hidden'); });
                }
            });

            if (search) {
                search.addEventListener('input', function () {
                    var q = this.value.toLowerCase();
                    labels.forEach(function (l) {
                        var text = l.textContent.toLowerCase();
                        l.classList.toggle('cs-rpt-ms-hidden', q.length > 0 && text.indexOf(q) === -1);
                    });
                });
            }

            ms.querySelectorAll('.cs-rpt-ms-list input').forEach(function (cb) {
                cb.addEventListener('change', updateLabel);
            });

            panel.addEventListener('click', function (e) { e.stopPropagation(); });
            updateLabel();
        });

        document.addEventListener('click', function () {
            document.querySelectorAll('.cs-rpt-ms-panel.open').forEach(function (p) {
                p.classList.remove('open');
            });
        });
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var exportBtn = document.getElementById('csExportExcelBtn');
        if (!exportBtn) return;

        var overlay = document.getElementById('csExportOverlay');
        var bar = document.getElementById('csExportBar');
        var pctLabel = document.getElementById('csExportPct');
        var statusLabel = document.getElementById('csExportStatus');
        var cancelBtn = document.getElementById('csExportCancelBtn');

        var steps = [
            { pct: 8,  text: 'Connecting to database…' },
            { pct: 18, text: 'Fetching Monthly Claim Volume…' },
            { pct: 28, text: 'Fetching Weekly Claim Volume…' },
            { pct: 38, text: 'Fetching Top 5 Reimbursement & Payments…' },
            { pct: 48, text: 'Fetching Insurance Aging & Panel data…' },
            { pct: 56, text: 'Fetching Rep Payments & Payment %…' },
            { pct: 64, text: 'Fetching CPT Payment % & Panel Averages…' },
            { pct: 72, text: 'Fetching ClaimLevelData rows…' },
            { pct: 80, text: 'Fetching LineLevelData rows…' },
            { pct: 88, text: 'Building Excel workbook…' },
            { pct: 94, text: 'Finalizing sheets & formatting…' }
        ];

        function getCookie(name) {
            var m = document.cookie.match('(^|;)\\s*' + name + '=([^;]*)');
            return m ? m[2] : null;
        }
        function deleteCookie(name) {
            document.cookie = name + '=; path=/; max-age=0';
        }

        function cleanup(pollTimer, creepTimer, iframe) {
            clearInterval(pollTimer);
            clearInterval(creepTimer);
            if (iframe && iframe.parentNode) document.body.removeChild(iframe);
        }

        function setPct(pct, text) {
            var p = Math.min(Math.round(pct), 99);
            bar.style.width = p + '%';
            pctLabel.textContent = p + '%';
            if (text) statusLabel.textContent = text;
        }

        exportBtn.addEventListener('click', function () {
            var form = document.getElementById('csRptFilterForm');
            if (!form) return;

            deleteCookie('csExportDone');

            overlay.style.display = 'flex';
            setPct(0, 'Starting export…');

            var startTime = Date.now();
            function elapsed() {
                var secs = Math.floor((Date.now() - startTime) / 1000);
                var m = Math.floor(secs / 60), s = secs % 60;
                return m > 0 ? m + 'm ' + s + 's' : s + 's';
            }

            // Walk through scripted steps
            var stepIdx = 0;
            var currentPct = 0;
            var stepTimer = setInterval(function () {
                if (stepIdx < steps.length) {
                    var s = steps[stepIdx];
                    currentPct = s.pct;
                    setPct(currentPct, s.text);
                    stepIdx++;
                } else {
                    clearInterval(stepTimer);
                }
            }, 1800);

            // After scripted steps end, keep creeping slowly toward 99%
            // and rotate reassuring messages with elapsed time
            var creepTimer = setInterval(function () {
                if (stepIdx >= steps.length) {
                    if (currentPct < 99) currentPct += 0.15;
                    var p = Math.min(Math.round(currentPct), 99);
                    bar.style.width = p + '%';
                    pctLabel.textContent = p + '%';

                    var msgs = [
                        'Writing ClaimLevelData sheet…',
                        'Writing LineLevelData sheet…',
                        'Formatting report sheets…',
                        'Almost there, please wait…',
                        'Large dataset — still processing…',
                        'Compressing workbook…',
                        'Hang tight, almost done…'
                    ];
                    var msgIdx = Math.floor((Date.now() - startTime) / 4000) % msgs.length;
                    statusLabel.textContent = msgs[msgIdx] + '  (' + elapsed() + ')';
                }
            }, 1000);

            // Trigger download via hidden iframe
            var params = new URLSearchParams(new FormData(form));
            var url = '@Url.Action("ExportExcel", "CollectionSummary")' + '?' + params.toString();
            var iframe = document.createElement('iframe');
            iframe.style.display = 'none';
            iframe.src = url;
            document.body.appendChild(iframe);

            // Poll for server cookie
            var pollTimer = setInterval(function () {
                if (getCookie('csExportDone')) {
                    clearInterval(pollTimer);
                    clearInterval(stepTimer);
                    clearInterval(creepTimer);
                    deleteCookie('csExportDone');

                    bar.style.width = '100%';
                    pctLabel.textContent = '100%';
                    statusLabel.textContent = 'Download complete!  (' + elapsed() + ')';

                    setTimeout(function () {
                        overlay.style.display = 'none';
                        if (iframe.parentNode) document.body.removeChild(iframe);
                    }, 900);
                }
            }, 500);

            // Cancel button
            var onCancel = function () {
                cleanup(pollTimer, creepTimer, iframe);
                clearInterval(stepTimer);
                deleteCookie('csExportDone');
                overlay.style.display = 'none';
                cancelBtn.removeEventListener('click', onCancel);
            };
            cancelBtn.addEventListener('click', onCancel);

            // Safety timeout: 10 minutes
            setTimeout(function () {
                cleanup(pollTimer, creepTimer, iframe);
                clearInterval(stepTimer);
                overlay.style.display = 'none';
            }, 600000);
        });
    });
</script>
