/* MCV data columns: compact and uniform */
#mcv-pane .cs-rpt-table { width: auto; }
#mcv-pane .cs-rpt-table thead th:nth-child(n+3) { white-space: nowrap; padding: .4rem .4rem; font-size: .62rem; width: 100px; min-width: 100px; max-width: 100px; }
