@model LabMetricsDashboard.Models.CollectionSummaryViewModel
@{
    ViewData["Title"]       = $"Collection Summary – {Model.SelectedLab}";
    ViewData["SelectedLab"] = Model.SelectedLab;
    ViewData["PageLabel"]   = "Collection Summary";
}

<style>
/* ?? Export loading overlay ?????????????????????????????????????????? */
.cs-export-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(15, 23, 42, .55);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
}
.cs-export-dialog {
    background: #fff; border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,.18);
    padding: 2rem 2.5rem; width: 380px; text-align: center;
}
.cs-export-icon {
    font-size: 2.4rem; color: #0d8553;
    margin-bottom: .6rem;
    animation: cs-export-pulse 1.4s ease-in-out infinite;
}
@@keyframes cs-export-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .6; transform: scale(.92); }
}
.cs-export-title {
    font-size: 1.05rem; font-weight: 700; color: #1e293b;
    margin-bottom: .25rem;
}
.cs-export-sub {
    font-size: .78rem; color: #64748b; margin-bottom: 1rem;
}
.cs-export-bar-bg {
    width: 100%; height: 10px; background: #e2e8f0;
    border-radius: 6px; overflow: hidden;
}
.cs-export-bar-fill {
    height: 100%; border-radius: 6px;
    background: linear-gradient(90deg, #047857, #0d8553, #10b981);
    transition: width .4s ease;
}
.cs-export-pct {
    font-size: .82rem; font-weight: 700; color: #0d8553;
    margin-top: .5rem;
}

/* ?? Reuse Production Report premium styles ????????????????????? */
.cs-rpt-wrap {
    border-radius: 14px; overflow: hidden;
    background: #fff; border: 1px solid #e0e6ed;
    box-shadow: 0 2px 12px rgba(0,0,0,.05);
}
.cs-rpt-scroll { max-height: 78vh; overflow: auto; }

.cs-rpt-table {
    border-collapse: separate; border-spacing: 0;
    font-size: .78rem; width: 100%;
}
.cs-rpt-table thead th {
    background: linear-gradient(135deg, #0a1628 0%, #0e3460 50%, #0d5c74 100%);
    color: rgba(255,255,255,.92); font-weight: 700; font-size: .68rem;
    letter-spacing: .04em; text-transform: uppercase;
    padding: .6rem .7rem; text-align: center;
    position: sticky; top: 0; z-index: 5;
    border-bottom: 1px solid #0a2a4a;
    border-right: 1px solid rgba(255,255,255,.08);
}
.cs-rpt-table thead th:first-child { text-align: center; width: 56px; }
.cs-rpt-table thead th:nth-child(2) { text-align: left; }

.cs-rpt-table td {
    padding: .55rem .7rem; vertical-align: middle;
    border-right: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
}
.cs-rpt-table td:first-child {
    text-align: center; font-weight: 700; color: #1e293b; width: 56px;
}
.cs-rpt-table td:nth-child(2) {
    text-align: left; font-weight: 600; color: #1e293b; min-width: 280px;
}
.cs-rpt-table td:nth-child(3) {
    text-align: right; font-weight: 700; font-size: .88rem;
    font-variant-numeric: tabular-nums;
}

.cs-rpt-table tbody tr:nth-child(odd) td { background: #f8fafc; }
.cs-rpt-table tbody tr:nth-child(even) td { background: #fff; }
.cs-rpt-table tbody tr:hover td { background: #eef4ff; }

/* Reimbursement bar */
.reimb-bar-bg {
    width: 100%; height: 22px; background: #e2e8f0;
    border-radius: 6px; overflow: hidden; position: relative;
    min-width: 120px;
}
.reimb-bar-fill {
    height: 100%; border-radius: 6px;
    background: linear-gradient(90deg, #0d5c74, #1565c0);
    transition: width .5s ease;
}
.reimb-bar-label {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .72rem; font-weight: 800; color: #1e293b;
    text-shadow: 0 0 3px #fff, 0 0 3px #fff, 0 0 3px #fff;
}

/* KPI cards */
.reimb-kpi {
    display: flex; gap: .35rem; font-size: .65rem; color: #64748b;
    margin-top: .15rem;
}
.reimb-kpi span { white-space: nowrap; }

/* ?? Top-5 premium dashboard cards ?????????????????????????????? */
.top5-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.5rem; }
@@media (max-width: 1100px) { .top5-cards { grid-template-columns: 1fr; } }

.top5-card {
    background: #fff; border-radius: 16px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px rgba(0,0,0,.06);
    overflow: hidden;
    display: flex; flex-direction: column;
}

/* Header: gradient left accent + title + badge */
.top5-card-hdr {
    padding: .9rem 1.2rem .5rem;
    border-left: 4px solid;
    display: flex; justify-content: space-between; align-items: flex-start;
}
.top5-card-hdr.reimb-hdr { border-left-color: #1565c0; }
.top5-card-hdr.totpay-hdr { border-left-color: #0d8553; }
.top5-card-hdr-title {
    font-size: .82rem; font-weight: 800; color: #1e293b;
    letter-spacing: .02em; text-transform: uppercase;
}
.top5-card-hdr-sub {
    font-size: .72rem; font-weight: 400; color: #64748b;
    margin-top: .15rem;
}
.top5-card-badge {
    display: inline-flex; align-items: center; gap: .35rem;
    font-size: .7rem; font-weight: 700; color: #fff;
    padding: .3rem .7rem; border-radius: 20px;
    white-space: nowrap; flex-shrink: 0;
}
.top5-card-badge.reimb-badge { background: linear-gradient(135deg, #1565c0, #0d5c74); }
.top5-card-badge.totpay-badge { background: linear-gradient(135deg, #0d8553, #047857); }

/* Body: KPI boxes + gauge row */
.top5-card-body {
    padding: .6rem 1.2rem 1rem;
    display: flex; align-items: center; gap: 1rem;
    flex: 1;
}
.top5-kpi-boxes {
    display: flex; gap: .75rem; flex: 1;
    flex-wrap: wrap;
}
.top5-kpi-box {
    flex: 1; min-width: 120px;
    background: #f8fafc; border: 1px solid #e2e8f0;
    border-radius: 10px; padding: .6rem .8rem;
}
.top5-kpi-box-label {
    display: flex; align-items: center; gap: .3rem;
    font-size: .65rem; font-weight: 600; color: #64748b;
    text-transform: uppercase; letter-spacing: .03em;
}
.top5-kpi-box-label i { font-size: .72rem; }
.top5-kpi-box-value {
    font-size: 1.35rem; font-weight: 800; color: #1e293b;
    margin-top: .2rem; font-variant-numeric: tabular-nums;
}

/* Circular donut gauge (CSS conic-gradient) */
.top5-gauge {
    position: relative; flex-shrink: 0;
    width: 90px; height: 90px;
}
.top5-gauge-ring {
    width: 90px; height: 90px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
}
.top5-gauge-ring.reimb-ring {
    background: conic-gradient(#1565c0 var(--gauge-pct, 0%), #e2e8f0 0%);
}
.top5-gauge-ring.totpay-ring {
    background: conic-gradient(#0d8553 var(--gauge-pct, 0%), #e2e8f0 0%);
}
.top5-gauge-inner {
    width: 66px; height: 66px; border-radius: 50%;
    background: #fff; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
}
.top5-gauge-pct {
    font-size: .92rem; font-weight: 800; color: #1e293b;
    line-height: 1;
}
.top5-gauge-label {
    font-size: .55rem; font-weight: 600; color: #94a3b8;
    text-transform: uppercase; letter-spacing: .04em;
    margin-top: .1rem;
}

/* Footer action message */
.top5-card-footer {
    padding: .65rem 1.2rem;
    font-size: .72rem; color: #475569; font-weight: 500;
    border-top: 1px solid #e2e8f0;
    background: #f8fafc;
}
.top5-card-footer strong { color: #1e293b; }
.top5-hl-blue { color: #1565c0; font-weight: 700; }
.top5-hl-green { color: #0d8553; font-weight: 700; }
.top5-hl-red { color: #dc2626; font-weight: 700; }

/* Payer list inside card */
.top5-payer-list { padding: 0 1.2rem .8rem; }
.top5-payer-row {
    display: flex; align-items: center; gap: .6rem;
    padding: .35rem 0; border-bottom: 1px solid #f1f5f9;
    font-size: .75rem;
}
.top5-payer-row:last-child { border-bottom: none; }
.top5-payer-rank {
    width: 22px; height: 22px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .62rem; font-weight: 800; color: #fff; flex-shrink: 0;
}
.top5-payer-rank.reimb-rank { background: linear-gradient(135deg, #1565c0, #0d5c74); }
.top5-payer-rank.totpay-rank { background: linear-gradient(135deg, #0d8553, #047857); }
.top5-payer-name {
    flex: 1; font-weight: 600; color: #1e293b;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.top5-payer-detail {
    display: flex; gap: .5rem; font-size: .65rem; color: #64748b; flex-shrink: 0;
}
.top5-payer-bar-wrap { width: 110px; flex-shrink: 0; }
.top5-payer-bar-bg {
    width: 100%; height: 18px; background: #e2e8f0;
    border-radius: 5px; overflow: hidden; position: relative;
}
.top5-payer-bar-fill {
    height: 100%; border-radius: 5px;
    transition: width .5s ease;
}
.top5-payer-bar-fill.reimb-fill { background: linear-gradient(90deg, #0d5c74, #1565c0); }
.top5-payer-bar-fill.totpay-fill { background: linear-gradient(90deg, #047857, #0d8553); }
.top5-payer-bar-label {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .62rem; font-weight: 800; color: #1e293b;
    text-shadow: 0 0 3px #fff, 0 0 3px #fff, 0 0 3px #fff;
}

/* ?? Filter panel (Production Report style) ????????????????????? */
.cs-rpt-filter-panel {
    background: #fff; border-radius: 12px;
    box-shadow: 0 2px 10px rgba(0,0,0,.07);
}
.cs-rpt-filter-badge { font-size: .7rem; vertical-align: middle; }

/* Multi-select dropdown */
.cs-rpt-ms { position: relative; }
.cs-rpt-ms-btn {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: .3rem .6rem; font-size: .8rem;
    border: 1px solid #ced4da; border-radius: .375rem;
    background: #fff; cursor: pointer; min-height: 31px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.cs-rpt-ms-btn:hover { border-color: #7B8B8E; }
.cs-rpt-ms-btn .cs-rpt-ms-count {
    background: #2B2D42; color: #fff; font-size: .65rem;
    border-radius: 10px; padding: 0 .45rem; margin-left: .4rem;
    font-weight: 700; flex-shrink: 0;
}
.cs-rpt-ms-panel {
    display: none; position: absolute; z-index: 100; top: 100%;
    left: 0; right: 0; background: #fff; border: 1px solid #ced4da;
    border-radius: .375rem; box-shadow: 0 4px 16px rgba(0,0,0,.12);
    margin-top: 2px; max-height: 280px; overflow: hidden;
}
.cs-rpt-ms-panel.open { display: flex; flex-direction: column; }
.cs-rpt-ms-search {
    border: none; border-bottom: 1px solid #e9ecef;
    padding: .4rem .6rem; font-size: .78rem; outline: none; width: 100%;
}
.cs-rpt-ms-list {
    overflow-y: auto; max-height: 220px; padding: .25rem 0;
}
.cs-rpt-ms-list label {
    display: flex; align-items: center; gap: .4rem;
    padding: .25rem .6rem; font-size: .78rem; cursor: pointer; margin: 0;
}
.cs-rpt-ms-list label:hover { background: #edf0f0; }
.cs-rpt-ms-list label.cs-rpt-ms-hidden { display: none; }

/* ?? Premium pill tabs ?????????????????????????????????????????? */
.cs-rpt-tabs {
    display: flex; flex-wrap: wrap; gap: .45rem;
    padding: .55rem .65rem;
    background: linear-gradient(135deg, #f8fafd 0%, #eef3fa 100%);
    border: 1px solid #dce4f0;
    border-radius: 1rem;
    box-shadow: 0 2px 10px rgba(15,23,42,.04);
}
.cs-rpt-tabs .nav-item { margin: 0; }
.cs-rpt-tabs .nav-link {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .45rem .85rem;
    font-size: .76rem; font-weight: 700; letter-spacing: .015em;
    color: #3b5578;
    background: #fff;
    border: 1.5px solid #d4dde9;
    border-radius: .75rem;
    transition: all .18s ease;
    box-shadow: 0 1px 3px rgba(15,23,42,.04);
    white-space: nowrap;
}
.cs-rpt-tabs .nav-link i {
    font-size: .82rem; opacity: .7; transition: opacity .18s;
}
.cs-rpt-tabs .nav-link:hover {
    color: #0e3460; background: #edf2fb;
    border-color: #b4c6e0;
    box-shadow: 0 2px 8px rgba(15,23,42,.08);
}
.cs-rpt-tabs .nav-link:hover i { opacity: 1; }
.cs-rpt-tabs .nav-link.active {
    color: #fff;
    background: linear-gradient(135deg, #0a1628 0%, #0e3460 50%, #0d5c74 100%);
    border-color: #0e3460;
    box-shadow: 0 4px 14px rgba(14,52,96,.30);
}
.cs-rpt-tabs .nav-link.active i { opacity: 1; }
.cs-rpt-tabs .nav-link.disabled {
    opacity: .45; pointer-events: none; cursor: default;
}

/* ?? Rep vs Payments sticky first column ???????????????????????? */
#reppay-pane .cs-rpt-table thead th:first-child {
    position: sticky; left: 0; z-index: 10;
    background: linear-gradient(135deg, #0a1628 0%, #0e3460 50%, #0d5c74 100%);
}
#reppay-pane .cs-rpt-table tbody td:first-child {
    position: sticky; left: 0; z-index: 3;
    border-right: 2px solid #d4dde9;
}
#reppay-pane .cs-rpt-table tbody tr:nth-child(odd) td:first-child { background: #f8fafc; }
#reppay-pane .cs-rpt-table tbody tr:nth-child(even) td:first-child { background: #fff; }
#reppay-pane .cs-rpt-table tbody tr:hover td:first-child { background: #eef4ff; }
