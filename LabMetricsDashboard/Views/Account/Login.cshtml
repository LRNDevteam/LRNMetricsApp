@model LabMetricsDashboard.Controllers.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In - Lab Revenue Intelligence";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --brand-deep: #0d1b2a;
            --brand-mid:  #1b3a5c;
            --brand-blue: #1565c0;
            --brand-cyan: #00b8d4;
        }
        * { box-sizing: border-box; }
        html, body { height:100%; margin:0; }
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background:
                radial-gradient(1100px 600px at 12% 18%, rgba(100,181,246,.18), transparent 60%),
                radial-gradient(900px 600px at 92% 84%, rgba(0,184,212,.18), transparent 60%),
                linear-gradient(135deg, var(--brand-deep) 0%, var(--brand-mid) 55%, var(--brand-blue) 100%);
            color:#fff;
            overflow:hidden;
        }

        /* Animated background orbs */
        .bg-orb {
            position:fixed; border-radius:50%; filter:blur(60px); opacity:.55;
            pointer-events:none;
            animation: float 18s ease-in-out infinite;
        }
        .bg-orb.o1 { width:340px; height:340px; background:#1565c0; top:-90px; left:-80px; }
        .bg-orb.o2 { width:280px; height:280px; background:#00b8d4; bottom:-80px; right:-60px; animation-delay:-6s; }
        .bg-orb.o3 { width:220px; height:220px; background:#64b5f6; top:55%; left:48%; animation-delay:-12s; opacity:.35; }
        @@keyframes float {
            0%,100% { transform: translate3d(0,0,0); }
            50%     { transform: translate3d(20px, -25px, 0); }
        }

        .login-shell {
            display:grid;
            grid-template-columns: 1.1fr .9fr;
            min-height:100vh;
        }
        @@media (max-width: 960px) {
            .login-shell { grid-template-columns: 1fr; }
            .hero-pane { display:none; }
        }

        /* Left hero pane */
        .hero-pane {
            position:relative; padding:3rem 3.25rem;
            display:flex; flex-direction:column; justify-content:space-between;
            backdrop-filter: blur(2px);
        }
        .brand {
            display:flex; align-items:center; gap:.7rem;
            font-weight:800; font-size:1.15rem; letter-spacing:.04em;
        }
        .brand .brand-mark {
            width:54px; height:54px; border-radius:14px;
            background:rgba(255,255,255,.12);
            border:1px solid rgba(255,255,255,.22);
            display:grid; place-items:center;
            box-shadow: 0 8px 22px rgba(0,0,0,.25);
            padding:6px;
        }
        .brand .brand-mark img { width:100%; height:100%; object-fit:contain; }
        .brand small { display:block; font-weight:500; opacity:.7; font-size:.7rem; letter-spacing:.18em; text-transform:uppercase; }

        /* LRN logo above sign-in form (mobile + a subtle reinforcement on the card) */
        .login-card-brand {
            display:flex; align-items:center; justify-content:center;
            gap:.6rem; margin-bottom:1.1rem;
        }
        .login-card-brand img { height:38px; width:auto; object-fit:contain; }
        .login-card-brand .name {
            font-weight:800; color:#0d1b2a; font-size:.95rem; letter-spacing:.04em;
            line-height:1.1;
        }
        .login-card-brand .name small {
            display:block; font-weight:600; color:#64748b;
            font-size:.62rem; letter-spacing:.18em; text-transform:uppercase;
        }

        .hero-headline {
            margin-top:auto; max-width:520px;
        }
        .hero-headline h1 {
            font-size: clamp(1.8rem, 2.6vw, 2.6rem);
            font-weight: 800; line-height:1.15;
            margin:0 0 1rem 0;
        }
        .hero-headline p {
            color: rgba(255,255,255,.78); font-size:1.02rem; line-height:1.55; margin:0;
        }

        .hero-features {
            margin-top:2.25rem;
            display:grid; grid-template-columns:repeat(2,minmax(0,1fr));
            gap:.85rem; max-width:520px;
        }
        .feature {
            background:rgba(255,255,255,.07);
            border:1px solid rgba(255,255,255,.12);
            border-radius:14px;
            padding:.75rem .9rem;
            display:flex; align-items:flex-start; gap:.7rem;
        }
        .feature i {
            font-size:1.1rem; color:#64b5f6;
            background:rgba(100,181,246,.16);
            width:32px; height:32px; border-radius:9px;
            display:grid; place-items:center; flex-shrink:0;
        }
        .feature .ftxt { font-size:.82rem; color:rgba(255,255,255,.85); line-height:1.3; }
        .feature .fttl { font-weight:700; color:#fff; display:block; margin-bottom:.1rem; }

        .hero-footer { font-size:.75rem; color:rgba(255,255,255,.55); margin-top:1.25rem; }

        /* Right login card pane */
        .login-pane {
            display:flex; align-items:center; justify-content:center;
            padding:2rem;
        }
        .login-card {
            width: 100%; max-width: 440px;
            background: rgba(255,255,255,.96);
            color:#1a2744;
            border-radius:24px;
            box-shadow: 0 30px 80px rgba(0,0,0,.4);
            padding: 2.25rem 2.25rem 1.75rem;
            backdrop-filter: blur(20px);
            border:1px solid rgba(255,255,255,.6);
        }
        .login-card h2 {
            margin:0 0 .25rem 0;
            font-weight:800; color:#0d1b2a;
            font-size:1.6rem;
        }
        .login-card .subtitle {
            color:#64748b; font-size:.88rem; margin-bottom:1.4rem;
        }
        .login-card .form-label {
            font-size:.72rem; font-weight:700; letter-spacing:.07em;
            text-transform:uppercase; color:#5a6a8a; margin-bottom:.35rem;
        }
        .login-card .input-group-text {
            background:transparent; border-right:none;
            color:#94a3b8;
        }
        .login-card .form-control {
            border-left:none;
            padding:.7rem .85rem; font-size:.95rem;
            border-radius: 0 12px 12px 0;
            border-color:#d1d9e6;
        }
        .login-card .input-group { border-radius:12px; }
        .login-card .input-group .form-control { box-shadow:none; }
        .login-card .input-group:focus-within .input-group-text,
        .login-card .input-group:focus-within .form-control,
        .login-card .input-group:focus-within .btn-toggle-pwd {
            border-color:#1565c0;
            box-shadow:0 0 0 3px rgba(21,101,192,.12);
        }
        .login-card .input-group-text:first-child {
            border-radius: 12px 0 0 12px;
            border-right:none;
        }
        .btn-toggle-pwd {
            border:1px solid #d1d9e6; border-left:none;
            background:transparent;
            border-radius: 0 12px 12px 0;
            color:#94a3b8;
            padding:0 .85rem;
        }
        .btn-toggle-pwd:hover { color:#1565c0; }

        .btn-signin {
            width:100%;
            background: linear-gradient(135deg, #1565c0, #00b8d4);
            color:#fff; font-weight:700;
            border:none; border-radius:12px;
            padding:.85rem 1rem; font-size:.95rem;
            letter-spacing:.04em;
            box-shadow:0 8px 22px rgba(21,101,192,.35);
            transition: transform .12s ease, box-shadow .15s ease, filter .15s ease;
        }
        .btn-signin:hover { transform: translateY(-1px); filter:brightness(1.05); box-shadow:0 12px 28px rgba(21,101,192,.45); }
        .btn-signin:active { transform: translateY(0); }
        .btn-signin .spinner-border { width:1rem; height:1rem; }

        .form-check-input:checked {
            background-color:#1565c0; border-color:#1565c0;
        }

        .login-footer {
            margin-top: 1.4rem; text-align:center;
            color:#94a3b8; font-size:.78rem;
        }

        .alert-login {
            border-radius:12px; padding:.7rem .9rem;
            font-size:.85rem;
            background:#fff5f5; color:#b91c1c;
            border:1px solid #fecaca;
            display:flex; align-items:flex-start; gap:.5rem;
        }
        .alert-login.success { background:#f0fdf4; color:#166534; border-color:#bbf7d0; }
    </style>
</head>
<body>

<div class="bg-orb o1"></div>
<div class="bg-orb o2"></div>
<div class="bg-orb o3"></div>

<div class="login-shell">

    <!-- Left hero pane -->
    <aside class="hero-pane">
        <div class="brand">
            <div class="brand-mark">
                <img src="~/images/LRN-White-Logo-footer-1-1.png" alt="LRN Logo" />
            </div>
            <div>
                Lab Revenue Intelligence
                <small>Navigator</small>
            </div>
        </div>

        <div class="hero-headline">
            <h1>Welcome back. <br/>Insights that move revenue forward.</h1>
            <p>Sign in to access dashboards, denial analytics, predictive insights and coding intelligence — all in one secure workspace.</p>

            <div class="hero-features">
                <div class="feature">
                    <i class="bi bi-speedometer2"></i>
                    <div class="ftxt"><span class="fttl">Revenue Dashboards</span>Real-time KPIs across labs.</div>
                </div>
                    <div class="feature">
                        <i class="bi bi-clipboard-data-fill"></i>
                        <div class="ftxt"><span class="fttl">Reports & Insights</span>Production, Collection, LIS &amp; Executive Summary.</div>
                    </div>
                <div class="feature">
                    <i class="bi bi-graph-up-arrow"></i>
                    <div class="ftxt"><span class="fttl">Predictive Analytics</span>Forecasts & risk insights.</div>
                </div>
                <div class="feature">
                    <i class="bi bi-pencil-square"></i>
                    <div class="ftxt"><span class="fttl">Coding Intelligence</span>Lost revenue detection.</div>
                </div>
            </div>
        </div>

        <div class="hero-footer">© 2026 Lab Revenue Intelligence · All rights reserved.</div>
    </aside>

    <!-- Right login card pane -->
    <main class="login-pane">
        <div class="login-card">
            <div class="login-card-brand">
                <img src="~/images/LRN-White-Logo-footer-1-1.png"
                     alt="LRN Logo"
                     style="filter:brightness(.2)" />
                <div class="name">
                    Lab Revenue Intelligence
                    <small>Navigator</small>
                </div>
            </div>
            <h2>Sign in</h2>
            <div class="subtitle">Use your account to access the workspace.</div>

            @if (TempData["LoginError"] is string loginError && !string.IsNullOrWhiteSpace(loginError))
            {
                <div class="alert-login mb-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>@loginError</div>
                </div>
            }
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
            {
                <div class="alert-login mb-3">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div>@ViewData.ModelState[""]!.Errors.First().ErrorMessage</div>
                </div>
            }

            <form asp-action="Login" method="post" autocomplete="off" id="loginForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@(ViewData["ReturnUrl"] as string)" />

                <div class="mb-3">
                    <label class="form-label" for="UserName">Username</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                        <input asp-for="UserName" id="UserName" class="form-control"
                               placeholder="Enter your username" required autofocus
                               autocomplete="username" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label mb-0" for="Password">Password</label>
                        <a href="#" class="small text-decoration-none" style="color:#1565c0">Forgot?</a>
                    </div>
                    <div class="input-group mt-1">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="Password" id="Password" type="password" class="form-control"
                               placeholder="Enter your password" required
                               autocomplete="current-password" />
                        <button class="btn btn-toggle-pwd" type="button" id="togglePwd" tabindex="-1">
                            <i class="bi bi-eye" id="togglePwdIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" asp-for="RememberMe" id="RememberMe" />
                    <label class="form-check-label small" for="RememberMe">Keep me signed in</label>
                </div>

                <button type="submit" class="btn-signin" id="btnSignin">
                    <span id="signinLabel"><i class="bi bi-box-arrow-in-right me-1"></i> Sign In</span>
                    <span id="signinSpinner" class="d-none">
                        <span class="spinner-border me-1" role="status"></span> Signing in…
                    </span>
                </button>
            </form>

            <div class="login-footer">
                Need help? Contact your administrator.
            </div>
        </div>
    </main>

</div>

<script>
    (function() {
        var pwd = document.getElementById('Password');
        var btn = document.getElementById('togglePwd');
        var icon = document.getElementById('togglePwdIcon');
        if (btn && pwd && icon) {
            btn.addEventListener('click', function() {
                if (pwd.type === 'password') {
                    pwd.type = 'text';
                    icon.classList.remove('bi-eye');
                    icon.classList.add('bi-eye-slash');
                } else {
                    pwd.type = 'password';
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                }
            });
        }

        var form = document.getElementById('loginForm');
        var label = document.getElementById('signinLabel');
        var spinner = document.getElementById('signinSpinner');
        var signBtn = document.getElementById('btnSignin');
        if (form && label && spinner && signBtn) {
            form.addEventListener('submit', function() {
                label.classList.add('d-none');
                spinner.classList.remove('d-none');
                signBtn.disabled = true;
            });
        }
    })();
</script>

</body>
</html>
