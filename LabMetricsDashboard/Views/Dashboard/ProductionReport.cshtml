@model LabMetricsDashboard.Models.ProductionReportViewModel
@{
    ViewData["Title"]       = $"Production Report – {Model.SelectedLab}";
    ViewData["SelectedLab"] = Model.SelectedLab;
    ViewData["PageLabel"]   = "Production Report";

    // Filter out year 1900 on the view side as well
    var validYears  = Model.Years.Where(y => y > 1900).ToList();
    var validMonths = Model.Months.Where(m => int.Parse(m[..4]) > 1900).ToList();

    var monthsByYear = validMonths
        .GroupBy(m => int.Parse(m[..4]))
        .OrderBy(g => g.Key)
        .ToDictionary(g => g.Key, g => g.OrderBy(m => m).ToList());

    string MonthLabel(string ym)
    {
        var parts = ym.Split('-');
        return new DateTime(int.Parse(parts[0]), int.Parse(parts[1]), 1).ToString("MMM");
    }

    int CellClaims(Dictionary<string, LabMetricsDashboard.Models.ProductionMonthCell>? d, string mk)
        => d is not null && d.TryGetValue(mk, out var c) ? c.ClaimCount : 0;
    decimal CellCharges(Dictionary<string, LabMetricsDashboard.Models.ProductionMonthCell>? d, string mk)
        => d is not null && d.TryGetValue(mk, out var c) ? c.BilledCharges : 0m;
    int YearClaims(Dictionary<int, LabMetricsDashboard.Models.ProductionYearTotal>? d, int y)
        => d is not null && d.TryGetValue(y, out var t) ? t.ClaimCount : 0;
    decimal YearCharges(Dictionary<int, LabMetricsDashboard.Models.ProductionYearTotal>? d, int y)
        => d is not null && d.TryGetValue(y, out var t) ? t.BilledCharges : 0m;

    int GrandYearClaims(int year) =>
        Model.GrandTotalByMonth.Where(kv => kv.Key.StartsWith($"{year:D4}")).Sum(kv => kv.Value.ClaimCount);
    decimal GrandYearCharges(int year) =>
        Model.GrandTotalByMonth.Where(kv => kv.Key.StartsWith($"{year:D4}")).Sum(kv => kv.Value.BilledCharges);

    // Recompute grand totals excluding 1900
    int grandClaims = Model.GrandTotalByMonth
        .Where(kv => int.Parse(kv.Key[..4]) > 1900).Sum(kv => kv.Value.ClaimCount);
    decimal grandCharges = Model.GrandTotalByMonth
        .Where(kv => int.Parse(kv.Key[..4]) > 1900).Sum(kv => kv.Value.BilledCharges);

    // Payer Breakdown helpers
    var pbYears  = Model.PayerBreakdownYears.Where(y => y > 1900).ToList();
    var pbMonths = Model.PayerBreakdownMonths.Where(m => int.Parse(m[..4]) > 1900).ToList();
    var pbMonthsByYear = pbMonths
        .GroupBy(m => int.Parse(m[..4]))
        .OrderBy(g => g.Key)
        .ToDictionary(g => g.Key, g => g.OrderBy(m => m).ToList());

    int PbCell(Dictionary<string, int>? d, string mk)
        => d is not null && d.TryGetValue(mk, out var v) ? v : 0;
    int PbYear(Dictionary<int, int>? d, int y)
        => d is not null && d.TryGetValue(y, out var v) ? v : 0;
    int PbGrandYear(int year) =>
        Model.PayerBreakdownGrandByMonth.Where(kv => kv.Key.StartsWith($"{year:D4}")).Sum(kv => kv.Value);
    int pbGrandTotal = Model.PayerBreakdownGrandByMonth
        .Where(kv => int.Parse(kv.Key[..4]) > 1900).Sum(kv => kv.Value);

    // Payer X Panel helpers
    var pxpPanels = Model.PayerPanelColumns;
    int PxpClaims(Dictionary<string, LabMetricsDashboard.Models.ProductionMonthCell>? d, string pk)
        => d is not null && d.TryGetValue(pk, out var c) ? c.ClaimCount : 0;
    decimal PxpCharges(Dictionary<string, LabMetricsDashboard.Models.ProductionMonthCell>? d, string pk)
        => d is not null && d.TryGetValue(pk, out var c) ? c.BilledCharges : 0m;

    // Unbilled X Aging helpers
    var agingBuckets = LabMetricsDashboard.Models.AgingBuckets.All;
    int UaClaims(Dictionary<string, LabMetricsDashboard.Models.ProductionMonthCell>? d, string bk)
        => d is not null && d.TryGetValue(bk, out var c) ? c.ClaimCount : 0;
    decimal UaCharges(Dictionary<string, LabMetricsDashboard.Models.ProductionMonthCell>? d, string bk)
        => d is not null && d.TryGetValue(bk, out var c) ? c.BilledCharges : 0m;

    // CPT Breakdown helpers
    var cptYears  = Model.CptBreakdownYears.Where(y => y > 1900).ToList();
    var cptMonths = Model.CptBreakdownMonths.Where(m => int.Parse(m[..4]) > 1900).ToList();
    var cptMonthsByYear = cptMonths
        .GroupBy(m => int.Parse(m[..4]))
        .OrderBy(g => g.Key)
        .ToDictionary(g => g.Key, g => g.OrderBy(m => m).ToList());

    decimal CptUnits(Dictionary<string, LabMetricsDashboard.Models.CptBreakdownCell>? d, string mk)
        => d is not null && d.TryGetValue(mk, out var c) ? c.Units : 0m;
    decimal CptCharges(Dictionary<string, LabMetricsDashboard.Models.CptBreakdownCell>? d, string mk)
        => d is not null && d.TryGetValue(mk, out var c) ? c.BilledCharges : 0m;
    decimal CptYearUnits(Dictionary<int, LabMetricsDashboard.Models.CptBreakdownCell>? d, int y)
        => d is not null && d.TryGetValue(y, out var t) ? t.Units : 0m;
    decimal CptYearCharges(Dictionary<int, LabMetricsDashboard.Models.CptBreakdownCell>? d, int y)
        => d is not null && d.TryGetValue(y, out var t) ? t.BilledCharges : 0m;
    decimal CptGrandYearUnits(int year) =>
        Model.CptBreakdownGrandByMonth.Where(kv => kv.Key.StartsWith($"{year:D4}")).Sum(kv => kv.Value.Units);
    decimal CptGrandYearCharges(int year) =>
        Model.CptBreakdownGrandByMonth.Where(kv => kv.Key.StartsWith($"{year:D4}")).Sum(kv => kv.Value.BilledCharges);
    decimal cptGrandUnits = Model.CptBreakdownGrandByMonth
        .Where(kv => int.Parse(kv.Key[..4]) > 1900).Sum(kv => kv.Value.Units);
    decimal cptGrandCharges = Model.CptBreakdownGrandByMonth
        .Where(kv => int.Parse(kv.Key[..4]) > 1900).Sum(kv => kv.Value.BilledCharges);
}

<style>
/* ?? Production Report styles ??????????????????????????????? */
.pr-wrap {
    border-radius: 14px; overflow: hidden;
    background: #fff; border: 1px solid #e0e6ed;
    box-shadow: 0 2px 12px rgba(0,0,0,.05);
}
.pr-scroll { max-height: 78vh; overflow: auto; }

.pr-table {
    border-collapse: separate; border-spacing: 0;
    font-size: .72rem;
    table-layout: fixed;
}

.pr-table thead th {
    background: linear-gradient(135deg, #0a1628 0%, #0e3460 50%, #0d5c74 100%);
    color: rgba(255,255,255,.92); font-weight: 700; font-size: .62rem;
    letter-spacing: .04em; text-transform: uppercase;
    padding: .5rem .4rem; text-align: center;
    white-space: normal; word-wrap: break-word;
    position: sticky; top: 0; z-index: 5;
    border-bottom: 1px solid #0a2a4a;
    border-right: 1px solid rgba(255,255,255,.08);
    line-height: 1.25;
}

/* Visible header rows are 1, 2, 3 (no hidden sizing row) */
.pr-table thead tr:nth-child(2) th {
    top: 30px; z-index: 4;
    background: linear-gradient(135deg, #162d50 0%, #1b4a6c 100%);
    font-size: .58rem;
}
.pr-table thead tr:nth-child(3) th {
    top: 56px; z-index: 3;
    background: #1e5a8a;
    font-size: .56rem; font-weight: 600;
}

.pr-table thead th:first-child {
    text-align: left; position: sticky; left: 0; z-index: 7;
}
.pr-table thead tr:nth-child(2) th:first-child { z-index: 6; }
.pr-table thead tr:nth-child(3) th:first-child { z-index: 5; }

.pr-table td {
    padding: .35rem .5rem; vertical-align: middle;
    text-align: right; white-space: nowrap;
    border-right: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
    overflow: hidden; text-overflow: ellipsis;
}

/* Month data columns — narrowed to ~70% */
th.pr-month-data, td.pr-month-data {
    padding-left: .2rem; padding-right: .2rem;
    font-size: .60rem;
}
.pr-table td:first-child {
    text-align: left; font-weight: 600; color: #1e293b;
    max-width: 260px; overflow: hidden; text-overflow: ellipsis;
    position: sticky; left: 0; z-index: 1;
    background: #fff; min-width: 200px;
}

.pr-panel-row td { background: #f0fdf4; font-weight: 700; }
.pr-panel-row td:first-child { background: #f0fdf4; color: #166534; }

.pr-payer-row td { background: #fff; color: #475569; font-weight: 400; }
.pr-payer-row td:first-child {
    padding-left: 1.5rem; font-weight: 500; color: #64748b; background: #fff;
}
.pr-payer-row:hover td { background: #f8fafc; }
.pr-payer-row:hover td:first-child { background: #f8fafc; }

.pr-total-row td {
    background: #0e3460 !important; color: #fff !important;
    font-weight: 800; border-top: 2px solid #0a2a4a;
}
.pr-total-row td:first-child { background: #0e3460 !important; color: #fff !important; }

.pr-year-total { background-color: #fefce8 !important; }
.pr-table thead th.pr-year-total {
    background: linear-gradient(135deg, #854d0e 0%, #a16207 100%) !important;
}
.pr-table thead tr:nth-child(3) th.pr-year-total {
    background: #a16207 !important;
}

.pr-grand-total { background-color: #fef3c7 !important; font-weight: 800; }
.pr-table thead th.pr-grand-total {
    background: linear-gradient(135deg, #78350f 0%, #92400e 100%) !important;
}
.pr-table thead tr:nth-child(3) th.pr-grand-total {
    background: #92400e !important;
}

/* Filter panel — matches Clinic Summary style */
.pr-filter-panel {
    background: #fff; border-radius: 12px;
    box-shadow: 0 2px 10px rgba(0,0,0,.07);
}
.pr-filter-badge { font-size: .7rem; vertical-align: middle; }

/* Multi-select dropdown */
.pr-ms { position: relative; }
.pr-ms-btn {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: .3rem .6rem; font-size: .8rem;
    border: 1px solid #ced4da; border-radius: .375rem;
    background: #fff; cursor: pointer; min-height: 31px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.pr-ms-btn:hover { border-color: #7B8B8E; }
.pr-ms-btn .pr-ms-count {
    background: #2B2D42; color: #fff; font-size: .65rem;
    border-radius: 10px; padding: 0 .45rem; margin-left: .4rem;
    font-weight: 700; flex-shrink: 0;
}
.pr-ms-panel {
    display: none; position: absolute; z-index: 100; top: 100%;
    left: 0; right: 0; background: #fff; border: 1px solid #ced4da;
    border-radius: .375rem; box-shadow: 0 4px 16px rgba(0,0,0,.12);
    margin-top: 2px; max-height: 280px; overflow: hidden;
}
.pr-ms-panel.open { display: flex; flex-direction: column; }
.pr-ms-search {
    border: none; border-bottom: 1px solid #e9ecef;
    padding: .4rem .6rem; font-size: .78rem; outline: none; width: 100%;
}
.pr-ms-list {
    overflow-y: auto; max-height: 220px; padding: .25rem 0;
}
.pr-ms-list label {
    display: flex; align-items: center; gap: .4rem;
    padding: .25rem .6rem; font-size: .78rem; cursor: pointer;
    margin: 0;
}
.pr-ms-list label:hover { background: #edf0f0; }
.pr-ms-list label.pr-ms-hidden { display: none; }

/* ?? Premium pill tabs ?????????????????????????????????????? */
.pr-tabs {
    display: flex; flex-wrap: wrap; gap: .45rem;
    padding: .55rem .65rem;
    background: linear-gradient(135deg, #f8fafd 0%, #eef3fa 100%);
    border: 1px solid #dce4f0;
    border-radius: 1rem;
    box-shadow: 0 2px 10px rgba(15,23,42,.04);
}
.pr-tabs .nav-item { margin: 0; }
.pr-tabs .nav-link {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .45rem .85rem;
    font-size: .76rem; font-weight: 700; letter-spacing: .015em;
    color: #3b5578;
    background: #fff;
    border: 1.5px solid #d4dde9;
    border-radius: .75rem;
    transition: all .18s ease;
    box-shadow: 0 1px 3px rgba(15,23,42,.04);
    white-space: nowrap;
}
.pr-tabs .nav-link i {
    font-size: .82rem; opacity: .7;
    transition: opacity .18s;
}
.pr-tabs .nav-link:hover {
    color: #0e3460; background: #edf2fb;
    border-color: #b4c6e0;
    box-shadow: 0 2px 8px rgba(15,23,42,.08);
}
.pr-tabs .nav-link:hover i { opacity: 1; }
.pr-tabs .nav-link.active {
    color: #fff;
    background: linear-gradient(135deg, #0a1628 0%, #0e3460 50%, #0d5c74 100%);
    border-color: #0e3460;
    box-shadow: 0 4px 14px rgba(14,52,96,.30);
}
.pr-tabs .nav-link.active i { opacity: 1; }
</style>

<!-- Page heading -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0 fw-bold">Production Report <span class="badge bg-primary bg-gradient fw-semibold" style="font-size:.45em;vertical-align:middle;border-radius:20px;padding:.35em .85em">@Model.SelectedLab</span></h2>
    <a asp-controller="Dashboard" asp-action="ClaimLevel" asp-route-lab="@Model.SelectedLab"
       class="btn btn-sm btn-outline-primary">
        <i class="bi bi-clipboard-data me-1"></i>Claim Level Details
    </a>
</div>



<!-- ??? Collapsible Filter panel ?????????????????????????????? -->
@if (!string.IsNullOrWhiteSpace(Model.SelectedLab))
{
    <div class="pr-filter-panel p-3 mb-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="fw-semibold" style="font-size:.9rem">
                <i class="bi bi-funnel"></i> Filters
                @if (Model.HasFilters)
                {
                    <span class="badge bg-primary pr-filter-badge ms-1">Active</span>
                }
            </span>
            <button class="btn btn-sm btn-link text-muted p-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#prFilterBody"
                    aria-expanded="@(Model.HasFilters ? "true" : "false")">
                @Html.Raw(Model.HasFilters ? "&#9650; Hide" : "&#9660; Show")
            </button>
        </div>

        <div id="prFilterBody" class="collapse @(Model.HasFilters ? "show" : "")">
            <form id="prFilterForm" method="get" asp-controller="Dashboard" asp-action="ProductionReport" data-lab-form>
                <input type="hidden" name="lab" value="@Model.SelectedLab" />

                <div class="row g-2 align-items-end mb-2">
                    <!-- Payer Name (multi-select) -->
                    <div class="col-sm-6 col-md-3">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PAYER NAME</label>
                        <div class="pr-ms" data-ms-name="filterPayerNames">
                            <div class="pr-ms-btn" tabindex="0">
                                <span class="pr-ms-label">All</span>
                                <span class="pr-ms-count" style="display:none">0</span>
                            </div>
                            <div class="pr-ms-panel">
                                <input type="text" class="pr-ms-search" placeholder="Search payers…" autocomplete="off" />
                                <div class="pr-ms-list">
                                    @foreach (var pn in Model.PayerNames)
                                    {
                                        <label><input type="checkbox" name="filterPayerNames" value="@pn"
                                            @(Model.FilterPayerNames.Contains(pn) ? "checked" : "") /> @pn</label>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Panel Name (multi-select) -->
                    <div class="col-sm-6 col-md-3">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PANEL NAME</label>
                        <div class="pr-ms" data-ms-name="filterPanelNames">
                            <div class="pr-ms-btn" tabindex="0">
                                <span class="pr-ms-label">All</span>
                                <span class="pr-ms-count" style="display:none">0</span>
                            </div>
                            <div class="pr-ms-panel">
                                <input type="text" class="pr-ms-search" placeholder="Search panels…" autocomplete="off" />
                                <div class="pr-ms-list">
                                    @foreach (var pl in Model.PanelNames)
                                    {
                                        <label><input type="checkbox" name="filterPanelNames" value="@pl"
                                            @(Model.FilterPanelNames.Contains(pl) ? "checked" : "") /> @pl</label>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    @{
                        // The date-range filter is applied against ChargeEnteredDate when the
                        // active rule uses ChargeEnteredDate columns (Rule1–Rule4), and against
                        // FirstBilledDate otherwise (Default / Rule5). Keep the label aligned with
                        // the actual filtered column so users aren't misled.
                        var rule = Model.ProductionSummaryRule;
                        var dateFilterUsesChargeEntered =
                            string.Equals(rule, "Rule1", StringComparison.OrdinalIgnoreCase) ||
                            string.Equals(rule, "Rule2", StringComparison.OrdinalIgnoreCase) ||
                            string.Equals(rule, "Rule3", StringComparison.OrdinalIgnoreCase) ||
                            string.Equals(rule, "Rule4", StringComparison.OrdinalIgnoreCase);
                        var dateFilterFromLabel = dateFilterUsesChargeEntered ? "CHARGE ENTERED DATE FROM" : "FIRST BILL DATE FROM";
                        var dateFilterToLabel   = dateFilterUsesChargeEntered ? "CHARGE ENTERED DATE TO"   : "FIRST BILL DATE TO";
                    }

                    <!-- Date filter From (label switches based on the active rule) -->
                    <div class="col-sm-6 col-md-3">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">@dateFilterFromLabel</label>
                        <input type="date" name="filterFirstBillFrom" class="form-control form-control-sm"
                               value="@Model.FilterFirstBillFrom" />
                    </div>
                    <!-- Date filter To (label switches based on the active rule) -->
                    <div class="col-sm-6 col-md-3">
                        <label class="form-label fw-semibold mb-1" style="font-size:.75rem">@dateFilterToLabel</label>
                        <input type="date" name="filterFirstBillTo" class="form-control form-control-sm"
                               value="@Model.FilterFirstBillTo" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="bi bi-funnel-fill me-1"></i>Apply
                    </button>
                    <a asp-controller="Dashboard" asp-action="ProductionReport"
                       asp-route-lab="@Model.SelectedLab"
                       class="btn btn-sm btn-outline-secondary">Clear</a>
                    <button type="button" id="exportExcelBtn" class="btn btn-sm btn-outline-success ms-auto">
                        <i class="bi bi-file-earmark-excel me-1"></i>Download Excel
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<!-- Production Report Excel export loading overlay -->
<div id="prExportOverlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(15,23,42,.55);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:16px;box-shadow:0 8px 40px rgba(0,0,0,.18);padding:2rem 2.5rem;width:380px;text-align:center">
        <div style="font-size:2.4rem;color:#0d8553;margin-bottom:.6rem;animation:prPulse 1.4s ease-in-out infinite">
            <i class="bi bi-file-earmark-excel"></i>
        </div>
        <div style="font-size:1.05rem;font-weight:700;color:#1e293b;margin-bottom:.25rem">Generating Excel Report</div>
        <div id="prExportStatus" style="font-size:.78rem;color:#64748b;margin-bottom:1rem">Starting export…</div>
        <div style="width:100%;height:10px;background:#e2e8f0;border-radius:6px;overflow:hidden">
            <div id="prExportBar" style="height:100%;border-radius:6px;background:linear-gradient(90deg,#047857,#0d8553,#10b981);transition:width .4s ease;width:0%"></div>
        </div>
        <div id="prExportPct" style="font-size:.82rem;font-weight:700;color:#0d8553;margin-top:.5rem">0%</div>
        <button type="button" id="prExportCancelBtn" class="btn btn-sm btn-outline-secondary mt-3">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </button>
    </div>
</div>
<style>@@keyframes prPulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(.92)} }</style>

