<script>
    // Multi-select dropdown widget (matches Clinic Summary pattern)
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.pr-ms').forEach(function (ms) {
            var btn = ms.querySelector('.pr-ms-btn');
            var panel = ms.querySelector('.pr-ms-panel');
            var search = ms.querySelector('.pr-ms-search');
            var labels = ms.querySelectorAll('.pr-ms-list label');
            var labelEl = ms.querySelector('.pr-ms-label');
            var countEl = ms.querySelector('.pr-ms-count');

            function updateLabel() {
                var checked = ms.querySelectorAll('.pr-ms-list input:checked');
                if (checked.length === 0) {
                    labelEl.textContent = 'All';
                    countEl.style.display = 'none';
                } else if (checked.length === 1) {
                    labelEl.textContent = checked[0].value;
                    countEl.style.display = 'none';
                } else {
                    labelEl.textContent = checked[0].value;
                    countEl.textContent = '+' + (checked.length - 1);
                    countEl.style.display = '';
                }
            }

            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                document.querySelectorAll('.pr-ms-panel.open').forEach(function (p) {
                    if (p !== panel) p.classList.remove('open');
                });
                panel.classList.toggle('open');
                if (panel.classList.contains('open') && search) {
                    search.value = '';
                    search.focus();
                    labels.forEach(function (l) { l.classList.remove('pr-ms-hidden'); });
                }
            });

            if (search) {
                search.addEventListener('input', function () {
                    var q = this.value.toLowerCase();
                    labels.forEach(function (l) {
                        var text = l.textContent.toLowerCase();
                        l.classList.toggle('pr-ms-hidden', q.length > 0 && text.indexOf(q) === -1);
                    });
                });
            }

            ms.querySelectorAll('.pr-ms-list input').forEach(function (cb) {
                cb.addEventListener('change', updateLabel);
            });

            panel.addEventListener('click', function (e) { e.stopPropagation(); });

            updateLabel();
        });

        document.addEventListener('click', function () {
            document.querySelectorAll('.pr-ms-panel.open').forEach(function (p) {
                p.classList.remove('open');
            });
        });

        // Export Excel with progress overlay
        var exportBtn = document.getElementById('exportExcelBtn');
        if (exportBtn) {
            var overlay = document.getElementById('prExportOverlay');
            var bar = document.getElementById('prExportBar');
            var pctLabel = document.getElementById('prExportPct');
            var statusLabel = document.getElementById('prExportStatus');
            var cancelBtn = document.getElementById('prExportCancelBtn');

            var steps = [
                { pct: 8,  text: 'Connecting to database\u2026' },
                { pct: 18, text: 'Fetching Monthly Claim Volume\u2026' },
                { pct: 26, text: 'Fetching Weekly Claim Volume\u2026' },
                { pct: 34, text: 'Fetching Coding data\u2026' },
                { pct: 42, text: 'Fetching Payer Breakdown\u2026' },
                { pct: 50, text: 'Fetching Payer x Panel\u2026' },
                { pct: 56, text: 'Fetching Unbilled Aging\u2026' },
                { pct: 62, text: 'Fetching CPT Breakdown\u2026' },
                { pct: 70, text: 'Fetching ClaimLevelData rows\u2026' },
                { pct: 78, text: 'Fetching LineLevelData rows\u2026' },
                { pct: 86, text: 'Building Excel workbook\u2026' },
                { pct: 94, text: 'Finalizing sheets & formatting\u2026' }
            ];

            function prGetCookie(name) {
                var m = document.cookie.match('(^|;)\\s*' + name + '=([^;]*)');
                return m ? m[2] : null;
            }
            function prDeleteCookie(name) {
                document.cookie = name + '=; path=/; max-age=0';
            }
            function prCleanup(p, c, s, iframe) {
                clearInterval(p); clearInterval(c); clearInterval(s);
                if (iframe && iframe.parentNode) document.body.removeChild(iframe);
            }

            exportBtn.addEventListener('click', function () {
                var form = document.getElementById('prFilterForm');
                if (!form) return;

                prDeleteCookie('prExportDone');
                overlay.style.display = 'flex';
                bar.style.width = '0%';
                pctLabel.textContent = '0%';
                statusLabel.textContent = 'Starting export\u2026';

                var startTime = Date.now();
                function elapsed() {
                    var secs = Math.floor((Date.now() - startTime) / 1000);
                    var m = Math.floor(secs / 60), s = secs % 60;
                    return m > 0 ? m + 'm ' + s + 's' : s + 's';
                }

                var stepIdx = 0, currentPct = 0;
                var stepTimer = setInterval(function () {
                    if (stepIdx < steps.length) {
                        currentPct = steps[stepIdx].pct;
                        bar.style.width = currentPct + '%';
                        pctLabel.textContent = currentPct + '%';
                        statusLabel.textContent = steps[stepIdx].text;
                        stepIdx++;
                    } else { clearInterval(stepTimer); }
                }, 1800);

                var creepTimer = setInterval(function () {
                    if (stepIdx >= steps.length) {
                        if (currentPct < 99) currentPct += 0.15;
                        var p = Math.min(Math.round(currentPct), 99);
                        bar.style.width = p + '%';
                        pctLabel.textContent = p + '%';
                        var msgs = [
                            'Writing ClaimLevelData sheet\u2026',
                            'Writing LineLevelData sheet\u2026',
                            'Formatting report sheets\u2026',
                            'Almost there, please wait\u2026',
                            'Large dataset \u2014 still processing\u2026',
                            'Compressing workbook\u2026',
                            'Hang tight, almost done\u2026'
                        ];
                        var msgIdx = Math.floor((Date.now() - startTime) / 4000) % msgs.length;
                        statusLabel.textContent = msgs[msgIdx] + '  (' + elapsed() + ')';
                    }
                }, 1000);

                var params = new URLSearchParams(new FormData(form));
                var url = '@Url.Action("ExportProductionReportExcel", "Dashboard")' + '?' + params.toString();
                var iframe = document.createElement('iframe');
                iframe.style.display = 'none';
                iframe.src = url;
                document.body.appendChild(iframe);

                var pollTimer = setInterval(function () {
                    if (prGetCookie('prExportDone')) {
                        prCleanup(pollTimer, creepTimer, stepTimer, iframe);
                        prDeleteCookie('prExportDone');
                        bar.style.width = '100%';
                        pctLabel.textContent = '100%';
                        statusLabel.textContent = 'Download complete!  (' + elapsed() + ')';
                        setTimeout(function () { overlay.style.display = 'none'; }, 900);
                    }
                }, 500);

                var onCancel = function () {
                    prCleanup(pollTimer, creepTimer, stepTimer, iframe);
                    prDeleteCookie('prExportDone');
                    overlay.style.display = 'none';
                    cancelBtn.removeEventListener('click', onCancel);
                };
                cancelBtn.addEventListener('click', onCancel);

                setTimeout(function () {
                    prCleanup(pollTimer, creepTimer, stepTimer, iframe);
                    overlay.style.display = 'none';
                }, 600000);
            });
        }
    });
</script>
