    </div>
}
else if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning mt-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i> @Model.ErrorMessage
    </div>
}
else
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:2rem;opacity:.4">&#128202;</div>
        <div class="fw-semibold mt-2">No clinic data available</div>
        <div class="small mt-1">Select a lab with DB enabled to view the clinic summary.</div>
    </div>
}

<script>
    // Multi-select dropdown widget
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.cs-ms').forEach(function (ms) {
            var btn = ms.querySelector('.cs-ms-btn');
            var panel = ms.querySelector('.cs-ms-panel');
            var search = ms.querySelector('.cs-ms-search');
            var labels = ms.querySelectorAll('.cs-ms-list label');
            var labelEl = ms.querySelector('.cs-ms-label');
            var countEl = ms.querySelector('.cs-ms-count');

            function updateLabel() {
                var checked = ms.querySelectorAll('.cs-ms-list input:checked');
                if (checked.length === 0) {
                    labelEl.textContent = 'All';
                    countEl.style.display = 'none';
                } else if (checked.length === 1) {
                    labelEl.textContent = checked[0].value;
                    countEl.style.display = 'none';
                } else {
                    labelEl.textContent = checked[0].value;
                    countEl.textContent = '+' + (checked.length - 1);
                    countEl.style.display = '';
                }
            }

            // Toggle panel
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                // Close other open panels
                document.querySelectorAll('.cs-ms-panel.open').forEach(function (p) {
                    if (p !== panel) p.classList.remove('open');
                });
                panel.classList.toggle('open');
                if (panel.classList.contains('open')) {
                    search.value = '';
                    search.focus();
                    labels.forEach(function (l) { l.classList.remove('cs-ms-hidden'); });
                }
            });

            // Search/filter
            search.addEventListener('input', function () {
                var q = this.value.toLowerCase();
                labels.forEach(function (l) {
                    var text = l.textContent.toLowerCase();
                    l.classList.toggle('cs-ms-hidden', q.length > 0 && text.indexOf(q) === -1);
                });
            });

            // Checkbox change
            ms.querySelectorAll('.cs-ms-list input').forEach(function (cb) {
                cb.addEventListener('change', updateLabel);
            });

            // Prevent panel close on click inside
            panel.addEventListener('click', function (e) { e.stopPropagation(); });

            // Init label
            updateLabel();
        });

        // Close all panels on outside click
        document.addEventListener('click', function () {
            document.querySelectorAll('.cs-ms-panel.open').forEach(function (p) {
                p.classList.remove('open');
            });
        });

        // Export Excel — reuse filter form values to build a download URL
        var exportBtn = document.getElementById('exportExcelBtn');
        if (exportBtn) {
            exportBtn.addEventListener('click', function () {
                var form = document.getElementById('csFilterForm');
                if (!form) return;
                var params = new URLSearchParams(new FormData(form));
                var url = '@Url.Action("ExportClinicSummaryExcel", "Dashboard")' + '?' + params.toString();
                window.location.href = url;
            });
        }
    });
</script>
