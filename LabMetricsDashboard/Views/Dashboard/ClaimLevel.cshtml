@model ClaimLevelViewModel
@{
    ViewData["Title"]       = $"Claim Level – {Model.SelectedLab}";
    ViewData["SelectedLab"] = Model.SelectedLab;
    ViewData["PageLabel"]   = "Claim Level Details";

    var routeValues = new Dictionary<string, string?>
    {
        ["lab"]             = Model.SelectedLab,
        ["filterPayerName"] = Model.FilterPayerName,
        ["filterDenialCode"]= Model.FilterDenialCode,
        ["filterDenialCodeExcludeBlank"] = Model.FilterDenialCodeExcludeBlank ? "true" : null,
        ["filterPayerExcludeBlank"] = Model.FilterPayerExcludeBlank ? "true" : null,
        ["filterPanelExcludeBlank"] = Model.FilterPanelExcludeBlank ? "true" : null,
        ["filterFirstBillFrom"]     = Model.FilterFirstBillFrom,
        ["filterFirstBillTo"]       = Model.FilterFirstBillTo,
        ["filterFirstBillNull"]     = Model.FilterFirstBillNull ? "true" : null,
        ["filterFirstBillExcludeBlank"] = Model.FilterFirstBillExcludeBlank ? "true" : null,
        ["filterChargeEnteredFrom"] = Model.FilterChargeEnteredFrom,
        ["filterChargeEnteredTo"]   = Model.FilterChargeEnteredTo,
        ["filterChargeEnteredNull"] = Model.FilterChargeEnteredNull ? "true" : null,
        ["filterChargeEnteredExcludeBlank"] = Model.FilterChargeEnteredExcludeBlank ? "true" : null,
        ["filterDosFrom"]           = Model.FilterDosFrom,
        ["filterDosTo"]             = Model.FilterDosTo,
        ["filterDosNull"]           = Model.FilterDosNull ? "true" : null,
    };
    var routeListValues = new Dictionary<string, List<string>>
    {
        ["filterPayerTypes"]    = Model.FilterPayerTypes,
        ["filterClaimStatuses"] = Model.FilterClaimStatuses,
        ["filterClinicNames"]   = Model.FilterClinicNames,
        ["filterPayerNames"]    = Model.FilterPayerNames,
        ["filterPanelNames"]    = Model.FilterPanelNames,
        ["filterAgingBuckets"]  = Model.FilterAgingBuckets,
    };
}

<style>
    .cl-filter-panel { background:#fff; border-radius:12px; box-shadow:0 2px 10px rgba(0,0,0,.07); }
    .cl-filter-badge { font-size:.7rem; vertical-align:middle; }
    .cl-data-card    { border:none; border-radius:12px; box-shadow:0 2px 14px rgba(0,0,0,.08); overflow:hidden; }
    .cl-data-card .card-header { background:linear-gradient(135deg,#0d1b2a,#1565c0); border-radius:12px 12px 0 0; }
    .cl-table th, .cl-table td { font-size:.78rem; padding:.38rem .55rem; white-space:nowrap; vertical-align:middle; }
    .cl-table thead th { background:#253858; color:#fff; font-weight:600; position:sticky; top:0; z-index:2; }
    .cl-table tbody tr:nth-child(odd)  { background:#fafbfc; }
    .cl-table tbody tr:nth-child(even) { background:#fff; }
    .cl-table tbody tr:hover { background:#eef4ff; }
    .cl-table td.amt { text-align:right; font-variant-numeric:tabular-nums; }

    /* Multi-select dropdown (same pattern as SalesRep / Clinic Summary) */
    .cs-ms { position:relative; }
    .cs-ms-btn {
        display:flex; align-items:center; justify-content:space-between;
        width:100%; padding:.3rem .6rem; font-size:.8rem;
        border:1px solid #ced4da; border-radius:.375rem;
        background:#fff; cursor:pointer; min-height:31px;
        white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .cs-ms-btn:hover { border-color:#7B8B8E; }
    .cs-ms-btn .cs-ms-count {
        background:#1565c0; color:#fff; font-size:.65rem;
        border-radius:10px; padding:0 .45rem; margin-left:.4rem;
        font-weight:700; flex-shrink:0;
    }
    .cs-ms-panel {
        display:none; position:absolute; z-index:100; top:100%;
        left:0; right:0; background:#fff; border:1px solid #ced4da;
        border-radius:.375rem; box-shadow:0 4px 16px rgba(0,0,0,.12);
        margin-top:2px; max-height:280px; overflow:hidden;
    }
    .cs-ms-panel.open { display:flex; flex-direction:column; }
    .cs-ms-search {
        border:none; border-bottom:1px solid #e9ecef;
        padding:.4rem .6rem; font-size:.78rem; outline:none; width:100%;
    }
    .cs-ms-list { overflow-y:auto; max-height:220px; padding:.25rem 0; }
    .cs-ms-list label {
        display:flex; align-items:center; gap:.4rem;
        padding:.25rem .6rem; font-size:.78rem; cursor:pointer; margin:0;
    }
    .cs-ms-list label:hover { background:#edf0f0; }
    .cs-ms-list label.cs-ms-hidden { display:none; }
</style>

<!-- Header -->
<h2 class="mb-3 fw-bold">&#128203; Claim Level Details <span class="badge bg-primary bg-gradient fw-semibold" style="font-size:.45em;vertical-align:middle;border-radius:20px;padding:.35em .85em">@Model.SelectedLab</span></h2>

<!-- Collapsible filter panel -->
<div class="cl-filter-panel p-3 mb-4">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <span class="fw-semibold" style="font-size:.9rem">
            <i class="bi bi-funnel"></i> Filters
            @if (Model.HasFilters)
            {
                <span class="badge bg-primary cl-filter-badge ms-1">Active</span>
            }
        </span>
        <button class="btn btn-sm btn-link text-muted p-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#claimFilterBody"
                aria-expanded="@(Model.HasFilters ? "true" : "false")">
            @Html.Raw(Model.HasFilters ? "&#9650; Hide" : "&#9660; Show")
        </button>
    </div>
    <div id="claimFilterBody" class="collapse @(Model.HasFilters ? "show" : "")">
        <form id="claimFilterForm" method="get" asp-controller="Dashboard" asp-action="ClaimLevel" data-lab-form>
            <input type="hidden" name="lab" value="@Model.SelectedLab" />
            <div class="row g-2 align-items-start mb-2">
                <!-- Payer Name (multi-select) -->
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PAYER NAME</label>
                    <div class="cs-ms" data-ms-name="filterPayerNames">
                        <div class="cs-ms-btn" tabindex="0">
                            <span class="cs-ms-label">All</span>
                            <span class="cs-ms-count" style="display:none">0</span>
                        </div>
                        <div class="cs-ms-panel">
                            <input type="text" class="cs-ms-search" placeholder="Search payer names…" autocomplete="off" />
                            <div class="cs-ms-list">
                                @foreach (var pn in Model.PayerNames)
                                {
                                    <label><input type="checkbox" name="filterPayerNames" value="@pn"
                                        @(Model.FilterPayerNames.Contains(pn) ? "checked" : "") /> @pn</label>
                                }
                            </div>
                        </div>
                    </div>
                    <label class="form-check-label mt-1" style="font-size:.7rem">
                        <input type="checkbox" name="filterPayerExcludeBlank" value="true" class="form-check-input"
                               @(Model.FilterPayerExcludeBlank ? "checked" : "") style="width:.85em;height:.85em" /> Exclude Blank
                    </label>
                </div>
                <!-- Panel Name (multi-select) -->
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PANEL NAME</label>
                    <div class="cs-ms" data-ms-name="filterPanelNames">
                        <div class="cs-ms-btn" tabindex="0">
                            <span class="cs-ms-label">All</span>
                            <span class="cs-ms-count" style="display:none">0</span>
                        </div>
                        <div class="cs-ms-panel">
                            <input type="text" class="cs-ms-search" placeholder="Search panels…" autocomplete="off" />
                            <div class="cs-ms-list">
                                @foreach (var pl in Model.PanelNames)
                                {
                                    <label><input type="checkbox" name="filterPanelNames" value="@pl"
                                        @(Model.FilterPanelNames.Contains(pl) ? "checked" : "") /> @pl</label>
                                }
                            </div>
                        </div>
                    </div>
                    <label class="form-check-label mt-1" style="font-size:.7rem">
                        <input type="checkbox" name="filterPanelExcludeBlank" value="true" class="form-check-input"
                               @(Model.FilterPanelExcludeBlank ? "checked" : "") style="width:.85em;height:.85em" /> Exclude Blank
                    </label>
                </div>
                <!-- Payer Type -->
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PAYER TYPE</label>
                    <div class="cs-ms" data-ms-name="filterPayerTypes">
                        <div class="cs-ms-btn" tabindex="0">
                            <span class="cs-ms-label">All</span>
                            <span class="cs-ms-count" style="display:none">0</span>
                        </div>
                        <div class="cs-ms-panel">
                            <input type="text" class="cs-ms-search" placeholder="Search payer types…" autocomplete="off" />
                            <div class="cs-ms-list">
                                @foreach (var pt in Model.PayerTypes)
                                {
                                    <label><input type="checkbox" name="filterPayerTypes" value="@pt"
                                        @(Model.FilterPayerTypes.Contains(pt) ? "checked" : "") /> @pt</label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Claim Status -->
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">CLAIM STATUS</label>
                    <div class="cs-ms" data-ms-name="filterClaimStatuses">
                        <div class="cs-ms-btn" tabindex="0">
                            <span class="cs-ms-label">All</span>
                            <span class="cs-ms-count" style="display:none">0</span>
                        </div>
                        <div class="cs-ms-panel">
                            <input type="text" class="cs-ms-search" placeholder="Search statuses…" autocomplete="off" />
                            <div class="cs-ms-list">
                                @foreach (var cs in Model.ClaimStatuses)
                                {
                                    <label><input type="checkbox" name="filterClaimStatuses" value="@cs"
                                        @(Model.FilterClaimStatuses.Contains(cs) ? "checked" : "") /> @cs</label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Clinic -->
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">CLINIC</label>
                    <div class="cs-ms" data-ms-name="filterClinicNames">
                        <div class="cs-ms-btn" tabindex="0">
                            <span class="cs-ms-label">All</span>
                            <span class="cs-ms-count" style="display:none">0</span>
                        </div>
                        <div class="cs-ms-panel">
                            <input type="text" class="cs-ms-search" placeholder="Search clinics…" autocomplete="off" />
                            <div class="cs-ms-list">
                                @foreach (var cn in Model.ClinicNames)
                                {
                                    <label><input type="checkbox" name="filterClinicNames" value="@cn"
                                        @(Model.FilterClinicNames.Contains(cn) ? "checked" : "") /> @cn</label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Aging Bucket -->
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">AGING BUCKET</label>
                    <div class="cs-ms" data-ms-name="filterAgingBuckets">
                        <div class="cs-ms-btn" tabindex="0">
                            <span class="cs-ms-label">All</span>
                            <span class="cs-ms-count" style="display:none">0</span>
                        </div>
                        <div class="cs-ms-panel">
                            <input type="text" class="cs-ms-search" placeholder="Search buckets…" autocomplete="off" />
                            <div class="cs-ms-list">
                                @foreach (var ab in Model.AgingBuckets)
                                {
                                    <label><input type="checkbox" name="filterAgingBuckets" value="@ab"
                                        @(Model.FilterAgingBuckets.Contains(ab) ? "checked" : "") /> @ab</label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row g-2 align-items-end mb-2">
                <!-- Denial Code (text search) -->
                <div class="col-sm-6 col-md-3">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">DENIAL CODE</label>
                    <input type="text" name="filterDenialCode" value="@Model.FilterDenialCode"
                           class="form-control form-control-sm" placeholder="Search…" />
                    <label class="form-check-label mt-1" style="font-size:.7rem">
                        <input type="checkbox" name="filterDenialCodeExcludeBlank" value="true" class="form-check-input"
                               @(Model.FilterDenialCodeExcludeBlank ? "checked" : "") style="width:.85em;height:.85em" /> Exclude Blank
                    </label>
                </div>
                <!-- First Billed Date range -->
                <div class="col-sm-6 col-md-3">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">FIRST BILLED DATE</label>
                    <div class="d-flex gap-1 align-items-center">
                        <input type="date" name="filterFirstBillFrom" value="@Model.FilterFirstBillFrom"
                               class="form-control form-control-sm" style="font-size:.75rem" />
                        <span style="font-size:.7rem">to</span>
                        <input type="date" name="filterFirstBillTo" value="@Model.FilterFirstBillTo"
                               class="form-control form-control-sm" style="font-size:.75rem" />
                    </div>
                    <label class="form-check-label mt-1" style="font-size:.7rem">
                        <input type="checkbox" name="filterFirstBillNull" value="true" class="form-check-input"
                               @(Model.FilterFirstBillNull ? "checked" : "") style="width:.85em;height:.85em" /> Include Null/Blank
                    </label>
                    <label class="form-check-label mt-1 ms-2" style="font-size:.7rem">
                        <input type="checkbox" name="filterFirstBillExcludeBlank" value="true" class="form-check-input"
                               @(Model.FilterFirstBillExcludeBlank ? "checked" : "") style="width:.85em;height:.85em" /> Exclude Blank
                    </label>
                </div>
                <!-- Charge Entered Date range -->
                <div class="col-sm-6 col-md-3">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">CHARGE ENTERED DATE</label>
                    <div class="d-flex gap-1 align-items-center">
                        <input type="date" name="filterChargeEnteredFrom" value="@Model.FilterChargeEnteredFrom"
                               class="form-control form-control-sm" style="font-size:.75rem" />
                        <span style="font-size:.7rem">to</span>
                        <input type="date" name="filterChargeEnteredTo" value="@Model.FilterChargeEnteredTo"
                               class="form-control form-control-sm" style="font-size:.75rem" />
                    </div>
                    <label class="form-check-label mt-1" style="font-size:.7rem">
                        <input type="checkbox" name="filterChargeEnteredNull" value="true" class="form-check-input"
                               @(Model.FilterChargeEnteredNull ? "checked" : "") style="width:.85em;height:.85em" /> Include Null/Blank
                    </label>
                    <label class="form-check-label mt-1 ms-2" style="font-size:.7rem">
                        <input type="checkbox" name="filterChargeEnteredExcludeBlank" value="true" class="form-check-input"
                               @(Model.FilterChargeEnteredExcludeBlank ? "checked" : "") style="width:.85em;height:.85em" /> Exclude Blank
                    </label>
                </div>
                <!-- Date of Service range -->
                <div class="col-sm-6 col-md-3">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">DATE OF SERVICE</label>
                    <div class="d-flex gap-1 align-items-center">
                        <input type="date" name="filterDosFrom" value="@Model.FilterDosFrom"
                               class="form-control form-control-sm" style="font-size:.75rem" />
                        <span style="font-size:.7rem">to</span>
                        <input type="date" name="filterDosTo" value="@Model.FilterDosTo"
                               class="form-control form-control-sm" style="font-size:.75rem" />
                    </div>
                    <label class="form-check-label mt-1" style="font-size:.7rem">
                        <input type="checkbox" name="filterDosNull" value="true" class="form-check-input"
                               @(Model.FilterDosNull ? "checked" : "") style="width:.85em;height:.85em" /> Include Null/Blank
                    </label>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">Apply Filters</button>
                <a asp-controller="Dashboard" asp-action="ClaimLevel" asp-route-lab="@Model.SelectedLab"
                   class="btn btn-outline-secondary btn-sm">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.DataSource))
{
    <div class="d-flex align-items-center gap-2 mb-3" style="font-size:.78rem">
        <span class="badge bg-success"><i class="bi bi-database-check"></i></span>
        <span class="text-muted">Source:</span>
        <span class="fw-semibold">@Model.DataSource</span>
    </div>
}
else
{
    <div class="alert alert-warning py-2 mb-3" style="font-size:0.8rem">
        No Claim Level data found for <strong>@Model.SelectedLab</strong>.
    </div>
}

@{
    ViewData["RouteValues"]     = routeValues;
    ViewData["RouteListValues"] = routeListValues;
}
<partial name="_Pager" model="Model.Paging" />

<!-- Data card -->
<div class="card cl-data-card mb-3">
    <div class="card-header text-white d-flex align-items-center justify-content-between py-2">
        <div>
            <span class="fw-bold" style="font-size:.9rem">&#128203; Claim Level Records</span>
            <span class="ms-2" style="font-size:.72rem;opacity:.8">
                @Model.Paging.TotalFiltered.ToString("N0") of @Model.Paging.TotalAll.ToString("N0") records
            </span>
        </div>
        <a asp-controller="Dashboard" asp-action="Index" asp-route-lab="@Model.SelectedLab"
           class="btn btn-sm btn-outline-light" style="font-size:.75rem">&larr; Dashboard</a>
    </div>
    <div class="table-responsive" style="max-height:72vh;overflow-y:auto">
        <table class="table table-sm table-bordered align-middle cl-table mb-0">
            <thead>
                <tr>
                    <th>Claim ID</th>
                    <th>Accession #</th>
                    <th>Date of Service</th>
                    <th>First Billed</th>
                    <th>Charge Entered</th>
                    <th>Panel</th>
                    <th>Payer Name</th>
                    <th>Payer Type</th>
                    <th>Clinic</th>
                    <th>Aging Bucket</th>
                    <th style="text-align:right">Charges</th>
                    <th style="text-align:right">Allowed</th>
                    <th style="text-align:right">Ins. Payment</th>
                    <th style="text-align:right">Pat. Payment</th>
                    <th style="text-align:right">Total Payments</th>
                    <th style="text-align:right">Total Balance</th>
                    <th>Claim Status</th>
                    <th>Denial Code</th>
                    <th>ICD Code</th>
                    <th style="text-align:center">Days to Bill</th>
                    <th style="text-align:center">Days to Post</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Records.Any())
                {
                    <tr>
                        <td colspan="21" class="text-center text-muted py-4">
                            No records match the selected filters.
                        </td>
                    </tr>
                }
                @foreach (var r in Model.Records)
                {
                    <tr>
                        <td>@r.ClaimID</td>
                        <td>@r.AccessionNumber</td>
                        <td>@r.DateOfService</td>
                        <td>@r.FirstBilledDate</td>
                        <td>@r.ChargeEnteredDate</td>
                        <td>@r.PanelName</td>
                        <td>@r.PayerName</td>
                        <td><span class="badge @PayerTypeBadge(r.PayerType)">@r.PayerType</span></td>
                        <td>@r.ClinicName</td>
                        <td><span class="badge bg-secondary">@r.AgingBucket</span></td>
                        <td class="amt">@r.ChargeAmount.ToString("C")</td>
                        <td class="amt">@r.AllowedAmount.ToString("C")</td>
                        <td class="amt">@r.InsurancePayment.ToString("C")</td>
                        <td class="amt">@r.PatientPayment.ToString("C")</td>
                        <td class="amt fw-semibold text-success">@r.TotalPayments.ToString("C")</td>
                        <td class="amt fw-semibold @(r.TotalBalance > 0 ? "text-danger" : "text-muted")">
                            @r.TotalBalance.ToString("C")
                        </td>
                        <td><span class="badge @ClaimStatusBadge(r.ClaimStatus)">@r.ClaimStatus</span></td>
                        <td>@r.DenialCode</td>
                        <td>@r.ICDCode</td>
                        <td style="text-align:center">@r.DaysToBill</td>
                        <td style="text-align:center">@r.DaysToPost</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pager" model="Model.Paging" />

@functions {
    static string PayerTypeBadge(string payerType) => payerType switch
    {
        var s when s.StartsWith("MC", StringComparison.OrdinalIgnoreCase) => "bg-primary",
        var s when s.StartsWith("CC", StringComparison.OrdinalIgnoreCase) => "bg-info text-dark",
        var s when s.StartsWith("SP", StringComparison.OrdinalIgnoreCase) => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    static string ClaimStatusBadge(string status) => status switch
    {
        "Fully Paid"             => "bg-success",
        "No Response"            => "bg-warning text-dark",
        "Patient Responsibility" => "bg-info text-dark",
        "Denied"                 => "bg-danger",
        _ => "bg-secondary"
    };
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.cs-ms').forEach(function (ms) {
            var btn   = ms.querySelector('.cs-ms-btn');
            var panel = ms.querySelector('.cs-ms-panel');
            var search = ms.querySelector('.cs-ms-search');
            var labels = ms.querySelectorAll('.cs-ms-list label');
            var labelEl = ms.querySelector('.cs-ms-label');
            var countEl = ms.querySelector('.cs-ms-count');

            function updateLabel() {
                var checked = ms.querySelectorAll('.cs-ms-list input:checked');
                if (checked.length === 0) {
                    labelEl.textContent = 'All';
                    countEl.style.display = 'none';
                } else if (checked.length === 1) {
                    labelEl.textContent = checked[0].value;
                    countEl.style.display = 'none';
                } else {
                    labelEl.textContent = checked[0].value;
                    countEl.textContent = '+' + (checked.length - 1);
                    countEl.style.display = '';
                }
            }

            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                document.querySelectorAll('.cs-ms-panel.open').forEach(function (p) {
                    if (p !== panel) p.classList.remove('open');
                });
                panel.classList.toggle('open');
                if (panel.classList.contains('open')) {
                    search.value = '';
                    search.focus();
                    labels.forEach(function (l) { l.classList.remove('cs-ms-hidden'); });
                }
            });

            search.addEventListener('input', function () {
                var q = this.value.toLowerCase();
                labels.forEach(function (l) {
                    var text = l.textContent.toLowerCase();
                    l.classList.toggle('cs-ms-hidden', q.length > 0 && text.indexOf(q) === -1);
                });
            });

            ms.querySelectorAll('.cs-ms-list input').forEach(function (cb) {
                cb.addEventListener('change', updateLabel);
            });

            panel.addEventListener('click', function (e) { e.stopPropagation(); });
            updateLabel();
        });

        document.addEventListener('click', function () {
            document.querySelectorAll('.cs-ms-panel.open').forEach(function (p) {
                p.classList.remove('open');
            });
        });
    });
</script>
