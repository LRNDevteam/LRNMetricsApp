@model LabMetricsDashboard.Models.PredictionAnalysisViewModel
@{
    ViewData["Title"]       = $"Line Item Detail – {Model.SelectedLab}";
    ViewData["SelectedLab"] = Model.SelectedLab;
    ViewData["PageLabel"]   = "Prediction – Line Detail";

    bool hasFilters = new[]
    {
        Model.FilterPayerName, Model.FilterPayerType, Model.FilterPanelName,
        Model.FilterFinalCoverageStatus, Model.FilterPayability, Model.FilterCPTCode
    }.Any(v => !string.IsNullOrWhiteSpace(v));

    var routeValues = new Dictionary<string, string?>
    {
        ["lab"]                       = Model.SelectedLab,
        ["filterPayerName"]           = Model.FilterPayerName,
        ["filterPayerType"]           = Model.FilterPayerType,
        ["filterPanelName"]           = Model.FilterPanelName,
        ["filterFinalCoverageStatus"] = Model.FilterFinalCoverageStatus,
        ["filterPayability"]          = Model.FilterPayability,
        ["filterCPTCode"]             = Model.FilterCPTCode,
    };

    static string PayabilityBadgeClass(string v) => v switch
    {
        "Payable"             => "bg-success",
        "Potentially Payable" => "bg-warning text-dark",
        "Unknown"             => "bg-secondary",
        _                     => "bg-danger"
    };
}

<style>
    .insight-card  { border:none; border-radius:12px; box-shadow:0 2px 14px rgba(0,0,0,.08); }
    .insight-table th, .insight-table td { font-size:.78rem; padding:.35rem .6rem; }
    .filter-panel  { background:#fff; border-radius:12px; box-shadow:0 2px 10px rgba(0,0,0,.07); }
</style>

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <h2 class="mb-0 fw-bold">&#128196; Line Item Detail</h2>
        <small class="text-muted">@Model.SelectedLab &mdash; @Model.Paging.TotalFiltered.ToString("N0") records (after global filter)</small>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <form method="get" asp-controller="Prediction" asp-action="LineDetail"
              class="d-flex align-items-center gap-2" data-lab-form>
            <label class="fw-semibold me-1 mb-0" for="lineLabSelect">Lab:</label>
            <select id="lineLabSelect" name="lab"
                    class="form-select form-select-sm" style="min-width:220px"
                    data-lab-selector onchange="this.form.submit()">
                @foreach (var lab in Model.AvailableLabs)
                {
                    if (lab == Model.SelectedLab) { <option value="@lab" selected="selected">@lab</option> }
                    else { <option value="@lab">@lab</option> }
                }
            </select>
        </form>
        <a asp-controller="Prediction" asp-action="Index"
           asp-route-lab="@Model.SelectedLab"
           asp-route-filterPayerName="@Model.FilterPayerName"
           asp-route-filterPayerType="@Model.FilterPayerType"
           asp-route-filterPanelName="@Model.FilterPanelName"
           asp-route-filterFinalCoverageStatus="@Model.FilterFinalCoverageStatus"
           asp-route-filterPayability="@Model.FilterPayability"
           asp-route-filterCPTCode="@Model.FilterCPTCode"
           class="btn btn-outline-secondary btn-sm">
            &larr; Back to Summary
        </a>
    </div>
</div>

<!-- Filter panel -->
<div class="filter-panel p-3 mb-4">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <span class="fw-semibold" style="font-size:.9rem">
            &#128269; Filters
            @if (hasFilters)
            {
                <span class="badge bg-primary ms-1" style="font-size:.7rem">Active</span>
            }
        </span>
        <button class="btn btn-sm btn-link text-muted p-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#lineFilterBody"
                aria-expanded="@(hasFilters ? "true" : "false")">
            @if (hasFilters)
            {
                <i class="bi bi-chevron-up me-1"></i><span>Hide</span>
            }
            else
            {
                <i class="bi bi-chevron-down me-1"></i><span>Show</span>
            }
        </button>
    </div>
    <div id="lineFilterBody" class="collapse @(hasFilters ? "show" : "")">
        <form method="get" asp-controller="Prediction" asp-action="LineDetail" data-lab-form>
            <input type="hidden" name="lab" value="@Model.SelectedLab" />
            <div class="row g-2 align-items-end">
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PAYER NAME</label>
                    <select name="filterPayerName" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var v in Model.PayerNames)
                        {
                            if (v == Model.FilterPayerName) { <option value="@v" selected="selected">@v</option> }
                            else { <option value="@v">@v</option> }
                        }
                    </select>
                </div>
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PAYER TYPE</label>
                    <select name="filterPayerType" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var v in Model.PayerTypes)
                        {
                            if (v == Model.FilterPayerType) { <option value="@v" selected="selected">@v</option> }
                            else { <option value="@v">@v</option> }
                        }
                    </select>
                </div>
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PANEL NAME</label>
                    <select name="filterPanelName" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var v in Model.PanelNames)
                        {
                            if (v == Model.FilterPanelName) { <option value="@v" selected="selected">@v</option> }
                            else { <option value="@v">@v</option> }
                        }
                    </select>
                </div>
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">COVERAGE STATUS</label>
                    <select name="filterFinalCoverageStatus" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var v in Model.FinalCoverageStatuses)
                        {
                            if (v == Model.FilterFinalCoverageStatus) { <option value="@v" selected="selected">@v</option> }
                            else { <option value="@v">@v</option> }
                        }
                    </select>
                </div>
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">PAYABILITY</label>
                    <select name="filterPayability" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var v in Model.PayabilityOptions)
                        {
                            if (v == Model.FilterPayability) { <option value="@v" selected="selected">@v</option> }
                            else { <option value="@v">@v</option> }
                        }
                    </select>
                </div>
                <div class="col-sm-6 col-md-2">
                    <label class="form-label fw-semibold mb-1" style="font-size:.75rem">CPT CODE</label>
                    <select name="filterCPTCode" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var v in Model.CPTCodes)
                        {
                            if (v == Model.FilterCPTCode) { <option value="@v" selected="selected">@v</option> }
                            else { <option value="@v">@v</option> }
                        }
                    </select>
                </div>
            </div>
            <div class="mt-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">Apply Filters</button>
                <a asp-controller="Prediction" asp-action="LineDetail" asp-route-lab="@Model.SelectedLab"
                   class="btn btn-outline-secondary btn-sm">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Line detail table -->
<div class="card insight-card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center" style="background:#f8f9fa">
        <span class="fw-bold" style="font-size:.88rem">&#128196; Line Item Detail</span>
        <span class="text-muted" style="font-size:.78rem">
            Showing @Model.Paging.FirstItem–@Model.Paging.LastItem of @Model.Paging.TotalFiltered.ToString("N0") records
        </span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover table-striped mb-0 insight-table">
                <thead class="table-dark">
                    <tr>
                        <th>Visit #</th>
                        <th>CPT</th>
                        <th>Payer</th>
                        <th>Type</th>
                        <th>Panel</th>
                        <th>Pay Status</th>
                        <th>Exp. Pmt Date</th>
                        <th class="text-end">Pred. Allowed</th>
                        <th class="text-end">Pred. Ins. Pmt</th>
                        <th class="text-end">Actual Allowed</th>
                        <th class="text-end">Actual Ins. Pmt</th>
                        <th class="text-end">Variance</th>
                        <th>Forecasting</th>
                        <th>Payability</th>
                        <th>Exp. Pmt Month</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Records.Count == 0)
                    {
                        <tr><td colspan="15" class="text-center text-muted py-3">No records match the current filters.</td></tr>
                    }
                    @foreach (var r in Model.Records)
                    {
                        var variance     = r.ModeAllowedAmountSameLab - r.AllowedAmount;
                        var varClass     = variance >= 0 ? "text-success" : "text-danger";
                        var payerDisplay = !string.IsNullOrWhiteSpace(r.PayerNameNormalized)
                            ? r.PayerNameNormalized : r.PayerName;
                        <tr>
                            <td>@r.VisitNumber</td>
                            <td><strong>@r.CPTCode</strong></td>
                            <td title="@r.PayerName">@(payerDisplay.Length > 24 ? payerDisplay[..24] + "…" : payerDisplay)</td>
                            <td><span class="badge bg-light text-dark border" style="font-size:.68rem">@r.PayerType</span></td>
                            <td title="@r.PanelName">@(r.PanelName.Length > 20 ? r.PanelName[..20] + "…" : r.PanelName)</td>
                            <td>@r.PayStatus</td>
                            <td style="white-space:nowrap">@r.ExpectedPaymentDate</td>
                            <td class="text-end">$@r.ModeAllowedAmountSameLab.ToString("N2")</td>
                            <td class="text-end">$@r.ModeInsurancePaidSameLab.ToString("N2")</td>
                            <td class="text-end">$@r.AllowedAmount.ToString("N2")</td>
                            <td class="text-end">$@r.InsurancePayment.ToString("N2")</td>
                            <td class="text-end fw-semibold @varClass">
                                @(variance >= 0 ? "+" : "")@variance.ToString("N2")
                            </td>
                            <td style="font-size:.75rem">@r.ForecastingPayability</td>
                            <td>
                                <span class="badge @PayabilityBadgeClass(r.Payability)" style="font-size:.68rem">@r.Payability</span>
                            </td>
                            <td style="white-space:nowrap">@r.ExpectedPaymentMonth</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Dashboard/_Pager.cshtml", Model.Paging,
    new ViewDataDictionary(ViewData) { ["RouteValues"] = routeValues })
