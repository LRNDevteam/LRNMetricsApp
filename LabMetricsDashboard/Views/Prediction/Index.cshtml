                    </div>
                    <div class="ratio-card" style="border-left-color:#c0392b">
                        <div class="rc-label">Non-Payment Rate</div>
                        <div class="rc-vals">
                            <span class="rc-val" style="color:#c0392b">@FmtPct(sm.NonPaymentRateClaim)</span><span class="rc-sub">Claim</span>
                            <span class="rc-val" style="color:#c0392b">@FmtPct(sm.NonPaymentRateAllowed)</span><span class="rc-sub">Allowed</span>
                            <span class="rc-val" style="color:#c0392b">@FmtPct(sm.NonPaymentRateInsurance)</span><span class="rc-sub">Ins. Pmt</span>
                        </div>
                    </div>
                    <div class="ratio-card" style="border-left-color:#e53935">
                        <div class="rc-label">Denied</div>
                        <div class="rc-vals">
                            <span class="rc-val">@FmtPct(sm.DeniedPctClaim)</span><span class="rc-sub">Claim</span>
                            <span class="rc-val">@FmtPct(sm.DeniedPctAllowed)</span><span class="rc-sub">Allowed</span>
                            <span class="rc-val">@FmtPct(sm.DeniedPctInsurance)</span><span class="rc-sub">Ins. Pmt</span>
                        </div>
                    </div>
                    <div class="ratio-card" style="border-left-color:#f57c00">
                        <div class="rc-label">No Response</div>
                        <div class="rc-vals">
                            <span class="rc-val">@FmtPct(sm.NoResponsePctClaim)</span><span class="rc-sub">Claim</span>
                            <span class="rc-val">@FmtPct(sm.NoResponsePctAllowed)</span><span class="rc-sub">Allowed</span>
                            <span class="rc-val">@FmtPct(sm.NoResponsePctInsurance)</span><span class="rc-sub">Ins. Pmt</span>
                        </div>
                    </div>
                    <div class="ratio-card" style="border-left-color:#6a1b9a">
                        <div class="rc-label">Adjusted</div>
                        <div class="rc-vals">
                            <span class="rc-val">@FmtPct(sm.AdjustedPctClaim)</span><span class="rc-sub">Claim</span>
                            <span class="rc-val">@FmtPct(sm.AdjustedPctAllowed)</span><span class="rc-sub">Allowed</span>
                            <span class="rc-val">@FmtPct(sm.AdjustedPctInsurance)</span><span class="rc-sub">Ins. Pmt</span>
                        </div>
                    </div>
                </div>
            </div>


            <!-- ?? Prediction Accuracy KPI tiles ???????????????????????? -->
            <div class="px-3 py-3" style="background:#f8fafc;border-top:1px solid #e2e8f0">
                <div class="fw-bold mb-3" style="font-size:.78rem;letter-spacing:.08em;color:#0d1b2a">
                    &#127919; PREDICTION ACCURACY
                </div>
                <div class="d-flex flex-wrap gap-3">

                    <!-- Claim % tile -->
                    <div style="background:#fff;border:1px solid #bfdbfe;border-left:4px solid #1565c0;
                                border-radius:10px;padding:.9rem 1.2rem;min-width:190px;
                                box-shadow:0 2px 8px rgba(21,101,192,.10);flex:1">
                        <div style="font-size:.65rem;font-weight:700;letter-spacing:.1em;
                                    color:#1565c0;text-transform:uppercase;margin-bottom:.3rem">
                            Claim (%)
                        </div>
                        <div style="font-size:2rem;font-weight:800;color:#1565c0;line-height:1;margin-bottom:.2rem">
                            @FmtPct(sm.PredVsActualRatioClaim)
                        </div>
                        <div style="font-size:.68rem;color:#64748b">Predicted vs Actuals Ratio</div>
                    </div>

                    <!-- Allowed Amount % tile -->
                    <div style="background:#fff;border:1px solid #bbf7d0;border-left:4px solid #2e7d32;
                                border-radius:10px;padding:.9rem 1.2rem;min-width:220px;
                                box-shadow:0 2px 8px rgba(46,125,50,.10);flex:1">
                        <div style="font-size:.65rem;font-weight:700;letter-spacing:.1em;
                                    color:#2e7d32;text-transform:uppercase;margin-bottom:.3rem">
                            Allowed Amount (%)
                        </div>
                        <div style="font-size:2rem;font-weight:800;color:#2e7d32;line-height:1;margin-bottom:.2rem">
                            @FmtPct(sm.PredVsActualAllowedAmount)
                        </div>
                        <div style="font-size:.68rem;color:#64748b">Predicted vs Actuals ¢ Allowed Amount</div>
                    </div>

                    <!-- Insurance Payment % tile -->
                    <div style="background:#fff;border:1px solid #e9d5ff;border-left:4px solid #6a1b9a;
                                border-radius:10px;padding:.9rem 1.2rem;min-width:220px;
                                box-shadow:0 2px 8px rgba(106,27,154,.10);flex:1">
                        <div style="font-size:.65rem;font-weight:700;letter-spacing:.1em;
                                    color:#6a1b9a;text-transform:uppercase;margin-bottom:.3rem">
                            Insurance Payment (%)
                        </div>
                        <div style="font-size:2rem;font-weight:800;color:#6a1b9a;line-height:1;margin-bottom:.2rem">
                            @FmtPct(sm.PredVsActualInsPayment)
                        </div>
                        <div style="font-size:.68rem;color:#64748b">Predicted vs Actuals ¢ Insurance Payment</div>
                    </div>

                </div>
            </div>
            </div>
            </div>
            <!-- /Summary tab pane -->

            @if (insight is not null)
            {
            <div class="tab-pane fade" id="pane-aiinsight" role="tabpanel">
                <div class="p-3" style="background:#f1f5f9">
                    <div class="row g-3">
                        @for (int si = 0; si < insight.Sections.Count; si++)
                        {
                            var sec   = insight.Sections[si];
                            var ci    = si % 4;
                            var bdr   = insSecBorder[ci];
                            var bg    = insSecBg[ci];
                            var icol  = insSecIcon[ci];
                            var emoji = insSecEmoji[ci];
                            <div class="col-12 col-xl-6">
                                <div class="h-100 rounded-3 overflow-hidden"
                                     style="background:#fff;border:1px solid #e2e8f0;box-shadow:0 2px 8px rgba(0,0,0,.05)">
                                    <!-- Section header bar -->
                                    <div class="d-flex align-items-center gap-2 px-3 py-2"
                                         style="background:@bg;border-bottom:2px solid @bdr">
                                        <span>@(new Microsoft.AspNetCore.Html.HtmlString(emoji))</span>
                                        <span class="fw-bold" style="font-size:.78rem;color:@icol;letter-spacing:.05em;text-transform:uppercase">
                                            @sec.SectionNumber. @sec.Title
                                        </span>
                                    </div>
                                    <!-- Subsections -->
                                    <div class="px-3 py-2">
                                        @foreach (var sub in sec.Subsections)
                                        {
                                            <div class="d-inline-block mb-2 mt-2 px-2 py-1 rounded-pill"
                                                 style="background:@bg;border:1px solid @bdr;font-size:.68rem;font-weight:700;color:@icol;letter-spacing:.04em;text-transform:uppercase">
                                                @sub.Title
                                            </div>
                                            <ul class="mb-2" style="list-style:none;padding-left:.25rem">
                                                @foreach (var bullet in sub.Bullets)
                                                {
                                                    <li class="d-flex gap-2 mb-1" style="font-size:.78rem;color:#374151;line-height:1.5">
                                                        <span style="color:@icol;font-weight:700;flex-shrink:0">&#8250;</span>
                                                        <span>@bullet</span>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <!-- Footer -->
                <div class="d-flex align-items-center justify-content-between px-4 py-2"
                     style="background:#f8fafc;border-top:1px solid #e2e8f0">
                    <span style="font-size:.68rem;color:#94a3b8">&#128196; Source: @insight.SourceFileName</span>
                    @if (Model.Insight is null)
                    {
                        <span class="badge bg-warning text-dark" style="font-size:.62rem">fallback data</span>
                    }
                </div>
            </div>
            }
            <!-- /AI Insights tab pane -->

        </div>
    </div>

    <!-- ?? Unified Analysis Tabs: Payers | CPT | Panels | Denial | No Response ?? -->
    <div class="card insight-card mb-4">
        <div class="card-header text-white d-flex align-items-center gap-2 px-3 py-2"
             style="background:linear-gradient(135deg,#0d1b2a,#1a2744)">
            <span>&#128202; Prediction Validation &amp; Breakdown Analysis</span>
        </div>
        <div class="card-body p-0">

            <!-- Pro Tab Bar -->
            <div class="pro-tabs" role="tablist">
                <button class="pro-tab active" id="pt-payers" data-bs-toggle="tab"
                        data-bs-target="#pp-payers" type="button" role="tab">
                    &#128100; Payers
                    <span class="pro-tab-badge">@Model.TopPayerInsights.Count</span>
                </button>
                <button class="pro-tab tab-cpt" id="pt-cpts" data-bs-toggle="tab"
                        data-bs-target="#pp-cpts" type="button" role="tab">
                    &#35; CPT Codes
                    <span class="pro-tab-badge">@Model.TopCptInsights.Count</span>
                </button>
                <button class="pro-tab tab-panel" id="pt-panels" data-bs-toggle="tab"
                        data-bs-target="#pp-panels" type="button" role="tab">
                    &#9635; Panels
                    <span class="pro-tab-badge">@Model.TopPanelInsights.Count</span>
                </button>
                <button class="pro-tab tab-denial" id="pt-denial" data-bs-toggle="tab"
                        data-bs-target="#pp-denial" type="button" role="tab">
                    &#128683; Denial Breakdown
                    <span class="pro-tab-badge">@db.TotalClaims.ToString("N0")</span>
                </button>
                <button class="pro-tab tab-noresp" id="pt-noresp" data-bs-toggle="tab"
                        data-bs-target="#pp-noresp" type="button" role="tab">
                    &#9888;&#65039; No Response
                    <span class="pro-tab-badge">@nr.TotalClaims.ToString("N0")</span>
                </button>
            </div>

            <div class="tab-content">

                <!-- ?? Payers ?? -->
                <div class="tab-pane fade show active" id="pp-payers" role="tabpanel">
                    @{
                        var pTotal = new
                        {
                            Claims    = Model.TopPayerInsights.Sum(r => r.TotalClaims),
                            Paid      = Model.TopPayerInsights.Sum(r => r.Paid),
                            Denied    = Model.TopPayerInsights.Sum(r => r.Denied),
                            NoResp    = Model.TopPayerInsights.Sum(r => r.NoResponse),
                            Adj       = Model.TopPayerInsights.Sum(r => r.Adjusted),
                            Unpaid    = Model.TopPayerInsights.Sum(r => r.Unpaid),
                            PredAllow = Model.TopPayerInsights.Sum(r => r.PredictedAllowed),
                            PredIns   = Model.TopPayerInsights.Sum(r => r.PredictedInsurance),
                            ActAllow  = Model.TopPayerInsights.Sum(r => r.ActualAllowed),
                            ActIns    = Model.TopPayerInsights.Sum(r => r.ActualInsurance),
                            Variance  = Model.TopPayerInsights.Sum(r => r.Variance),
                        };
                    }
                    <div class="px-3 py-2" style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                        <span class="fw-semibold" style="font-size:.8rem;color:#1a2744">Prediction Validation by Payer (Claim Level)</span>
                        <span class="text-muted ms-2" style="font-size:.72rem">Sorted by Total Claims Descending</span>
                    </div>
                    <div class="table-responsive">
                        <table class="vt-table">
                            <thead>
                                <tr>
                                    <th>Payer Name</th><th>Payer Type</th>
                                    <th class="text-end">Total Claims</th>
                                    <th class="text-end" style="color:#4caf50">Paid</th>
                                    <th class="text-end" style="color:#ef5350">Denied</th>
                                    <th class="text-end" style="color:#ff9800">No Response</th>
                                    <th class="text-end" style="color:#ab47bc">Adjusted</th>
                                    <th class="text-end" style="color:#ef5350">Unpaid</th>
                                    <th class="text-end">Payment Rate (%)</th>
                                    <th class="text-end">Predicted Allowed</th>
                                    <th class="text-end">Pred. Ins. Payment</th>
                                    <th class="text-end">Actual Allowed ($)</th>
                                    <th class="text-end">Actual Ins. Payment</th>
                                    <th class="text-end">Variance ($)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.TopPayerInsights)
                                {
                                    <tr>
                                        <td class="fw-semibold" title="@r.PayerName">@r.PayerName</td>
                                        <td>@if (!string.IsNullOrWhiteSpace(r.PayerType)) { <span class="vt-type-badge">@r.PayerType</span> }</td>
                                        <td class="text-end fw-bold">@r.TotalClaims</td>
                                        <td class="text-end vt-paid">@r.Paid</td>
                                        <td class="text-end vt-denied">@r.Denied</td>
                                        <td class="text-end vt-noresp">@r.NoResponse</td>
                                        <td class="text-end vt-adj">@r.Adjusted</td>
                                        <td class="text-end vt-unpaid fw-bold">@r.Unpaid</td>
                                        <td class="text-end fw-semibold" style="color:@(r.PaymentRatePct >= 50 ? "#2e7d32" : "#c0392b")">
                                            @(r.PaymentRatePct.HasValue ? $"{r.PaymentRatePct:N1}%" : "Ś")
                                        </td>
                                        <td class="text-end">@(r.PredictedAllowed == 0 ? "" : $"${r.PredictedAllowed:N2}")</td>
                                        <td class="text-end">@(r.PredictedInsurance == 0 ? "" : $"${r.PredictedInsurance:N2}")</td>
                                        <td class="text-end">@(r.ActualAllowed == 0 ? "" : $"${r.ActualAllowed:N2}")</td>
                                        <td class="text-end">@(r.ActualInsurance == 0 ? "" : $"${r.ActualInsurance:N2}")</td>
                                        <td class="text-end fw-semibold @(r.Variance >= 0 ? "vt-var-pos" : "vt-var-neg")">
                                            @(r.Variance == 0 ? "" : (r.Variance > 0 ? "+" : "") + $"${r.Variance:N2}")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="vt-total">
                                    <td colspan="2">TOTAL</td>
                                    <td class="text-end">@pTotal.Claims</td>
                                    <td class="text-end">@pTotal.Paid</td>
                                    <td class="text-end">@pTotal.Denied</td>
                                    <td class="text-end">@pTotal.NoResp</td>
                                    <td class="text-end">@pTotal.Adj</td>
                                    <td class="text-end">@pTotal.Unpaid</td>
                                    <td></td>
                                    <td class="text-end">$@pTotal.PredAllow.ToString("N2")</td>
                                    <td class="text-end">$@pTotal.PredIns.ToString("N2")</td>
                                    <td class="text-end">$@pTotal.ActAllow.ToString("N2")</td>
                                    <td class="text-end">$@pTotal.ActIns.ToString("N2")</td>
                                    <td class="text-end @(pTotal.Variance >= 0 ? "vt-var-pos" : "vt-var-neg")">
                                        @((pTotal.Variance > 0 ? "+" : "") + $"${pTotal.Variance:N2}")
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <!-- ?? CPT Codes ?? -->
                <div class="tab-pane fade" id="pp-cpts" role="tabpanel">
                    <div class="px-3 py-2" style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                        <span class="fw-semibold" style="font-size:.8rem;color:#00695c">CPT Code Breakdown</span>
                    </div>
                    <div class="table-responsive">
                        <table class="vt-table">
                            <thead>
                                <tr>
                                    <th>CPT Code</th>
                                    <th class="text-end">Claims</th>
                                    <th class="text-end">Pred. Allowed</th>
                                    <th class="text-end">Pred. Ins. Pmt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.TopCptInsights)
                                {
                                    <tr>
                                        <td><strong>@r.CPTCode</strong></td>
                                        <td class="text-end">@r.LineItems.ToString("N0")</td>
                                        <td class="text-end">$@r.PredictedAllowed.ToString("N0")</td>
                                        <td class="text-end fw-semibold vt-var-pos">$@r.PredictedInsurance.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- ?? Panels ?? -->
                <div class="tab-pane fade" id="pp-panels" role="tabpanel">
                    @{
                        var plTotal = new
                        {
                            Claims    = Model.TopPanelInsights.Sum(r => r.TotalClaims),
                            Paid      = Model.TopPanelInsights.Sum(r => r.Paid),
                            Denied    = Model.TopPanelInsights.Sum(r => r.Denied),
                            NoResp    = Model.TopPanelInsights.Sum(r => r.NoResponse),
                            Adj       = Model.TopPanelInsights.Sum(r => r.Adjusted),
                            Unpaid    = Model.TopPanelInsights.Sum(r => r.Unpaid),
                            PredAllow = Model.TopPanelInsights.Sum(r => r.PredictedAllowed),
                            PredIns   = Model.TopPanelInsights.Sum(r => r.PredictedInsurance),
                            ActAllow  = Model.TopPanelInsights.Sum(r => r.ActualAllowed),
                            ActIns    = Model.TopPanelInsights.Sum(r => r.ActualInsurance),
                            Variance  = Model.TopPanelInsights.Sum(r => r.Variance),
                        };
                    }
                    <div class="px-3 py-2" style="background:#f8fafc;border-bottom:1px solid #e2e8f0">
                        <span class="fw-semibold" style="font-size:.8rem;color:#00695c">Prediction Validation by Panel (Claim Level)</span>
                        <span class="text-muted ms-2" style="font-size:.72rem">Sorted by Total Claims Descending</span>
                    </div>
                    <div class="table-responsive">
                        <table class="vt-table">
                            <thead>
                                <tr>
                                    <th>Panel Name</th>
                                    <th class="text-end">Total Claims</th>
                                    <th class="text-end" style="color:#4caf50">Paid</th>
                                    <th class="text-end" style="color:#ef5350">Denied</th>
                                    <th class="text-end" style="color:#ff9800">No Response</th>
                                    <th class="text-end" style="color:#ab47bc">Adjusted</th>
                                    <th class="text-end" style="color:#ef5350">Unpaid</th>
                                    <th class="text-end">Payment Rate (%)</th>
                                    <th class="text-end">Predicted Allowed</th>
                                    <th class="text-end">Pred. Ins. Payment</th>
                                    <th class="text-end">Actual Allowed ($)</th>
                                    <th class="text-end">Actual Ins. Payment</th>
                                    <th class="text-end">Variance ($)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.TopPanelInsights)
                                {
                                    <tr>
                                        <td class="fw-semibold">@r.PanelName</td>
                                        <td class="text-end fw-bold">@r.TotalClaims</td>
                                        <td class="text-end vt-paid">@r.Paid</td>
                                        <td class="text-end vt-denied">@r.Denied</td>
                                        <td class="text-end vt-noresp">@r.NoResponse</td>
                                        <td class="text-end vt-adj">@r.Adjusted</td>
                                        <td class="text-end vt-unpaid fw-bold">@r.Unpaid</td>
                                        <td class="text-end fw-semibold" style="color:@(r.PaymentRatePct >= 50 ? "#2e7d32" : "#c0392b")">
                                            @(r.PaymentRatePct.HasValue ? $"{r.PaymentRatePct:N1}%" : "Ś")
                                        </td>
                                        <td class="text-end">@(r.PredictedAllowed == 0 ? "" : $"${r.PredictedAllowed:N2}")</td>
                                        <td class="text-end">@(r.PredictedInsurance == 0 ? "" : $"${r.PredictedInsurance:N2}")</td>
                                        <td class="text-end">@(r.ActualAllowed == 0 ? "" : $"${r.ActualAllowed:N2}")</td>
                                        <td class="text-end">@(r.ActualInsurance == 0 ? "" : $"${r.ActualInsurance:N2}")</td>
                                        <td class="text-end fw-semibold @(r.Variance >= 0 ? "vt-var-pos" : "vt-var-neg")">
                                            @(r.Variance == 0 ? "" : (r.Variance > 0 ? "+" : "") + $"${r.Variance:N2}")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="vt-total">
                                    <td>TOTAL</td>
                                    <td class="text-end">@plTotal.Claims</td>
                                    <td class="text-end">@plTotal.Paid</td>
                                    <td class="text-end">@plTotal.Denied</td>
                                    <td class="text-end">@plTotal.NoResp</td>
                                    <td class="text-end">@plTotal.Adj</td>
                                    <td class="text-end">@plTotal.Unpaid</td>
                                    <td></td>
                                    <td class="text-end">$@plTotal.PredAllow.ToString("N2")</td>
                                    <td class="text-end">$@plTotal.PredIns.ToString("N2")</td>
                                    <td class="text-end">$@plTotal.ActAllow.ToString("N2")</td>
                                    <td class="text-end">$@plTotal.ActIns.ToString("N2")</td>
                                    <td class="text-end @(plTotal.Variance >= 0 ? "vt-var-pos" : "vt-var-neg")">
                                        @((plTotal.Variance > 0 ? "+" : "") + $"${plTotal.Variance:N2}")
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <!-- ?? Denial Breakdown ?? -->
                <div class="tab-pane fade" id="pp-denial" role="tabpanel">
                    <div class="px-3 py-2 d-flex align-items-center justify-content-between"
                         style="background:#fff5f5;border-bottom:1px solid #fecaca">
                        <span class="fw-semibold" style="font-size:.8rem;color:#b71c1c">
                            &#128683; Predicted to Pay vs Denial Breakdown
                        </span>
                        <span class="badge" style="background:#b71c1c;font-size:.7rem">
                            @db.TotalClaims.ToString("N0") denied claims
                        </span>
                    </div>
                    @if (db.PayerRows.Count == 0)
                    {
                        <div class="p-3 text-muted" style="font-size:.85rem">No denied records match the current filter criteria.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="denial-table">
                                <thead>
                                    <tr>
                                        <th rowspan="2" style="min-width:180px;text-align:left">Payer Name</th>
                                        @foreach (var mo in db.Months)
                                        {
                                            <th colspan="3" class="denial-month-group">@mo</th>
                                        }
                                        <th colspan="3" style="background:#1b5e20">Total</th>
                                    </tr>
                                    <tr>
                                        @foreach (var mo in db.Months)
                                        {
                                            <th class="denial-month-group">Claims</th>
                                            <th>Pred. Allowed ($)</th>
                                            <th>Pred. Ins. Pmt ($)</th>
                                        }
                                        <th style="background:#2e7d32">Claims</th>
                                        <th style="background:#2e7d32">Pred. Allowed ($)</th>
                                        <th style="background:#2e7d32">Pred. Ins. Pmt ($)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payer in db.PayerRows)
                                    {
                                        <tr class="denial-row-payer">
                                            <td title="@payer.PayerName">
                                                @(payer.PayerName.Length > 38 ? payer.PayerName[..38] + "ģ" : payer.PayerName)
                                            </td>
                                            @foreach (var mo in db.Months)
                                            {
                                                var ma = payer.ByMonth.GetValueOrDefault(mo);
                                                <td class="cnt denial-month-group">@((ma?.ClaimCount ?? 0).ToString("N0"))</td>
                                                <td class="amt">$@((ma?.PredictedAllowed ?? 0).ToString("N0"))</td>
                                                <td class="amt">$@((ma?.PredictedInsurance ?? 0).ToString("N0"))</td>
                                            }
                                            <td class="cnt">@payer.TotalClaims.ToString("N0")</td>
                                            <td class="amt">$@payer.TotalPredictedAllowed.ToString("N0")</td>
                                            <td class="amt">$@payer.TotalPredictedInsurance.ToString("N0")</td>
                                        </tr>
                                        @foreach (var dc in payer.TopDenialCodes)
                                        {
                                            <tr class="denial-row-code">
                                                <td title="@dc.DenialDescription">
                                                    &nbsp;&nbsp;&nbsp;@dc.DenialCode
                                                    @if (!string.IsNullOrWhiteSpace(dc.DenialDescription))
                                                    {
                                                        <span class="text-muted" style="font-weight:400">
                                                            &mdash; @(dc.DenialDescription.Length > 40 ? dc.DenialDescription[..40] + "ģ" : dc.DenialDescription)
                                                        </span>
                                                    }
                                                </td>
                                                @foreach (var mo in db.Months)
                                                {
                                                    var ma = dc.ByMonth.GetValueOrDefault(mo);
                                                    <td class="cnt denial-month-group">@((ma?.ClaimCount ?? 0).ToString("N0"))</td>
                                                    <td class="amt">$@((ma?.PredictedAllowed ?? 0).ToString("N0"))</td>
                                                    <td class="amt">$@((ma?.PredictedInsurance ?? 0).ToString("N0"))</td>
                                                }
                                                <td class="cnt">@dc.TotalClaims.ToString("N0")</td>
                                                <td class="amt">$@dc.TotalPredictedAllowed.ToString("N0")</td>
                                                <td class="amt">$@dc.TotalPredictedInsurance.ToString("N0")</td>
                                            </tr>
                                        }
                                    }
                                    <tr class="denial-row-total">
                                        <td>Total</td>
                                        @foreach (var mo in db.Months)
                                        {
                                            var ma = db.TotalByMonth.GetValueOrDefault(mo);
                                            <td class="cnt denial-month-group">@((ma?.ClaimCount ?? 0).ToString("N0"))</td>
                                            <td class="amt">$@((ma?.PredictedAllowed ?? 0).ToString("N0"))</td>
                                            <td class="amt">$@((ma?.PredictedInsurance ?? 0).ToString("N0"))</td>
                                        }
                                        <td class="cnt">@db.TotalClaims.ToString("N0")</td>
                                        <td class="amt">$@db.TotalPredictedAllowed.ToString("N0")</td>
                                        <td class="amt">$@db.TotalPredictedInsurance.ToString("N0")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <!-- ?? No Response Breakdown ?? -->
                <div class="tab-pane fade" id="pp-noresp" role="tabpanel">
                    <div class="px-3 py-2 d-flex align-items-center justify-content-between"
                         style="background:#fdf4ff;border-bottom:1px solid #e9d5ff">
                        <span class="fw-semibold" style="font-size:.8rem;color:#6a1b9a">
                            &#9888;&#65039; Predicted to Pay vs No Response Breakdown
                        </span>
                        <span class="badge" style="background:#6a1b9a;font-size:.7rem">
                            @nr.TotalClaims.ToString("N0") no-response claims
                        </span>
                    </div>
                    @if (nr.PayerRows.Count == 0)
                    {
                        <div class="p-3 text-muted" style="font-size:.85rem">No no-response records match the current filter criteria.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="nr-table">
                                <thead>
                                    <tr>
                                        <th rowspan="2" style="min-width:180px;text-align:left">Payer Name</th>
                                        @foreach (var bkt in AgeBuckets.All)
                                        {
                                            <th colspan="3" class="nr-bucket-group">@bkt days</th>
                                        }
                                        <th colspan="3" style="background:#1b5e20">Total</th>
                                        <th rowspan="2" style="background:#37474f;min-width:130px">Priority Level</th>
                                    </tr>
                                    <tr>
                                        @foreach (var bkt in AgeBuckets.All)
                                        {
                                            <th class="nr-bucket-group">Claims</th>
                                            <th>Pred. Allowed ($)</th>
                                            <th>Pred. Ins. Pmt ($)</th>
                                        }
                                        <th style="background:#2e7d32">Claims</th>
                                        <th style="background:#2e7d32">Pred. Allowed ($)</th>
                                        <th style="background:#2e7d32">Pred. Ins. Pmt ($)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payer in nr.PayerRows)
                                    {
                                        <tr class="nr-row-payer">
                                            <td title="@payer.PayerName">
                                                @(payer.PayerName.Length > 38 ? payer.PayerName[..38] + "ģ" : payer.PayerName)
                                            </td>
                                            @foreach (var bkt in AgeBuckets.All)
                                            {
                                                var ba = payer.ByBucket.GetValueOrDefault(bkt);
                                                <td class="cnt nr-bucket-group">@((ba?.ClaimCount ?? 0).ToString("N0"))</td>
                                                <td class="amt">$@((ba?.PredictedAllowed ?? 0).ToString("N0"))</td>
                                                <td class="amt">$@((ba?.PredictedInsurance ?? 0).ToString("N0"))</td>
                                            }
                                            <td class="cnt">@payer.TotalClaims.ToString("N0")</td>
                                            <td class="amt">$@payer.TotalPredictedAllowed.ToString("N0")</td>
                                            <td class="amt">$@payer.TotalPredictedInsurance.ToString("N0")</td>
                                            <td class="text-center">
                                                <span class="pri-badge @PriBadgeClass(payer.PriorityBucket)">
                                                    @PriLabel(payer.PriorityBucket)
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                    <tr class="nr-row-total">
                                        <td>Total</td>
                                        @foreach (var bkt in AgeBuckets.All)
                                        {
                                            var tba = nr.TotalByBucket.GetValueOrDefault(bkt);
                                            <td class="cnt nr-bucket-group">@((tba?.ClaimCount ?? 0).ToString("N0"))</td>
                                            <td class="amt">$@((tba?.PredictedAllowed ?? 0).ToString("N0"))</td>
                                            <td class="amt">$@((tba?.PredictedInsurance ?? 0).ToString("N0"))</td>
                                        }
                                        <td class="cnt">@nr.TotalClaims.ToString("N0")</td>
                                        <td class="amt">$@nr.TotalPredictedAllowed.ToString("N0")</td>
                                        <td class="amt">$@nr.TotalPredictedInsurance.ToString("N0")</td>
                                        <td></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>

    <!-- ?? Line Item Detail (separate page) ????????????????????????? -->
    <div class="card insight-card mb-4" style="border:1px solid #dee2e6">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3 py-3 px-4">
            <div>
                <div class="fw-bold" style="font-size:.95rem">&#128196; Line Item Detail</div>
                <div class="text-muted" style="font-size:.8rem">
                    @Model.Paging.TotalFiltered.ToString("N0") records (after global filter) Ś view on a dedicated page with filters and paging.
                </div>
            </div>
            <a asp-controller="Prediction" asp-action="LineDetail"
               asp-route-lab="@Model.SelectedLab"
               asp-route-filterPayerName="@Model.FilterPayerName"
               asp-route-filterPayerType="@Model.FilterPayerType"
               asp-route-filterPanelName="@Model.FilterPanelName"
               asp-route-filterFinalCoverageStatus="@Model.FilterFinalCoverageStatus"
               asp-route-filterPayability="@Model.FilterPayability"
               asp-route-filterCPTCode="@Model.FilterCPTCode"
               class="btn btn-primary">
                &#128196; Open Line Detail &rarr;
            </a>
        </div>
    </div>

    <!-- ?? Forecasting Summary (separate page) ???????????????????????????? -->
    <div class="card insight-card mb-4" style="border:1px solid #dee2e6">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3 py-3 px-4">
            <div>
                <div class="fw-bold" style="font-size:.95rem">&#128197; Forecasting Summary</div>
                <div class="text-muted" style="font-size:.8rem">
                    Last 4 weeks Median &amp; Mode weekly breakdown by payer Ś view on a dedicated page.
                </div>
            </div>
            <a asp-controller="Prediction" asp-action="ForecastingSummary"
               asp-route-lab="@Model.SelectedLab"
               asp-route-filterPayerName="@Model.FilterPayerName"
               asp-route-filterPayerType="@Model.FilterPayerType"
               asp-route-filterPanelName="@Model.FilterPanelName"
               asp-route-filterCPTCode="@Model.FilterCPTCode"
               class="btn btn-success">
                &#128197; Open Forecasting Summary &rarr;
            </a>
        </div>
    </div>
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var exportBtn = document.getElementById('exportPredictionExcelBtn');
        if (exportBtn) {
            exportBtn.addEventListener('click', function () {
                var form = exportBtn.closest('form');
                if (!form) return;
                var params = new URLSearchParams(new FormData(form));
                var url = '@Url.Action("ExportPredictionExcel", "Prediction")' + '?' + params.toString();
                lmdExcelDownload(url);
            });
        }
    });
</script>
