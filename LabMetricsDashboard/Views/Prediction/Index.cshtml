    <!-- ?? Prediction vs Non-Payment Summary ??????????????????????????????? -->
    <div class="card insight-card mb-4">
        <div class="card-header text-white d-flex align-items-center justify-content-between"
             style="background:linear-gradient(135deg,#0d1b2a,#1565c0)">
            <div>
                <div class="fw-bold">&#128203; Prediction vs Non-Payment Summary</div>
                <div style="font-size:.72rem;opacity:.8;font-weight:400">
                    Claims = COUNT(DISTINCT Visit#) &nbsp;|&nbsp;
                    Predicted = SUM(Mode Allowed / Mode Ins. Paid) &nbsp;|&nbsp;
                    Analysis cutoff: Expected Payment Date &lt; Start of current week
                </div>
            </div>
        </div>

        <!-- Tab bar -->
        <div class="pro-tabs" role="tablist" style="border-radius:0">
            <button class="pro-tab active" id="pt-summary" data-bs-toggle="tab"
                    data-bs-target="#pane-summary" type="button" role="tab">
                &#128203; Summary
            </button>
            @if (insight is not null)
            {
                <button class="pro-tab tab-insight" id="pt-aiinsight" data-bs-toggle="tab"
                        data-bs-target="#pane-aiinsight" type="button" role="tab">
                    &#129504; Insights
                    <span class="pro-tab-badge">@insight.Sections.Count</span>
                </button>
            }
        </div>

        <div class="tab-content">

            <!-- Summary tab (existing content) -->
            <div class="tab-pane fade show active" id="pane-summary" role="tabpanel">
                <div class="card-body p-0">

                <div class="table-responsive">
                <table class="metrics-sheet">
                    @{
                        var toPay  = Model.Buckets.FirstOrDefault(b => b.BucketName == "Predicted To Pay");
                        var paid   = Model.Buckets.FirstOrDefault(b => b.BucketName == "Predicted \u2013 Paid");
                        var unpaid = Model.Buckets.FirstOrDefault(b => b.BucketName == "Predicted \u2013 Unpaid");
                        var denied = Model.Buckets.FirstOrDefault(b => b.BucketName == "Unpaid \u2013 Denied");
                        var noresp = Model.Buckets.FirstOrDefault(b => b.BucketName == "Unpaid \u2013 No Response");
                        var adj    = Model.Buckets.FirstOrDefault(b => b.BucketName == "Unpaid \u2013 Adjusted");
                    }
                    <thead>
                        <tr>
                            <th style="width:16%">Metrics</th>
                            <th class="text-end" style="width:9%">Claim Count (#)</th>
                            <th class="text-end" style="width:12%">Predicted Allowed ($)</th>
                            <th class="text-end" style="width:12%">Predicted Insurance Payment ($)</th>
                            <th class="text-end" style="width:12%">Actual Allowed Amount ($)</th>
                            <th class="text-end" style="width:12%">Actual Insurance Payment ($)</th>
                            <th class="text-end" style="width:13%">Allowed Amount - Actual Vs Predicted ($)</th>
                            <th class="text-end" style="width:14%">Insurance Paid -  Actual  vs Predicted ($)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                        string FmtVariance(decimal? pred, decimal? actual)
                        {
                            // Show Actual - Predicted as positive when actual > predicted
                            if (pred is null || actual is null) return "\u2014";
                            var v = actual.Value - pred.Value;
                            return (v >= 0 ? "+" : "") + v.ToString("N2");
                        }
                        string VarClass(decimal? pred, decimal? actual)
                        {
                            if (pred is null || actual is null) return "na-cell";
                            return (actual.Value - pred.Value) >= 0 ? "text-success" : "text-danger";
                        }
                        }

                        <!-- Predicted To Pay -->
                        <tr class="row-summary">
                            <td><strong>Predicted To Pay</strong></td>
                            <td class="text-end val-cell">@(toPay?.ClaimCount.ToString("N0") ?? "\u2014")</td>
                            <td class="text-end val-cell">@FmtAmt(toPay?.PredictedAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(toPay?.PredictedInsurance)</td>
                            <td class="text-end na-cell">Ś</td>
                            <td class="text-end na-cell">Ś</td>
                            <td class="text-end na-cell">Ś</td>
                            <td class="text-end na-cell">Ś</td>
                        </tr>

                        <!-- Predicted ¢ Paid -->
                        <tr class="row-summary">
                            <td><strong>Predicted ¢ Paid</strong></td>
                            <td class="text-end val-cell">@(paid?.ClaimCount.ToString("N0") ?? "\u2014")</td>
                            <td class="text-end val-cell">@FmtAmt(paid?.PredictedAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(paid?.PredictedInsurance)</td>
                            <td class="text-end val-cell">@FmtAmt(paid?.ActualAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(paid?.ActualInsurance)</td>
                            <td class="text-end val-cell fw-semibold @VarClass(paid?.PredictedAllowed, paid?.ActualAllowed)">
                                @FmtVariance(paid?.PredictedAllowed, paid?.ActualAllowed)
                            </td>
                            <td class="text-end val-cell fw-semibold @VarClass(paid?.PredictedInsurance, paid?.ActualInsurance)">
                                @FmtVariance(paid?.PredictedInsurance, paid?.ActualInsurance)
                            </td>
                        </tr>

                        <!-- Predicted ¢ Unpaid -->
                        <tr class="row-sub">
                            <td>Predicted ¢ Unpaid</td>
                            <td class="text-end val-cell">@(unpaid?.ClaimCount.ToString("N0") ?? "\u2014")</td>
                            <td class="text-end val-cell">@FmtAmt(unpaid?.PredictedAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(unpaid?.PredictedInsurance)</td>
                            <td class="text-end val-cell">@FmtAmt(unpaid?.ActualAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(unpaid?.ActualInsurance)</td>
                            <td class="text-end val-cell fw-semibold @VarClass(unpaid?.PredictedAllowed, unpaid?.ActualAllowed)">
                                @FmtVariance(unpaid?.PredictedAllowed, unpaid?.ActualAllowed)
                            </td>
                            <td class="text-end val-cell fw-semibold @VarClass(unpaid?.PredictedInsurance, unpaid?.ActualInsurance)">
                                @FmtVariance(unpaid?.PredictedInsurance, unpaid?.ActualInsurance)
                            </td>
                        </tr>

                        <!-- Unpaid ¢ Denied -->
                        <tr class="row-sub-2">
                            <td>Unpaid ¢ Denied</td>
                            <td class="text-end val-cell">@(denied?.ClaimCount.ToString("N0") ?? "\u2014")</td>
                            <td class="text-end val-cell">@FmtAmt(denied?.PredictedAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(denied?.PredictedInsurance)</td>
                            <td class="text-end val-cell">@FmtAmt(denied?.ActualAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(denied?.ActualInsurance)</td>
                            <td class="text-end val-cell fw-semibold @VarClass(denied?.PredictedAllowed, denied?.ActualAllowed)">
                                @FmtVariance(denied?.PredictedAllowed, denied?.ActualAllowed)
                            </td>
                            <td class="text-end val-cell fw-semibold @VarClass(denied?.PredictedInsurance, denied?.ActualInsurance)">
                                @FmtVariance(denied?.PredictedInsurance, denied?.ActualInsurance)
                            </td>
                        </tr>

                        <!-- Unpaid ¢ No Response -->
                        <tr class="row-sub-2">
                            <td>Unpaid ¢ No Response</td>
                            <td class="text-end val-cell">@(noresp?.ClaimCount.ToString("N0") ?? "\u2014")</td>
                            <td class="text-end val-cell">@FmtAmt(noresp?.PredictedAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(noresp?.PredictedInsurance)</td>
                            <td class="text-end val-cell">@FmtAmt(noresp?.ActualAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(noresp?.ActualInsurance)</td>
                            <td class="text-end val-cell fw-semibold @VarClass(noresp?.PredictedAllowed, noresp?.ActualAllowed)">
                                @FmtVariance(noresp?.PredictedAllowed, noresp?.ActualAllowed)
                            </td>
                            <td class="text-end val-cell fw-semibold @VarClass(noresp?.PredictedInsurance, noresp?.ActualInsurance)">
                                @FmtVariance(noresp?.PredictedInsurance, noresp?.ActualInsurance)
                            </td>
                        </tr>

                        <!-- Unpaid ¢ Adjusted -->
                        <tr class="row-sub-2">
                            <td>Unpaid ¢ Adjusted</td>
                            <td class="text-end val-cell">@(adj?.ClaimCount.ToString("N0") ?? "\u2014")</td>
                            <td class="text-end val-cell">@FmtAmt(adj?.PredictedAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(adj?.PredictedInsurance)</td>
                            <td class="text-end val-cell">@FmtAmt(adj?.ActualAllowed)</td>
                            <td class="text-end val-cell">@FmtAmt(adj?.ActualInsurance)</td>
                            <td class="text-end val-cell fw-semibold @VarClass(adj?.PredictedAllowed, adj?.ActualAllowed)">
                                @FmtVariance(adj?.PredictedAllowed, adj?.ActualAllowed)
                            </td>
                            <td class="text-end val-cell fw-semibold @VarClass(adj?.PredictedInsurance, adj?.ActualInsurance)">
                                @FmtVariance(adj?.PredictedInsurance, adj?.ActualInsurance)
                            </td>
                        </tr>


                        @* ?? Prediction Accuracy ?? moved to KPI cards below *@
                    </tbody>
                </table>
            </div>

            <!-- ?? Ratios card strip ???????????????????????????????????? -->
            <div class="ratio-strip">
                <div class="fw-bold mb-2" style="font-size:.75rem;color:#0d1b2a;letter-spacing:.04em">&#128200; RATIOS</div>
                <div class="d-flex flex-wrap gap-2">
                    <div class="ratio-card">
                        <div class="rc-label">Payment Ratio</div>
                        <div class="rc-vals">
                            <span class="rc-val">@FmtPct(sm.PaymentRatioClaim)</span><span class="rc-sub">Claim</span>
                            <span class="rc-val">@FmtPct(sm.PaymentRatioAllowed)</span><span class="rc-sub">Allowed</span>
