@model LabMetricsDashboard.ViewModels.AppUsagePageViewModel
@{
    ViewData["Title"] = "Active Users";
}

<div class="container-fluid px-0 usage-monitor-page">
    <div class="card shadow-sm border-0 active-users-card">
        <div class="card-header bg-white border-0 pt-3 pb-2 d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <h4 class="mb-1">Active Logged-in Users</h4>
                <div class="text-muted small">Shows only users active in the last 20 minutes. Same user from multiple systems/browsers appears as separate sessions.</div>
            </div>
            <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis px-3 py-2">
                @Model.ActiveUsersCount active
            </span>
        </div>
        <div class="card-body pt-2">
            <div class="table-responsive active-users-table-wrap">
                <table class="table table-sm table-hover align-middle active-users-table mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Current Page</th>
                            <th>Location</th>
                            <th>Logged In / Using Since</th>
                            <th>Last Seen</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.ActiveUsers.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-muted py-4 text-center">No active users found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.ActiveUsers)
                        {
                            var activeMinutes = Math.Max(0, (int)Math.Round((DateTime.UtcNow - item.FirstSeenOnUtc).TotalMinutes));
                            var lastSeenAgo = Math.Max(0, (int)Math.Round((DateTime.UtcNow - item.LastSeenOnUtc).TotalSeconds));
                            var statusClass = item.CurrentIdleSeconds >= 300 ? "bg-warning-subtle text-warning-emphasis" : "bg-success-subtle text-success-emphasis";
                            var mapUrl = item.Latitude.HasValue && item.Longitude.HasValue
                                ? $"https://www.google.com/maps?q={item.Latitude.Value:0.000000},{item.Longitude.Value:0.000000}"
                                : string.Empty;

                            <tr>
                                <td>
                                    <div class="fw-bold">@item.UserName</div>
                                    <div class="text-muted small">Device/Browser: @item.BrowserId</div>
                                    <div class="text-muted small">Tab: @item.TabId</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.PageName</div>
                                    <div class="text-muted small text-break">@item.Path</div>
                                </td>
                                <td>
                                    <div>@(string.IsNullOrWhiteSpace(item.LocationText) ? "Location not allowed / unavailable" : item.LocationText)</div>
                                    @if (item.Latitude.HasValue && item.Longitude.HasValue)
                                    {
                                        <div class="small">
                                            <a href="@mapUrl" target="_blank" rel="noopener">Open map</a>
                                            <span class="text-muted ms-1">@item.Latitude.Value.ToString("0.000000"), @item.Longitude.Value.ToString("0.000000")</span>
                                        </div>
                                    }
                                    <div class="text-muted small">IP: @item.IpAddress</div>
                                </td>
                                <td>
                                    <div>@item.FirstSeenOnUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
                                    <div class="text-muted small">@activeMinutes min</div>
                                </td>
                                <td>
                                    <div>@item.LastSeenOnUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
                                    <div class="text-muted small">@lastSeenAgo sec ago</div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @statusClass px-3 py-2">@item.IdleStatus</span>
                                    <div class="text-muted small mt-1">Idle: @item.CurrentIdleSeconds sec</div>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .active-users-card {
        border-radius: 1rem;
    }

    .active-users-table-wrap {
        border: 1px solid #dbe6f3;
        border-radius: .8rem;
        overflow: auto;
        max-height: calc(100vh - 210px);
    }

    .active-users-table thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #0d3b66;
        color: #fff;
        border-color: #164d80;
        white-space: nowrap;
    }

    .active-users-table td,
    .active-users-table th {
        padding: .7rem .8rem;
    }
</style>
