@* ?? Floating Help Bot Chat Widget ??????????????????????????????????? *@

<style>
    /* ?? Floating button ???????????????????????????????????????? */
    .helpbot-fab {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1565c0, #0d47a1);
        color: #fff;
        border: none;
        box-shadow: 0 4px 16px rgba(21, 101, 192, .45);
        cursor: pointer;
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        transition: transform .2s, box-shadow .2s;
    }

    .helpbot-fab:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 24px rgba(21, 101, 192, .6);
    }

    /* ?? Chat panel ????????????????????????????????????????????? */
    .helpbot-panel {
        position: fixed;
        bottom: 92px;
        right: 24px;
        width: 380px;
        max-height: 520px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0, 0, 0, .18);
        z-index: 10001;
        display: none;
        flex-direction: column;
        overflow: hidden;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .helpbot-panel.open {
        display: flex;
    }

    .helpbot-header {
        background: linear-gradient(135deg, #0d1b2a 0%, #1b3a5c 60%, #1565c0 100%);
        color: #fff;
        padding: 14px 18px;
        font-weight: 600;
        font-size: .95rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .helpbot-header i {
        font-size: 1.2rem;
    }

    .helpbot-body {
        flex: 1;
        overflow-y: auto;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-height: 340px;
    }

    .helpbot-msg {
        max-width: 85%;
        padding: 10px 14px;
        border-radius: 14px;
        font-size: .85rem;
        line-height: 1.45;
        word-wrap: break-word;
    }

    .helpbot-msg.bot {
        background: #f0f4f8;
        color: #1a1a2e;
        align-self: flex-start;
        border-bottom-left-radius: 4px;
    }

    .helpbot-msg.user {
        background: linear-gradient(135deg, #1565c0, #1976d2);
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
    }

    .helpbot-suggestions {
        display: flex;
        flex-direction: column;
        gap: 5px;
        margin-top: 4px;
    }

    .helpbot-suggestion-btn {
        background: #e3f2fd;
        border: 1px solid #90caf9;
        border-radius: 10px;
        padding: 6px 12px;
        font-size: .78rem;
        color: #1565c0;
        cursor: pointer;
        text-align: left;
        transition: background .15s;
    }

    .helpbot-suggestion-btn:hover {
        background: #bbdefb;
    }

    .helpbot-footer {
        display: flex;
        border-top: 1px solid #e0e0e0;
        padding: 10px;
        gap: 8px;
    }

    .helpbot-input {
        flex: 1;
        border: 1px solid #cfd8dc;
        border-radius: 10px;
        padding: 8px 12px;
        font-size: .85rem;
        outline: none;
        transition: border-color .15s;
    }

    .helpbot-input:focus {
        border-color: #1565c0;
    }

    .helpbot-send {
        background: #1565c0;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 8px 14px;
        cursor: pointer;
        font-size: .85rem;
        transition: background .15s;
    }

    .helpbot-send:hover {
        background: #0d47a1;
    }

    .helpbot-typing {
        font-size: .8rem;
        color: #90a4ae;
        font-style: italic;
        align-self: flex-start;
    }
</style>

<!-- Floating Action Button -->
<button class="helpbot-fab" id="helpbotFab" title="Help Bot">
    <i class="bi bi-life-preserver"></i>
</button>

<!-- Chat Panel -->
<div class="helpbot-panel" id="helpbotPanel">
    <div class="helpbot-header">
        <i class="bi bi-robot"></i>
        LRN Help Bot
    </div>
    <div class="helpbot-body" id="helpbotBody">
        <div class="helpbot-msg bot">
            <i class="bi bi-hand-wave" style="margin-right:4px;"></i> Hi! I'm the LRN Help Bot. Ask me anything about this application — coding validation, claim data, predictions, and more.
        </div>
        <div class="helpbot-suggestions" id="helpbotInitSuggestions"></div>
    </div>
    <div class="helpbot-footer">
        <input type="text" class="helpbot-input" id="helpbotInput"
               placeholder="Type your question..." autocomplete="off" />
        <button class="helpbot-send" id="helpbotSend">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>
</div>

<script>
(function () {
    const apiBase = '@Url.Content("~/api/helpbot")';
    const fab = document.getElementById('helpbotFab');
    const panel = document.getElementById('helpbotPanel');
        const body = document.getElementById('helpbotBody');
        const input = document.getElementById('helpbotInput');
        const sendBtn = document.getElementById('helpbotSend');
        const initSuggestions = document.getElementById('helpbotInitSuggestions');

        fab.addEventListener('click', function () {
            panel.classList.toggle('open');
            if (panel.classList.contains('open')) {
                input.focus();
                loadTopics();
            }
        });

        sendBtn.addEventListener('click', sendMessage);
        input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') sendMessage();
        });

        let topicsLoaded = false;

        function loadTopics() {
            if (topicsLoaded) return;
            topicsLoaded = true;
            fetch(apiBase + '/topics')
                .then(r => r.json())
                .then(topics => {
                    // Show first 5 as quick-start suggestions
                    var shown = topics.slice(0, 5);
                    shown.forEach(function (q) {
                        var btn = document.createElement('button');
                        btn.className = 'helpbot-suggestion-btn';
                        btn.textContent = q;
                        btn.addEventListener('click', function () {
                            input.value = q;
                            sendMessage();
                        });
                        initSuggestions.appendChild(btn);
                    });
                })
                .catch(function (err) { console.error('HelpBot topics error:', err); });
        }

        function sendMessage() {
            var question = input.value.trim();
            if (!question) return;
            input.value = '';

            // Remove initial suggestions after first message
            initSuggestions.style.display = 'none';

            appendMsg(question, 'user');
            appendTyping();

            fetch(apiBase + '/ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: question })
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    removeTyping();
                    appendMsg(data.answer, 'bot');

                    if (data.suggestions && data.suggestions.length > 0) {
                        var container = document.createElement('div');
                        container.className = 'helpbot-suggestions';

                        data.suggestions.forEach(function (s) {
                            var btn = document.createElement('button');
                            btn.className = 'helpbot-suggestion-btn';
                            btn.textContent = s;
                            btn.addEventListener('click', function () {
                                input.value = s;
                                sendMessage();
                            });
                            container.appendChild(btn);
                        });

                        body.appendChild(container);
                        scrollBottom();
                    }
                })
                .catch(function (err) {
                    removeTyping();
                    appendMsg('Sorry, something went wrong: ' + (err.message || err) + '. Check browser console (F12) for details.', 'bot');
                    console.error('HelpBot error:', err);
                });
        }

        function appendMsg(text, type) {
            var div = document.createElement('div');
            div.className = 'helpbot-msg ' + type;
            div.textContent = text;
            body.appendChild(div);
            scrollBottom();
        }

        function appendTyping() {
            var div = document.createElement('div');
            div.className = 'helpbot-typing';
            div.id = 'helpbotTyping';
            div.textContent = 'Thinking�';
            body.appendChild(div);
            scrollBottom();
        }

        function removeTyping() {
            var el = document.getElementById('helpbotTyping');
            if (el) el.remove();
        }

        function scrollBottom() {
            body.scrollTop = body.scrollHeight;
        }
    })();
</script>
