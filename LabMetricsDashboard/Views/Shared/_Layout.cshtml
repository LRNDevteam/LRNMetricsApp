    <div class="container-fluid px-4 pt-3">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-2 mt-3">
        <div class="container-fluid px-4">
            <small class="text-muted">&copy; 2026 Lab Revenue Intelligence</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Show the loader whenever a lab-selector dropdown changes.
        // Any <select data-lab-selector> on the page triggers this.
        document.addEventListener('change', function (e) {
        const sel = e.target;
        if (!sel.matches('[data-lab-selector]')) return;
        const labName = sel.options[sel.selectedIndex]?.text ?? 'selected lab';
        const text = document.getElementById('lmd-loader-text');
        if (text) text.textContent = 'Loading ' + labName + '…';
        document.getElementById('lmd-loader').classList.add('active');
        });

        // Also show loader for Apply-Filter form submissions that contain a lab param.
        document.addEventListener('submit', function (e) {
        const form = e.target;
        if (!form.matches('[data-lab-form]')) return;
        const labInput = form.querySelector('[name="lab"]');
        const labName = labInput
        ? (labInput.tagName === 'SELECT'
        ? labInput.options[labInput.selectedIndex]?.text
        : labInput.value)
        : '';
        const text = document.getElementById('lmd-loader-text');
        if (text) text.textContent = labName ? 'Loading ' + labName + '…' : 'Loading…';
        document.getElementById('lmd-loader').classList.add('active');
        });

        // Hide loader when navigating back (bfcache restore).
        window.addEventListener('pageshow', function (e) {
        if (e.persisted) {
        document.getElementById('lmd-loader').classList.remove('active');
        }
        });

        // Reusable Excel download with loading overlay.
        // Shows the full-screen loader, fetches the file as a blob,
        // triggers a browser download, then hides the loader.
        window.lmdExcelDownload = function (url) {
        var loader = document.getElementById('lmd-loader');
        var text = document.getElementById('lmd-loader-text');
        if (text) text.textContent = 'Generating Excel\u2026';
        if (loader) loader.classList.add('active');

        fetch(url, { credentials: 'same-origin' })
        .then(function (resp) {
        if (!resp.ok) throw new Error('Export failed (' + resp.status + ')');
        var cd = resp.headers.get('content-disposition') || '';
        var match = cd.match(/filename[^;=\n]*=(['"]?)([^'"\n;]+)\1/);
        var filename = match ? match[2] : 'export.xlsx';
        return resp.blob().then(function (blob) { return { blob: blob, filename: filename }; });
        })
        .then(function (result) {
        var a = document.createElement('a');
        a.href = URL.createObjectURL(result.blob);
        a.download = result.filename;
        document.body.appendChild(a);
        a.click();
        setTimeout(function () { URL.revokeObjectURL(a.href); a.remove(); }, 100);
        })
        .catch(function (err) {
        console.error('Excel download error:', err);
        alert('Excel export failed. Please try again.');
        })
        .finally(function () {
        if (loader) loader.classList.remove('active');
        });
        };

        // ── Navbar lab selector ─────────────────────────────────────
        (function () {
        var btn = document.getElementById('navLabBtn');
        var panel = document.getElementById('navLabPanel');
        var search = document.getElementById('navLabSearch');
        var list = document.getElementById('navLabList');
        if (!btn || !panel) return;

        btn.addEventListener('click', function (e) {
        e.stopPropagation();
        panel.classList.toggle('open');
        if (panel.classList.contains('open') && search) {
        search.value = '';
        search.focus();
        list.querySelectorAll('a').forEach(function (a) { a.classList.remove('nav-lab-hidden'); });
        }
        });

        if (search) {
        search.addEventListener('input', function () {
        var q = this.value.toLowerCase();
        list.querySelectorAll('a').forEach(function (a) {
        a.classList.toggle('nav-lab-hidden', q.length > 0 && a.textContent.toLowerCase().indexOf(q) === -1);
        });
        });
        search.addEventListener('click', function (e) { e.stopPropagation(); });
        }

        panel.addEventListener('click', function (e) { e.stopPropagation(); });

        // When a lab is clicked, navigate to the current page with the new lab
        list.addEventListener('click', function (e) {
        var a = e.target.closest('a[data-lab]');
        if (!a) return;
        e.preventDefault();
        var newLab = a.getAttribute('data-lab');
        // Navigate to current path with only the lab param (clear filters)
        var url = new URL(window.location.pathname, window.location.origin);
        url.searchParams.set('lab', newLab);
        // Show loader
        var text = document.getElementById('lmd-loader-text');
        if (text) text.textContent = 'Loading ' + newLab + '\u2026';
        document.getElementById('lmd-loader').classList.add('active');
        window.location.href = url.toString();
        });

        // Close on outside click
        document.addEventListener('click', function () {
        panel.classList.remove('open');
        });
        })();
    </script>

    <script>
        (function () {
        const heartbeatUrl = '@Url.Action("Heartbeat", "Usage")';
        if (!heartbeatUrl || !window.fetch || !window.sessionStorage) {
        return;
        }

        const tabStorageKey = 'lmd.usage.tabid';
        let tabId = sessionStorage.getItem(tabStorageKey);
        if (!tabId) {
        tabId = (window.crypto && window.crypto.randomUUID)
        ? window.crypto.randomUUID()
        : ('tab-' + Math.random().toString(36).slice(2) + Date.now().toString(36));
        sessionStorage.setItem(tabStorageKey, tabId);
        }

        let lastActionAt = Date.now();
        let geo = null;
        let lastSent = 0;
        let pendingLocationSend = false;

        function pageTitle() {
        return (document.title || '').replace(/\s*-\s*Lab Revenue Intelligence\s*$/i, '').trim() || 'Unknown';
        }

        function currentIdleSeconds() {
        return Math.max(0, Math.floor((Date.now() - lastActionAt) / 1000));
        }

        function markActivity() {
        lastActionAt = Date.now();
        }

        ['click', 'keydown', 'mousemove', 'scroll', 'touchstart', 'focus'].forEach(function (evt) {
        window.addEventListener(evt, markActivity, { passive: true });
        });

        document.addEventListener('visibilitychange', function () {
        if (!document.hidden) {
        markActivity();
        }
        sendHeartbeat(true);
        });

        function buildPayload() {
        return {
        tabId: tabId,
        pageName: pageTitle(),
        path: window.location.pathname,
        queryString: window.location.search || '',
        idleSeconds: currentIdleSeconds(),
        latitude: geo ? geo.latitude : null,
        longitude: geo ? geo.longitude : null,
        locationText: geo ? geo.locationText : null
        };
        }

        function sendHeartbeat(force) {
        const now = Date.now();
        if (!force && (now - lastSent) < 12000) {
        return;
        }
        lastSent = now;

        const body = JSON.stringify(buildPayload());
        fetch(heartbeatUrl, {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'X-Lmd-TabId': tabId
        },
        body: body,
        credentials: 'same-origin',
        keepalive: true
        }).catch(function () { });
        }

        window.addEventListener('pagehide', function () {
        const body = JSON.stringify(buildPayload());
        if (navigator.sendBeacon) {
        const blob = new Blob([body], { type: 'application/json' });
        navigator.sendBeacon(heartbeatUrl, blob);
        } else {
        sendHeartbeat(true);
        }
        });

        if (navigator.permissions && navigator.geolocation) {
        navigator.permissions.query({ name: 'geolocation' }).then(function (result) {
        if (result.state === 'granted') {
        navigator.geolocation.getCurrentPosition(function (position) {
        geo = {
        latitude: Number(position.coords.latitude.toFixed(6)),
        longitude: Number(position.coords.longitude.toFixed(6)),
        locationText: Number(position.coords.latitude).toFixed(6) + ', ' + Number(position.coords.longitude).toFixed(6)
        };
        pendingLocationSend = true;
        sendHeartbeat(true);
        }, function () { }, { enableHighAccuracy: false, maximumAge: 600000, timeout: 8000 });
        }
        }).catch(function () { });
        }

        sendHeartbeat(true);
        window.setInterval(function () {
        sendHeartbeat(false);
        }, 15000);
        })();
    </script>

    @await Html.PartialAsync("_HelpBotWidget")
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
