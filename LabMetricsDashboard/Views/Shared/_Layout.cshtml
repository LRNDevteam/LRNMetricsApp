@using LabMetricsDashboard.Models
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lab Revenue Intelligence</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LabMetricsDashboard.styles.css" asp-append-version="true" />
    <style>
        /* ── Global overrides ───────────────────────────────────────── */
        body {
            background-color: #f0f4f8;
        }

        /* ── Navbar ─────────────────────────────────────────────────── */
        .lmd-navbar {
            background: linear-gradient(135deg, #0d1b2a 0%, #1b3a5c 60%, #1565c0 100%);
            box-shadow: 0 2px 12px rgba(0, 0, 0, .35);
        }

        .lmd-navbar .navbar-brand {
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: .03em;
            color: #fff !important;
        }

        .lmd-navbar .navbar-brand span {
            color: #64b5f6;
        }

        .lmd-navbar .nav-link,
        .lmd-navbar .dropdown-toggle {
            color: rgba(255, 255, 255, .85) !important;
            font-size: .9rem;
        }

        .lmd-navbar .nav-link:hover,
        .lmd-navbar .dropdown-toggle:hover {
            color: #fff !important;
        }

        .lmd-navbar .nav-link.active {
            color: #64b5f6 !important;
            font-weight: 600;
        }

        .lmd-navbar .dropdown-menu {
            background: #1b3a5c;
            border: 1px solid rgba(255, 255, 255, .12);
        }

        .lmd-navbar .dropdown-item {
            color: rgba(255, 255, 255, .85);
            font-size: .88rem;
        }

        .lmd-navbar .dropdown-item:hover {
            background: rgba(255, 255, 255, .1);
            color: #fff;
        }

        .lmd-navbar .navbar-toggler {
            border-color: rgba(255, 255, 255, .3);
        }

        /* ── Breadcrumb bar ──────────────────────────────────────────── */
        .lmd-breadcrumb {
            background: linear-gradient(90deg, #1565c0 0%, #0097a7 100%);
            padding: .45rem 1.5rem;
            font-size: .82rem;
        }

        .lmd-breadcrumb a {
            color: rgba(255, 255, 255, .78);
            text-decoration: none;
        }

        .lmd-breadcrumb a:hover {
            color: #fff;
            text-decoration: underline;
        }

        .lmd-breadcrumb .bc-sep {
            color: rgba(255, 255, 255, .45);
            margin: 0 .4rem;
        }

        .lmd-breadcrumb .bc-current {
            color: #fff;
            font-weight: 600;
        }

        .lmd-breadcrumb .bc-lab {
            background: rgba(255, 255, 255, .18);
            border: 1px solid rgba(255, 255, 255, .3);
            border-radius: 20px;
            padding: .1em .75em;
            color: #fff;
            font-weight: 700;
            margin-left: .5rem;
            letter-spacing: .02em;
        }

        /* ── Full-screen loading overlay ─────────────────────────────── */
        #lmd-loader {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(13, 27, 42, .72);
            backdrop-filter: blur(3px);
            z-index: 9999;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1.2rem;
        }

        #lmd-loader.active {
            display: flex;
        }

        .lmd-spinner {
            width: 56px;
            height: 56px;
            border: 5px solid rgba(255, 255, 255, .2);
            border-top-color: #64b5f6;
            border-radius: 50%;
            animation: lmd-spin .75s linear infinite;
        }

        @@keyframes lmd-spin {
            to {
                transform: rotate(360deg);
            }
        }

        .lmd-loader-text {
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: .04em;
        }

        /* ── Footer ──────────────────────────────────────────────────── */
        footer {
            background: #e8edf3;
            border-top: 1px solid #cdd5e0 !important;
        }
    </style>
</head>

<body>

    <!-- Full-screen loader overlay -->
    <div id="lmd-loader" role="status" aria-live="polite" aria-label="Loading">
        <div class="lmd-spinner"></div>
        <div class="lmd-loader-text" id="lmd-loader-text">Loading lab data…</div>
    </div>

    <header>
        <!-- Main navbar -->
        <nav class="navbar navbar-expand-sm lmd-navbar mb-0 py-2">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img src="~/images/LRN-White-Logo-footer-1-1.png" alt="LRN Logo"
                         style="height:36px;width:auto;object-fit:contain" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">&#8962; Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">&#9700; Revenue Dashboard</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                &#9741; Reports
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Dashboard" asp-action="ClaimLevel">
                                        Claim Level Details
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Dashboard" asp-action="LineLevel">
                                        Line Level Details
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="DenialDashboard" asp-action="Index">&#9700; Denial Dashboard</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                &#128202; Analytics
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Prediction" asp-action="Index">
                                        &#128202; Prediction Analysis
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Prediction" asp-action="ForecastingSummary">
                                        &#128197; Forecasting Summary
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.15)"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Coding" asp-action="Summary">
                                        &#9998; Coding Summary
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Dashboard" asp-action="ClinicSummary">
                                        &#127973; Clinic Summary
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Dashboard" asp-action="SalesRepSummary">
                                        &#128100; Sales Rep Summary
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Breadcrumb bar — only shown when a lab is selected -->
        @{
            var selectedLab = ViewData["SelectedLab"] as string;
            var pageLabel   = ViewData["PageLabel"]   as string;
        }
        @if (!string.IsNullOrEmpty(selectedLab))
        {
            <div class="lmd-breadcrumb d-flex align-items-center flex-wrap gap-1">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span class="bc-sep">›</span>
                <a asp-controller="Dashboard" asp-action="Index" asp-route-lab="@selectedLab">Revenue Dashboard</a>
                @if (!string.IsNullOrEmpty(pageLabel))
                {
                    <span class="bc-sep">›</span>
                    <span class="bc-current">@pageLabel</span>
                }
                <span class="bc-lab">&#9670; @selectedLab</span>
            </div>
        }
    </header>

    <div class="container-fluid px-4 pt-3">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-2 mt-3">
        <div class="container-fluid px-4">
            <small class="text-muted">&copy; 2026 Lab Revenue Intelligence</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Show the loader whenever a lab-selector dropdown changes.
        // Any <select data-lab-selector> on the page triggers this.
        document.addEventListener('change', function (e) {
            const sel = e.target;
            if (!sel.matches('[data-lab-selector]')) return;
            const labName = sel.options[sel.selectedIndex]?.text ?? 'selected lab';
            const text = document.getElementById('lmd-loader-text');
            if (text) text.textContent = 'Loading ' + labName + '…';
            document.getElementById('lmd-loader').classList.add('active');
        });

        // Also show loader for Apply-Filter form submissions that contain a lab param.
        document.addEventListener('submit', function (e) {
            const form = e.target;
            if (!form.matches('[data-lab-form]')) return;
            const labInput = form.querySelector('[name="lab"]');
            const labName  = labInput
                ? (labInput.tagName === 'SELECT'
                    ? labInput.options[labInput.selectedIndex]?.text
                    : labInput.value)
                : '';
            const text = document.getElementById('lmd-loader-text');
            if (text) text.textContent = labName ? 'Loading ' + labName + '…' : 'Loading…';
            document.getElementById('lmd-loader').classList.add('active');
        });

        // Hide loader when navigating back (bfcache restore).
        window.addEventListener('pageshow', function (e) {
            if (e.persisted) {
                document.getElementById('lmd-loader').classList.remove('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
