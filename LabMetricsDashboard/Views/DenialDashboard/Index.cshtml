<script>
    document.addEventListener('DOMContentLoaded', function () {
        const loader = document.getElementById('pageLoader');
        const activeTabInput = document.getElementById('activeTabInput');
        const tabButtons = document.querySelectorAll('#dashboardTabs button[data-bs-toggle="pill"]');
        const form = document.getElementById('dashboardFilterForm');
        const exportButton = document.getElementById('exportExcelBtn');
        const labSelect = document.getElementById('labSelect');
        const filterCollapse = document.getElementById('dashboardFiltersCollapse');
        const filterToggleText = document.querySelector('#filterCollapseToggle .filter-toggle-text');
        const filterStateKey = 'denialDashboard.filtersCollapsed';

        function showLoader() {
            if (loader) {
                loader.classList.remove('hidden');
            }
        }

        function updateFilterToggleLabel(isShown) {
            if (filterToggleText) {
                filterToggleText.textContent = isShown ? 'Hide Filters' : 'Show Filters';
            }
        }

        if (filterCollapse) {
            const savedState = localStorage.getItem(filterStateKey);
            if (savedState === 'true') {
                filterCollapse.classList.remove('show');
                updateFilterToggleLabel(false);
            }
            else {
                updateFilterToggleLabel(true);
            }

            filterCollapse.addEventListener('shown.bs.collapse', function () {
                localStorage.setItem(filterStateKey, 'false');
                updateFilterToggleLabel(true);
            });

            filterCollapse.addEventListener('hidden.bs.collapse', function () {
                localStorage.setItem(filterStateKey, 'true');
                updateFilterToggleLabel(false);
            });
        }

        function navigateToTab(nextTab) {
            if (!form || !nextTab) {
                return;
            }

            if (activeTabInput) {
                activeTabInput.value = nextTab;
            }

            const pageInput = form.querySelector('input[name="Page"]');
            const insightPageInput = form.querySelector('input[name="InsightPage"]');
            const lineItemPageInput = form.querySelector('input[name="LineItemPage"]');
            if (pageInput) pageInput.value = '1';
            if (insightPageInput) insightPageInput.value = '1';
            if (lineItemPageInput) lineItemPageInput.value = '1';

            const formData = new FormData(form);
            formData.set('ActiveTab', nextTab);
            formData.set('Page', '1');
            formData.set('InsightPage', '1');
            formData.set('LineItemPage', '1');

            const params = new URLSearchParams();
            formData.forEach(function (value, key) {
                if (value === null || value === undefined) {
                    return;
                }

                const text = String(value).trim();
                if (text === '') {
                    return;
                }

                params.append(key, text);
            });

            showLoader();
            window.location.assign(form.action + '?' + params.toString());
        }

        tabButtons.forEach(function (button) {
            button.addEventListener('click', function (event) {
                const target = button.getAttribute('data-bs-target');
                if (!target) {
                    return;
                }

                const nextTab = target.replace('#', '');
                const currentActive = document.querySelector('#dashboardTabs .nav-link.active');
                const currentTarget = currentActive ? ((currentActive.getAttribute('data-bs-target') || '').replace('#', '')) : '';
                if (nextTab === currentTarget) {
                    return;
                }

                event.preventDefault();
                navigateToTab(nextTab);
            });

            button.addEventListener('keydown', function (event) {
                if (event.key === 'Enter' || event.key === ' ') {
                    const target = button.getAttribute('data-bs-target');
                    if (!target) {
                        return;
                    }

                    event.preventDefault();
                    navigateToTab(target.replace('#', ''));
                }
            });
        });

        if (form) {
            form.addEventListener('submit', function () {
                showLoader();
            });
        }

        document.querySelectorAll('.js-loader-link').forEach(function (link) {
            link.addEventListener('click', function () {
                showLoader();
            });
        });

        document.querySelectorAll('.js-loader-button').forEach(function (button) {
            button.addEventListener('click', function () {
                if (!button.id || button.id !== 'exportExcelBtn') {
                    showLoader();
                }
            });
        });

        if (exportButton) {
            exportButton.addEventListener('click', function () {
                if (!form) {
                    return;
                }

                const formData = new FormData(form);
                const labId = formData.get('LabId');
                if (!labId) {
                    alert('Please select a lab first.');
                    return;
                }

                const params = new URLSearchParams();
                formData.forEach(function (value, key) {
                    if (value !== null && value !== undefined && value !== '') {
                        params.append(key, value.toString());
                    }
                });

                showLoader();
                const url = '@Url.Action("ExportToExcel", "DenialDashboard")' + '?' + params.toString();
                window.location.href = url;
                setTimeout(function () {
                    if (loader) {
                        loader.classList.add('hidden');
                    }
                }, 3000);
            });
        }

        document.querySelectorAll('.task-upload-form').forEach(function (formElement) {
            const trigger = formElement.querySelector('.task-upload-trigger');
            const input = formElement.querySelector('.task-upload-input');
            if (!trigger || !input) return;

            trigger.addEventListener('click', function () {
                input.click();
            });

            input.addEventListener('change', function () {
                if (!input.files || input.files.length === 0) {
                    return;
                }
                showLoader();
                formElement.submit();
            });
        });

        document.querySelectorAll('.table-search-input').forEach(function (input) {
            input.addEventListener('input', function () {
                const tableId = input.getAttribute('data-target-table');
                const table = document.getElementById(tableId);
                if (!table) return;
                const searchText = (input.value || '').trim().toLowerCase();
                table.querySelectorAll('tbody tr').forEach(function (row) {
                    const text = (row.innerText || '').toLowerCase();
                    row.style.display = text.includes(searchText) ? '' : 'none';
                });
            });
        });

        document.querySelectorAll('.accordion-search-input').forEach(function (input) {
            input.addEventListener('input', function () {
                const accordionId = input.getAttribute('data-target-accordion');
                const accordion = document.getElementById(accordionId);
                if (!accordion) return;
                const searchText = (input.value || '').trim().toLowerCase();
                accordion.querySelectorAll('.claim-group-item').forEach(function (item) {
                    const text = (item.innerText || '').toLowerCase();
                    item.style.display = text.includes(searchText) ? '' : 'none';
                });
            });
        });

        const autocompleteUrl = '@Url.Action("GetFilterAutocompleteOptions", "DenialDashboard")';
        const autocompleteCachePrefix = 'denial-dashboard:autocomplete:';
        const labSelect2 = form ? form.querySelector('select[name="LabId"]') : null;

        function uniqueValues(values) {
            const seen = new Set();
            return (values || []).filter(function (value) {
                const normalized = (value || '').trim();
                if (!normalized) return false;
                const key = normalized.toLowerCase();
                if (seen.has(key)) return false;
                seen.add(key);
                return true;
            });
        }

        function summarizeSelection(values, placeholder) {
            const selected = uniqueValues(values);
            if (!selected.length) return placeholder;
            if (selected.length === 1) return selected[0];
            if (selected.length === 2) return selected.join(', ');
            return selected.length + ' selected';
        }

        function initMultiSelect(container) {
            const name = container.dataset.name;
            const placeholder = container.dataset.placeholder || 'Select';
            const parsedOptions = JSON.parse(container.dataset.options || '[]');
            const parsedSelected = JSON.parse(container.dataset.selected || '[]');
            let options = uniqueValues(parsedOptions);
            let selected = uniqueValues(parsedSelected);

            container.innerHTML = '';
            container.classList.add('msf');
            container.innerHTML = `
                <input type="hidden" name="${name}" class="msf-hidden" />
                <button type="button" class="form-select filter-select text-start msf-toggle"></button>
                <div class="msf-menu shadow-sm d-none">
                    <div class="msf-search-wrap"><input type="text" class="form-control form-control-sm msf-search" placeholder="Search..." autocomplete="off" /></div>
                    <div class="msf-actions">
                        <button type="button" class="btn btn-link btn-sm p-0 msf-select-all">Select all</button>
                        <button type="button" class="btn btn-link btn-sm p-0 msf-clear">Clear</button>
                    </div>
                    <div class="msf-options"></div>
                </div>`;

            const hiddenInput = container.querySelector('.msf-hidden');
            const toggle = container.querySelector('.msf-toggle');
            const menu = container.querySelector('.msf-menu');
            const search = container.querySelector('.msf-search');
            const optionsWrap = container.querySelector('.msf-options');
            const selectAllButton = container.querySelector('.msf-select-all');
            const clearButton = container.querySelector('.msf-clear');

            function syncHidden() {
                hiddenInput.value = uniqueValues(selected).join('|');
                toggle.textContent = summarizeSelection(selected, placeholder);
            }

            function renderOptions(filterText) {
                const term = (filterText || '').trim().toLowerCase();
                const optionList = term
                    ? options.filter(function (value) { return value.toLowerCase().includes(term); })
                    : options.slice();

                optionsWrap.innerHTML = '';
                if (!optionList.length) {
                    optionsWrap.innerHTML = '<div class="msf-empty">No matches</div>';
                    return;
                }

                optionList.forEach(function (value) {
                    const row = document.createElement('label');
                    row.className = 'msf-option';
                    const checked = selected.some(function (item) { return item.toLowerCase() === value.toLowerCase(); });
                    row.innerHTML = `<input type="checkbox" value="${value.replace(/"/g, '&quot;')}" ${checked ? 'checked' : ''} /> <span>${value}</span>`;
                    const input = row.querySelector('input');
                    input.addEventListener('change', function () {
                        if (input.checked) {
                            selected.push(value);
                        } else {
                            selected = selected.filter(function (item) { return item.toLowerCase() !== value.toLowerCase(); });
                        }
                        selected = uniqueValues(selected);
                        syncHidden();
                    });
                    optionsWrap.appendChild(row);
                });
            }

            function setOptions(nextOptions) {
                options = uniqueValues([].concat(nextOptions || [], selected));
                renderOptions(search.value);
                syncHidden();
            }

            toggle.addEventListener('click', function () {
                document.querySelectorAll('.msf-menu').forEach(function (item) {
                    if (item !== menu) item.classList.add('d-none');
                });
                menu.classList.toggle('d-none');
                if (!menu.classList.contains('d-none')) {
                    search.focus();
                }
            });

            search.addEventListener('input', function () {
                renderOptions(search.value);
            });

            selectAllButton.addEventListener('click', function () {
                selected = uniqueValues(options.slice());
                renderOptions(search.value);
                syncHidden();
            });

            clearButton.addEventListener('click', function () {
                selected = [];
                renderOptions(search.value);
                syncHidden();
            });

            container._multiSelect = { setOptions: setOptions, getSelected: function () { return selected.slice(); } };
            renderOptions('');
            syncHidden();
        }

        document.querySelectorAll('.multi-select-filter').forEach(initMultiSelect);

        document.addEventListener('click', function (event) {
            document.querySelectorAll('.multi-select-filter').forEach(function (container) {
                if (!container.contains(event.target)) {
                    const menu = container.querySelector('.msf-menu');
                    if (menu) menu.classList.add('d-none');
                }
            });
        });

        function getAutocompleteLabId() {
            return labSelect2 ? (labSelect2.value || '').trim() : '';
        }

        function applyAutocompletePayload(payload) {
            if (!payload) return;

            const payloadMap = {
                payerNames: payload.payerNames || payload.PayerNames || [],
                payerTypes: payload.payerTypes || payload.PayerTypes || [],
                panelNames: payload.panelNames || payload.PanelNames || [],
                referringProviders: payload.referringProviders || payload.ReferringProviders || [],
                clinicNames: payload.clinicNames || payload.ClinicNames || [],
                salesRepnames: payload.salesRepnames || payload.SalesRepnames || []
            };

            document.querySelectorAll('.remote-multi-select').forEach(function (container) {
                const key = container.dataset.remoteKey;
                if (container._multiSelect && payloadMap[key]) {
                    container._multiSelect.setOptions(payloadMap[key]);
                }
            });
        }

        async function loadFilterAutocomplete(forceRefresh) {
            const labId = getAutocompleteLabId();
            if (!labId) return;

            const cacheKey = autocompleteCachePrefix + labId;
            if (!forceRefresh) {
                const cached = localStorage.getItem(cacheKey);
                if (cached) {
                    try {
                        applyAutocompletePayload(JSON.parse(cached));
                        return;
                    } catch (error) {
                        localStorage.removeItem(cacheKey);
                    }
                }
            }

            try {
                const response = await fetch(autocompleteUrl + '?labId=' + encodeURIComponent(labId), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (!response.ok) return;

                const payload = await response.json();
                localStorage.setItem(cacheKey, JSON.stringify(payload));
                applyAutocompletePayload(payload);
            } catch (error) {
                console.warn('Unable to load filter autocomplete values.', error);
            }
        }

        if (labSelect) {
            const loadAutocompleteIfVisible = function (forceRefresh) {
                const collapseHidden = filterCollapse && !filterCollapse.classList.contains('show');
                if (collapseHidden) {
                    return;
                }
                loadFilterAutocomplete(forceRefresh);
            };

            loadAutocompleteIfVisible(false);

            if (filterCollapse) {
                filterCollapse.addEventListener('shown.bs.collapse', function () {
                    loadAutocompleteIfVisible(false);
                });
            }

            labSelect.addEventListener('change', function () {
                loadAutocompleteIfVisible(true);
            });
        }

        function parseSortableValue(value) {
            const raw = (value || '').trim();
            const cleaned = raw.replace(/[$,%]/g, '').replace(/,/g, '').trim();
            const numeric = Number(cleaned);
            if (cleaned !== '' && !Number.isNaN(numeric)) {
                return numeric;
            }

            const parsedDate = Date.parse(raw);
            if (!Number.isNaN(parsedDate)) {
                return parsedDate;
            }

            return raw.toLowerCase();
        }

        document.querySelectorAll('table.sortable-table').forEach(function (table) {
            const headers = table.querySelectorAll('thead th');
            const tbody = table.querySelector('tbody');
            if (!tbody) return;

            headers.forEach(function (header, index) {
                header.classList.add('sortable-header');
                header.setAttribute('role', 'button');
                header.setAttribute('tabindex', '0');
                header.setAttribute('title', 'Sort');

                function sortTable() {
                    const currentDirection = header.getAttribute('data-sort-direction') === 'asc' ? 'asc' : 'desc';
                    const nextDirection = currentDirection === 'asc' ? 'desc' : 'asc';
                    headers.forEach(function (th) {
                        th.removeAttribute('data-sort-direction');
                        th.classList.remove('sorted-asc', 'sorted-desc');
                    });
                    header.setAttribute('data-sort-direction', nextDirection);
                    header.classList.add(nextDirection === 'asc' ? 'sorted-asc' : 'sorted-desc');

                    const rows = Array.from(tbody.querySelectorAll('tr')).filter(function (row) {
                        return !row.querySelector('td[colspan]');
                    });

                    rows.sort(function (a, b) {
                        const aText = a.children[index] ? a.children[index].innerText : '';
                        const bText = b.children[index] ? b.children[index].innerText : '';
                        const aValue = parseSortableValue(aText);
                        const bValue = parseSortableValue(bText);

                        if (aValue < bValue) return nextDirection === 'asc' ? -1 : 1;
                        if (aValue > bValue) return nextDirection === 'asc' ? 1 : -1;
                        return 0;
                    });

                    rows.forEach(function (row) {
                        tbody.appendChild(row);
                    });
                }

                header.addEventListener('click', sortTable);
                header.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        sortTable();
                    }
                });
            });
        });
    });
</script>