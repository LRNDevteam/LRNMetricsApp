@using System.Linq
@using System.Globalization
@using System.Text.Json
@model DashboardPageViewModel
@{
    var usd = CultureInfo.GetCultureInfo("en-US");
    string Money(decimal? amount) => (amount ?? 0m).ToString("C2", usd);
    string PercentWidth(decimal percentage) => Math.Clamp((double)percentage, 0d, 100d).ToString("0.#", CultureInfo.InvariantCulture);
    IReadOnlyList<string> SelectedValues(string? raw, bool treatAllAsEmpty = false)
    {
        if (string.IsNullOrWhiteSpace(raw)) return Array.Empty<string>();

        var items = raw.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (treatAllAsEmpty && items.Any(x => x.Equals("(All)", StringComparison.OrdinalIgnoreCase)))
        {
            return Array.Empty<string>();
        }

        return items;
    }
    string SelectedSummary(string? raw, bool treatAllAsEmpty = false)
    {
        var items = SelectedValues(raw, treatAllAsEmpty);
        if (items.Count == 0) return string.Empty;
        return string.Join(", ", items);
    }
    ViewData["Title"] = "Denial Dashboard";
    var today = DateTime.Today;
    var activeTab = Model.Filters.ActiveTab;
    var activeFilters = new List<KeyValuePair<string, string?>>
{
    new("Lab", string.IsNullOrWhiteSpace(Model.CurrentLabName) ? "-" : Model.CurrentLabName),
    new("Status", SelectedSummary(Model.Filters.Status, true)),
    new("Priority", SelectedSummary(Model.Filters.Priority, true)),
    new("Action Category", SelectedSummary(Model.Filters.ActionCategory, true)),
    new("SLA Deadline", SelectedSummary(Model.Filters.Deadline, true)),
    new("Classification", SelectedSummary(Model.Filters.Classification, true)),
    new("Payer", SelectedSummary(Model.Filters.PayerName)),
    new("Payer Type", SelectedSummary(Model.Filters.PayerType)),
    new("Panel", SelectedSummary(Model.Filters.PanelName)),
    new("Referring Provider", SelectedSummary(Model.Filters.ReferringProvider)),
    new("Clinic", SelectedSummary(Model.Filters.ClinicName)),
    new("Sales Rep", SelectedSummary(Model.Filters.SalesRepname)),
    new("DOS From", Model.Filters.DateOfServiceFrom?.ToString("dd MMM yyyy")),
    new("DOS To", Model.Filters.DateOfServiceTo?.ToString("dd MMM yyyy")),
    new("First Billed From", Model.Filters.FirstBilledDateFrom?.ToString("dd MMM yyyy")),
    new("First Billed To", Model.Filters.FirstBilledDateTo?.ToString("dd MMM yyyy")),
    new("Denial Date From", Model.Filters.DenialDateFrom?.ToString("dd MMM yyyy")),
    new("Denial Date To", Model.Filters.DenialDateTo?.ToString("dd MMM yyyy"))
}
    .Where(x => !string.IsNullOrWhiteSpace(x.Value) && x.Value != "(All)")
    .ToList();
    string StatusBadge(string status) => status switch
    {
        "Open" => "badge-soft-primary",
        "In Progress" => "badge-soft-warning",
        "Completed" => "badge-soft-success",
        "On Hold" => "badge-soft-secondary",
        "Escalated" => "badge-soft-danger",
        "Closed" => "badge-soft-dark",
        _ => "badge-soft-info"
    };
    string PriorityBadge(string priority) => priority switch
    {
        "High" => "badge-soft-danger",
        "Medium" => "badge-soft-warning",
        "Low" => "badge-soft-success",
        _ => "badge-soft-info"
    };
    string SlaBadge(string sla) => sla switch
    {
        "Overdue" => "badge-soft-danger",
        "Due Soon" => "badge-soft-warning",
        "Met" => "badge-soft-success",
        _ => "badge-soft-primary"
    };
    string RecordsPageUrl(int page, string? tabOverride = null) => Url.Action("Index", "DenialDashboard", new
    {
        LabId = Model.Filters.LabId,
        Status = Model.Filters.Status,
        Priority = Model.Filters.Priority,
        ActionCategory = Model.Filters.ActionCategory,
        Deadline = Model.Filters.Deadline,
        Classification = Model.Filters.Classification,
        SalesRepname = Model.Filters.SalesRepname,
        ClinicName = Model.Filters.ClinicName,
        ReferringProvider = Model.Filters.ReferringProvider,
        PayerName = Model.Filters.PayerName,
        PayerType = Model.Filters.PayerType,
        PanelName = Model.Filters.PanelName,
        FirstBilledDateFrom = Model.Filters.FirstBilledDateFrom?.ToString("yyyy-MM-dd"),
        FirstBilledDateTo = Model.Filters.FirstBilledDateTo?.ToString("yyyy-MM-dd"),
        DateOfServiceFrom = Model.Filters.DateOfServiceFrom?.ToString("yyyy-MM-dd"),
        DateOfServiceTo = Model.Filters.DateOfServiceTo?.ToString("yyyy-MM-dd"),
        DenialDateFrom = Model.Filters.DenialDateFrom?.ToString("yyyy-MM-dd"),
        DenialDateTo = Model.Filters.DenialDateTo?.ToString("yyyy-MM-dd"),
        ActiveTab = tabOverride ?? activeTab,
        Page = page,
        PageSize = Model.Filters.PageSize,
        InsightPage = Model.Filters.InsightPage,
        InsightPageSize = Model.Filters.InsightPageSize,
        LineItemPage = Model.Filters.LineItemPage,
        LineItemPageSize = Model.Filters.LineItemPageSize
    }) ?? "#";
    string InsightPageUrl(int page) => Url.Action("Index", "DenialDashboard", new
    {
        LabId = Model.Filters.LabId,
        Status = Model.Filters.Status,
        Priority = Model.Filters.Priority,
        ActionCategory = Model.Filters.ActionCategory,
        Deadline = Model.Filters.Deadline,
        Classification = Model.Filters.Classification,
        SalesRepname = Model.Filters.SalesRepname,
        ClinicName = Model.Filters.ClinicName,
        ReferringProvider = Model.Filters.ReferringProvider,
        PayerName = Model.Filters.PayerName,
        PayerType = Model.Filters.PayerType,
        PanelName = Model.Filters.PanelName,
        FirstBilledDateFrom = Model.Filters.FirstBilledDateFrom?.ToString("yyyy-MM-dd"),
        FirstBilledDateTo = Model.Filters.FirstBilledDateTo?.ToString("yyyy-MM-dd"),
        DateOfServiceFrom = Model.Filters.DateOfServiceFrom?.ToString("yyyy-MM-dd"),
        DateOfServiceTo = Model.Filters.DateOfServiceTo?.ToString("yyyy-MM-dd"),
        DenialDateFrom = Model.Filters.DenialDateFrom?.ToString("yyyy-MM-dd"),
        DenialDateTo = Model.Filters.DenialDateTo?.ToString("yyyy-MM-dd"),
        ActiveTab = "denial-insight",
        Page = Model.Filters.Page,
        PageSize = Model.Filters.PageSize,
        InsightPage = page,
        InsightPageSize = Model.Filters.InsightPageSize,
        LineItemPage = Model.Filters.LineItemPage,
        LineItemPageSize = Model.Filters.LineItemPageSize
    }) ?? "#";
    string LineItemPageUrl(int page) => Url.Action("Index", "DenialDashboard", new
    {
        LabId = Model.Filters.LabId,
        Status = Model.Filters.Status,
        Priority = Model.Filters.Priority,
        ActionCategory = Model.Filters.ActionCategory,
        Deadline = Model.Filters.Deadline,
        Classification = Model.Filters.Classification,
        SalesRepname = Model.Filters.SalesRepname,
        ClinicName = Model.Filters.ClinicName,
        ReferringProvider = Model.Filters.ReferringProvider,
        PayerName = Model.Filters.PayerName,
        PayerType = Model.Filters.PayerType,
        PanelName = Model.Filters.PanelName,
        FirstBilledDateFrom = Model.Filters.FirstBilledDateFrom?.ToString("yyyy-MM-dd"),
        FirstBilledDateTo = Model.Filters.FirstBilledDateTo?.ToString("yyyy-MM-dd"),
        DateOfServiceFrom = Model.Filters.DateOfServiceFrom?.ToString("yyyy-MM-dd"),
        DateOfServiceTo = Model.Filters.DateOfServiceTo?.ToString("yyyy-MM-dd"),
        DenialDateFrom = Model.Filters.DenialDateFrom?.ToString("yyyy-MM-dd"),
        DenialDateTo = Model.Filters.DenialDateTo?.ToString("yyyy-MM-dd"),
        ActiveTab = "line-item",
        Page = Model.Filters.Page,
        PageSize = Model.Filters.PageSize,
        InsightPage = Model.Filters.InsightPage,
        InsightPageSize = Model.Filters.InsightPageSize,
        LineItemPage = page,
        LineItemPageSize = Model.Filters.LineItemPageSize
    }) ?? "#";
}
<style>
    .filter-shell {
        border-radius: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .section-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1b3a5c;
        letter-spacing: .01em;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: .92rem;
        margin-top: .15rem;
    }

    .filter-select,
    .table-search-input,
    .accordion-search-input {
        border-radius: .75rem;
        border: 1px solid #d8e2ee;
        min-height: 42px;
    }

        .filter-select:focus,
        .table-search-input:focus,
        .accordion-search-input:focus {
            border-color: #5b9df9;
            box-shadow: 0 0 0 .2rem rgba(91, 157, 249, .15);
        }

    .msf {
        position: relative;
    }

    .msf-toggle {
        display: flex;
        align-items: center;
        min-height: 42px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .msf-menu {
        position: absolute;
        inset: calc(100% + .35rem) 0 auto 0;
        z-index: 1080;
        background: #fff;
        border: 1px solid #d8e2ee;
        border-radius: .9rem;
        padding: .6rem;
    }

    .msf-search-wrap {
        margin-bottom: .45rem;
    }

    .msf-actions {
        display: flex;
        justify-content: space-between;
        font-size: .82rem;
        margin-bottom: .45rem;
    }

    .msf-options {
        max-height: 210px;
        overflow: auto;
        display: grid;
        gap: .2rem;
    }

    .msf-option {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .3rem .25rem;
        border-radius: .55rem;
        cursor: pointer;
    }

        .msf-option:hover {
            background: #f4f8fd;
        }

        .msf-option input {
            margin: 0;
        }

    .msf-empty {
        padding: .5rem .35rem;
        color: #6b7280;
        font-size: .85rem;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .35rem .7rem;
        border-radius: 999px;
        background: #eef4fb;
        color: #294766;
        font-size: .8rem;
        font-weight: 600;
        border: 1px solid #d9e5f2;
    }

    .chip-muted {
        background: #f3f4f6;
        border-color: #e5e7eb;
        color: #4b5563;
    }

    .chip-warning {
        background: #fff8e6;
        border-color: #fde7a8;
        color: #9a6700;
    }

    .chip-success {
        background: #e9f9ef;
        border-color: #b7ebc7;
        color: #146c43;
    }

    .chip-danger {
        background: #feeaec;
        border-color: #f5b9c0;
        color: #b42318;
    }

    .dashboard-tabs {
        gap: .6rem;
        border-bottom: 0;
    }

        .dashboard-tabs .nav-link {
            border: 1px solid #d8e2ee;
            color: #34516f;
            border-radius: .85rem;
            background: #fff;
            padding: .65rem 1rem;
            font-weight: 600;
            box-shadow: 0 4px 14px rgba(15, 23, 42, .04);
        }

            .dashboard-tabs .nav-link:hover {
                background: #f4f8fd;
                border-color: #c6d7ea;
            }

            .dashboard-tabs .nav-link.active {
                color: #fff;
                border-color: #1f6feb;
                background: linear-gradient(135deg, #1565c0 0%, #1f6feb 100%);
                box-shadow: 0 10px 24px rgba(31, 111, 235, .25);
            }

    .mini-panel,
    .table-card {
        border: 1px solid #e3ebf5;
        border-radius: 1rem;
        background: #fff;
        padding: 1rem;
        height: auto;
    }

    .mini-panel-title {
        font-weight: 700;
        color: #294766;
        margin-bottom: .8rem;
        font-size: .95rem;
    }

    .kpi-card {
        border-radius: 1rem;
        padding: 1rem 1.1rem;
        color: #15314b;
        background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
        border: 1px solid #d9e6f5;
        box-shadow: 0 8px 20px rgba(15, 23, 42, .05);
        min-height: 114px;
    }

        .kpi-card.accent-blue {
            background: linear-gradient(180deg, #e9f3ff 0%, #ffffff 100%);
            border-color: #cddff9;
        }

        .kpi-card.accent-amber {
            background: linear-gradient(180deg, #fff7e8 0%, #ffffff 100%);
            border-color: #f6deb0;
        }

        .kpi-card.accent-green {
            background: linear-gradient(180deg, #ecfbf1 0%, #ffffff 100%);
            border-color: #c4ebcf;
        }

        .kpi-card.accent-red {
            background: linear-gradient(180deg, #fff0f1 0%, #ffffff 100%);
            border-color: #f3c2c7;
        }

        .kpi-card.accent-purple {
            background: linear-gradient(180deg, #f6efff 0%, #ffffff 100%);
            border-color: #decdf7;
        }

        .kpi-card.accent-rose {
            background: linear-gradient(180deg, #fff0f7 0%, #ffffff 100%);
            border-color: #f2c9dd;
        }

        .kpi-card.accent-dark {
            background: linear-gradient(180deg, #eef2f7 0%, #ffffff 100%);
            border-color: #d4dde7;
        }

    .kpi-label {
        color: #5c738a;
        font-size: .84rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: .45rem;
    }

    .kpi-value {
        font-size: 1.65rem;
        font-weight: 800;
        line-height: 1.15;
        color: #0f2942;
    }

    .table-search {
        position: relative;
        min-width: 240px;
    }

        .table-search .bi-search {
            position: absolute;
            top: 50%;
            left: .85rem;
            transform: translateY(-50%);
            color: #7b8794;
            z-index: 2;
        }

        .table-search .form-control {
            padding-left: 2.35rem;
            border-radius: .8rem;
        }

    .app-table thead th {
        background: #f6f9fc;
        color: #37516b;
        font-size: .82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .03em;
        border-bottom-width: 1px;
        white-space: nowrap;
    }

    .app-table tbody td {
        vertical-align: middle;
        color: #213547;
    }

    .app-table tbody tr:hover {
        background: #f9fbff;
    }

    .narrow-cell {
        max-width: 220px;
        white-space: normal;
    }

    .badge-soft-primary {
        background: #e8f1ff;
        color: #1557b0;
    }

    .badge-soft-warning {
        background: #fff4db;
        color: #9a6700;
    }

    .badge-soft-success {
        background: #e9f9ef;
        color: #146c43;
    }

    .badge-soft-secondary {
        background: #eef0f4;
        color: #4b5563;
    }

    .badge-soft-danger {
        background: #feeaec;
        color: #b42318;
    }

    .badge-soft-dark {
        background: #e5e7eb;
        color: #111827;
    }

    .badge-soft-info {
        background: #e8fbff;
        color: #0f5d78;
    }

    .badge-soft-primary,
    .badge-soft-warning,
    .badge-soft-success,
    .badge-soft-secondary,
    .badge-soft-danger,
    .badge-soft-dark,
    .badge-soft-info {
        border-radius: 999px;
        padding: .45rem .7rem;
        font-weight: 700;
        font-size: .76rem;
    }

    .app-accordion .accordion-item {
        border: 1px solid #dfe7f2;
        border-radius: 1rem;
        overflow: hidden;
        margin-bottom: .85rem;
        box-shadow: 0 8px 20px rgba(15, 23, 42, .04);
    }

    .app-accordion .accordion-button {
        background: #fff;
        font-weight: 600;
        color: #213547;
        box-shadow: none;
        gap: .4rem;
    }

        .app-accordion .accordion-button:not(.collapsed) {
            background: #f7fbff;
            color: #0f2942;
        }

    .app-accordion .accordion-body {
        background: #fcfdff;
    }

    .tab-content > .tab-pane {
        animation: fadeInUp .18s ease-in-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(4px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 767.98px) {
        .table-search {
            min-width: 100%;
        }

        .kpi-value {
            font-size: 1.35rem;
        }
    }
</style>
<link href="~/css/denial_dashboard.css" rel="stylesheet" />
<div id="pageLoader" class="hidden" aria-live="polite" aria-busy="true">
    <div class="page-loader-card">
        <div class="page-loader-spinner"></div>
        @*     <div class="fw-semibold text-primary mb-1">Loading dashboard data...</div>
      <div class="small text-muted">Please wait while the selected lab data is prepared.</div> *@
    </div>
</div>
@if (TempData["DenialDashboardSuccess"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success border-0 shadow-sm">@successMessage</div>
}
@if (TempData["DenialDashboardError"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-warning border-0 shadow-sm">@errorMessage</div>
}
<div class="filter-shell card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="section-title">Global filters</div>
                @* <div class="section-subtitle">Lab options now come from LRNMaster.dbo.LRNMetricsLab. The selected lab resolves its ConnectionKey from appsettings and loads Task Board, Denial Insight, and Line Item from that lab database.</div> *@
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2 ms-auto">
                <div class="text-end me-2">
                    <div class="small text-muted">Data source for selected lab</div>
                    <div class="fw-semibold">@Model.CurrentLabName · @Model.AllRecordCount.ToString("N0") rows · @Model.FilteredRecordCount.ToString("N0") visible after filtering</div>
                </div>
                <button class="btn btn-outline-primary rounded-pill px-3" type="button" data-bs-toggle="collapse" data-bs-target="#dashboardFiltersCollapse" aria-expanded="true" aria-controls="dashboardFiltersCollapse" id="filterCollapseToggle">
                    <i class="bi bi-sliders me-1"></i><span class="filter-toggle-text">Hide Filters</span>
                </button>
            </div>
        </div>

        <div class="collapse show" id="dashboardFiltersCollapse">
            <form method="get" class="row g-3 align-items-end filter-form-grid" id="dashboardFilterForm">
                <div class="col-12">
                    <div class="filter-group-heading">Workflow filters</div>
                </div>

                <input type="hidden" name="ActiveTab" id="activeTabInput" value="@activeTab" />
                <input type="hidden" name="Page" value="1" />
                <input type="hidden" name="InsightPage" value="1" />
                <input type="hidden" name="LineItemPage" value="1" />
                <input type="hidden" name="PageSize" value="@Model.Filters.PageSize" />
                <input type="hidden" name="InsightPageSize" value="@Model.Filters.InsightPageSize" />
                <input type="hidden" name="LineItemPageSize" value="@Model.Filters.LineItemPageSize" />

                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Lab <span class="text-danger">*</span></label>
                    <select class="form-select filter-select" id="labSelect" name="LabId" required>
                        @if (Model.LabOptions.Any())
                        {
                            @foreach (var option in Model.LabOptions)
                            {
                                if (option.LabId == Model.Filters.LabId)
                                {
                                    <option value="@option.LabId" selected>@option.LabName</option>
                                }
                                else
                                {
                                    <option value="@option.LabId">@option.LabName</option>
                                }
                            }
                        }
                        else
                        {
                            <option value="">No labs available</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Task Status</label>
                    <div class="multi-select-filter" data-name="Status" data-placeholder="All statuses" data-options='@Html.Raw(JsonSerializer.Serialize(Model.StatusOptions.Where(x => x != "(All)")))' data-selected='@Html.Raw(JsonSerializer.Serialize(SelectedValues(Model.Filters.Status, true)))'></div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Priority</label>
                    <div class="multi-select-filter" data-name="Priority" data-placeholder="All priorities" data-options='@Html.Raw(JsonSerializer.Serialize(Model.PriorityOptions.Where(x => x != "(All)")))' data-selected='@Html.Raw(JsonSerializer.Serialize(SelectedValues(Model.Filters.Priority, true)))'></div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Classification</label>
                    <div class="multi-select-filter" data-name="Classification" data-placeholder="All classifications" data-options='@Html.Raw(JsonSerializer.Serialize(Model.ClassificationOptions.Where(x => x != "(All)")))' data-selected='@Html.Raw(JsonSerializer.Serialize(SelectedValues(Model.Filters.Classification, true)))'></div>
                </div>

                <div class="col-12">
                    <div class="filter-group-heading filter-group-heading-secondary">Payer / service filters</div>
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Action Category</label>
                    <div class="multi-select-filter" data-name="ActionCategory" data-placeholder="All action categories" data-options='@Html.Raw(JsonSerializer.Serialize(Model.ActionCategoryOptions.Where(x => x != "(All)")))' data-selected='@Html.Raw(JsonSerializer.Serialize(SelectedValues(Model.Filters.ActionCategory, true)))'></div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">SLA</label>
                    <div class="multi-select-filter" data-name="Deadline" data-placeholder="All SLA buckets" data-options='@Html.Raw(JsonSerializer.Serialize(Model.DeadlineOptions.Where(x => x != "(All)")))' data-selected='@Html.Raw(JsonSerializer.Serialize(SelectedValues(Model.Filters.Deadline, true)))'></div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Payer Name</label>
                    <div class="multi-select-filter remote-multi-select" data-name="PayerName" data-placeholder="Select payer names" data-remote-key="payerNames" data-options='[]' data-selected='@Html.Raw(JsonSerializer.Serialize(SelectedValues(Model.Filters.PayerName)))'></div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Payer Type</label>
                    <div class="multi-select-filter remote-multi-select" data-name="PayerType" data-placeholder="Select payer types" data-remote-key="payerTypes" data-options='[]' data-selected='@Html.Raw(JsonSerializer.Serialize(SelectedValues(Model.Filters.PayerType)))'></div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Panel Name</label>
                    <div class="multi-select-filter remote-multi-select" data-name="PanelName" data-placeholder="Select panel names" data-remote-key="panelNames" data-options='[]' data-selected='@Html.Raw(JsonSerializer.Serialize(SelectedValues(Model.Filters.PanelName)))'></div>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label">Referring Provider</label>
