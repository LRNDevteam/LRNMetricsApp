@using System.Globalization
@model LabMetricsDashboard.ViewModels.LisSummaryPageViewModel
@{
    ViewData["Title"] = "LIS Summary";
    var result = Model.Result;
    var monthColumns = new List<(string Key, int Year, string Label, bool IsYearTotal)>();
    if (result is not null)
    {
        foreach (var year in result.Years.OrderBy(x => x))
        {
            var yearMonths = result.Months.Where(x => x.StartsWith($"{year:D4}-", StringComparison.OrdinalIgnoreCase)).OrderBy(x => x).ToList();
            foreach (var monthKey in yearMonths)
            {
                var month = int.Parse(monthKey[^2..]);
                monthColumns.Add((monthKey, year, new DateTime(year, month, 1).ToString("MMM-yyyy"), false));
            }
            if (yearMonths.Count > 0)
            {
                monthColumns.Add(($"{year:D4}-TOTAL", year, $"{year} Total", true));
            }
        }
    }

    var useUploadedLogicTemplate = result?.LogicSheetName?.Equals("Augustus", StringComparison.OrdinalIgnoreCase) == true
        || result?.LogicSheetName?.Equals("Certus", StringComparison.OrdinalIgnoreCase) == true;
    var logicTemplateCss = useUploadedLogicTemplate ? "lis-template-with-logic" : string.Empty;
    string DateValue(DateOnly? value) => value?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? string.Empty;
    string RowCss(int level) => level <= 0 ? "lis-summary-section-row" : level == 1 ? "lis-summary-level-one" : "lis-summary-level-two";
}

<style>
    .lis-filter-shell {
        border-radius: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }
    .section-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1b3a5c;
    }
    .section-subtitle {
        color: #6b7280;
        font-size: .92rem;
        margin-top: .15rem;
    }
    .filter-select {
        border-radius: .75rem;
        border: 1px solid #d8e2ee;
        min-height: 42px;
    }
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .35rem .7rem;
        border-radius: 999px;
        background: #eef4fb;
        color: #294766;
        font-size: .8rem;
        font-weight: 600;
        border: 1px solid #d9e5f2;
    }
    .table-card {
        border: 1px solid #e3ebf5;
        border-radius: 1rem;
        background: #fff;
        padding: 1rem;
    }
    .lis-summary-table {
        border-color: #d8e2ee;
        font-size: .86rem;
    }
    .lis-summary-table thead th {
        background: #dce8f6;
        color: #1b3a5c;
        font-weight: 700;
        text-align: center;
        vertical-align: middle;
        white-space: nowrap;
        border: 1px solid #afc4df;
    }
    .lis-summary-table thead .year-header th {
        background: #bfd5ee;
    }
    .lis-summary-table tbody td {
        border: 1px solid #dde7f0;
        vertical-align: top;
    }
    .lis-summary-table .logic-col {
        min-width: 420px;
        max-width: 620px;
        white-space: normal;
    }
    .lis-summary-table .desc-col {
        min-width: 250px;
    }
    .lis-summary-table .count-cell {
        text-align: right;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }
    .lis-summary-section-row td {
        background: #f6f9fc;
        font-weight: 700;
    }
    .lis-summary-level-one td:nth-child(2) {
        font-weight: 700;
    }
    .lis-summary-level-two td:nth-child(2) {
        padding-left: 2rem;
    }
    .lis-summary-table.lis-template-with-logic .logic-col {
        width: 420px !important;
        min-width: 420px !important;
        max-width: 420px !important;
        white-space: normal;
    }
    .year-total-cell {
        background: #f8fbff;
        font-weight: 700;
    }
    .grand-total-cell,
    .grand-total-row td {
        background: #fff2cc !important;
        font-weight: 800;
    }


    /* Excel-style LIS freeze pane */
    .lis-freeze-scroll {
        width: 100%;
        max-height: min(74vh, calc(100vh - 230px));
        overflow: auto;
        position: relative;
        border: 1px solid #d8e2ee;
        border-radius: .85rem;
        background: #fff;
        scrollbar-gutter: stable both-edges;
    }
    .lis-summary-table.lis-freeze-table {
        width: max-content !important;
        min-width: 100% !important;
        table-layout: fixed;
        border-collapse: separate !important;
        border-spacing: 0 !important;
    }
    .lis-summary-table.lis-freeze-table th,
    .lis-summary-table.lis-freeze-table td {
        background-clip: padding-box;
    }
    .lis-summary-table.lis-freeze-table thead th {
        position: sticky;
        top: var(--lis-sticky-top, 0px);
        z-index: 40;
    }
    .lis-summary-table.lis-freeze-table .lis-code-col {
        width: 56px !important;
        min-width: 56px !important;
        max-width: 56px !important;
        text-align: center;
    }
    .lis-summary-table.lis-freeze-table .desc-col {
        width: 300px !important;
        min-width: 300px !important;
        max-width: 300px !important;
        white-space: normal;
    }
    .lis-summary-table.lis-freeze-table .sticky-col-1,
    .lis-summary-table.lis-freeze-table .sticky-col-2,
    .lis-summary-table.lis-freeze-table .sticky-col-3 {
        position: sticky;
        background: #fff;
        z-index: 18;
    }
    .lis-summary-table.lis-freeze-table .sticky-col-1 { left: 0; }
    .lis-summary-table.lis-freeze-table .sticky-col-2 { left: 56px; box-shadow: 1px 0 0 #dde7f0; }
    .lis-summary-table.lis-freeze-table .sticky-col-3 { left: 356px; box-shadow: 1px 0 0 #dde7f0; }
    .lis-summary-table.lis-freeze-table thead .sticky-col-1,
    .lis-summary-table.lis-freeze-table thead .sticky-col-2,
    .lis-summary-table.lis-freeze-table thead .sticky-col-3 {
        z-index: 70;
        background: #123b63;
        color: #fff;
    }
    .lis-summary-table.lis-freeze-table .count-cell,
    .lis-summary-table.lis-freeze-table th:not(.desc-col):not(.lis-code-col):not(.logic-col) {
        width: 96px;
        min-width: 96px;
        max-width: 96px;
        white-space: nowrap;
    }
    .lis-summary-section-row .sticky-col-1,
    .lis-summary-section-row .sticky-col-2,
    .lis-summary-section-row .sticky-col-3 { background: #f6f9fc !important; }
    .grand-total-row .sticky-col-1,
    .grand-total-row .sticky-col-2,
    .grand-total-row .sticky-col-3 { background: #fff2cc !important; }

</style>

@if (TempData["LisSummaryError"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-warning border-0 shadow-sm">@error</div>
}

<div class="lis-filter-shell card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="section-title">LIS Summary</div>
                <div class="section-subtitle">Grouped by collected date and calculated using the lab-specific Excel logic.</div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <span class="chip">Lab: @(string.IsNullOrWhiteSpace(Model.CurrentLabName) ? "-" : Model.CurrentLabName)</span>
                @if (result is not null)
                {
                    <span class="chip">Logic: @result.LogicSheetName</span>
                    <span class="chip">Total: @result.GrandTotal.ToString("N0")</span>
                }
            </div>
        </div>

        <form method="get" asp-action="Index" asp-controller="LisSummary" class="row g-3 align-items-end">
            <div class="col-12 col-md-4 col-xl-3">
                <label class="form-label">Lab <span class="text-danger">*</span></label>
                <select class="form-select filter-select" name="LabId" required>
                    @foreach (var lab in Model.LabOptions)
                    {
                        if (lab.LabId == Model.Filters.LabId)
                        {
                            <option value="@lab.LabId" selected>@lab.LabName</option>
                        }
                        else
                        {
                            <option value="@lab.LabId">@lab.LabName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-4 col-xl-3">
                <label class="form-label">Collected From</label>
                <input class="form-control filter-select" type="date" name="CollectedFrom" value="@DateValue(Model.Filters.CollectedFrom)" />
            </div>
            <div class="col-12 col-md-4 col-xl-3">
                <label class="form-label">Collected To</label>
                <input class="form-control filter-select" type="date" name="CollectedTo" value="@DateValue(Model.Filters.CollectedTo)" />
            </div>
            <div class="col-12 col-xl-3 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-funnel me-1"></i>Apply Filters
                </button>
                <a class="btn btn-outline-success rounded-pill px-3" href="@Url.Action("ExportToExcel", "LisSummary", new { LabId = Model.Filters.LabId, CollectedFrom = Model.Filters.CollectedFrom?.ToString("yyyy-MM-dd"), CollectedTo = Model.Filters.CollectedTo?.ToString("yyyy-MM-dd") })">
                    <i class="bi bi-file-earmark-excel me-1"></i>Export Excel
                </a>
            </div>
        </form>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning border-0 shadow-sm">@Model.ErrorMessage</div>
}
else if (result is null)
{
    <div class="alert alert-info border-0 shadow-sm">No LIS Summary data found.</div>
}
else
{
    <div class="card border-0 shadow-sm table-card">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <div class="section-title">@result.LogicSheetName Summary</div>
                    <div class="section-subtitle">Format follows the attached Excel logic workbook.</div>
                </div>
                <span class="chip">Rows: @result.Rows.Count.ToString("N0")</span>
            </div>

            <div class="lis-freeze-scroll" id="lisSummaryFreeze">
                <table class="table table-sm lis-summary-table lis-freeze-table align-middle mb-0 @logicTemplateCss">
                    <thead>
                        <tr class="year-header">
                            <th rowspan="2" class="lis-code-col sticky-col-1">@(useUploadedLogicTemplate ? "S.No" : "#")</th>
                            <th rowspan="2" class="desc-col sticky-col-2">LIS STATUS SUMMARY</th>
                            @if (useUploadedLogicTemplate)
                            {
                                <th rowspan="2" class="logic-col sticky-col-3">Logic</th>
                            }
                            @foreach (var year in result.Years.OrderBy(x => x))
                            {
                                var yearMonthCount = monthColumns.Count(x => x.Year == year);
                                if (yearMonthCount > 0)
                                {
                                    <th colspan="@yearMonthCount">@year</th>
                                }
                            }
                            <th rowspan="2" class="grand-total-cell">Total</th>
                        </tr>
                        <tr>
                            @foreach (var column in monthColumns)
                            {
                                <th class="@(column.IsYearTotal ? "year-total-cell" : "")">@column.Label</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in result.Rows)
                        {
                            <tr class="@RowCss(row.Level)">
                                <td class="lis-code-col sticky-col-1">@row.Code</td>
                                <td class="desc-col sticky-col-2">@row.Description</td>
                                @if (useUploadedLogicTemplate)
                                {
                                    <td class="logic-col sticky-col-3">@row.Logic</td>
                                }
                                @foreach (var column in monthColumns)
                                {
                                    if (column.IsYearTotal)
                                    {
                                        <td class="count-cell year-total-cell">@(row.ByYear.TryGetValue(column.Year, out var yearTotal) ? yearTotal.ToString("N0") : "0")</td>
                                    }
                                    else
                                    {
                                        <td class="count-cell">@(row.ByMonth.TryGetValue(column.Key, out var monthTotal) ? monthTotal.ToString("N0") : "0")</td>
                                    }
                                }
                                <td class="count-cell grand-total-cell">@row.Total.ToString("N0")</td>
                            </tr>
                        }
                        <tr class="grand-total-row">
                            <td class="lis-code-col sticky-col-1"></td>
                            <td class="desc-col sticky-col-2">Grand Total</td>
                            @if (useUploadedLogicTemplate)
                            {
                                <td class="logic-col sticky-col-3"></td>
                            }
                            @foreach (var column in monthColumns)
                            {
                                if (column.IsYearTotal)
                                {
                                    <td class="count-cell">@(result.GrandTotalByYear.TryGetValue(column.Year, out var yearTotal) ? yearTotal.ToString("N0") : "0")</td>
                                }
                                else
                                {
                                    <td class="count-cell">@(result.GrandTotalByMonth.TryGetValue(column.Key, out var monthTotal) ? monthTotal.ToString("N0") : "0")</td>
                                }
                            }
                            <td class="count-cell">@result.GrandTotal.ToString("N0")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}


<script>
    (function () {
        const root = document.getElementById('lisSummaryFreeze');
        if (!root) return;

        const updateLisHeaderOffsets = () => {
            let top = 0;
            root.querySelectorAll('thead tr').forEach(row => {
                row.querySelectorAll('th').forEach(cell => cell.style.setProperty('--lis-sticky-top', `${top}px`));
                top += row.getBoundingClientRect().height;
            });
        };

        requestAnimationFrame(updateLisHeaderOffsets);
        window.addEventListener('resize', updateLisHeaderOffsets, { passive: true });
    })();
</script>
